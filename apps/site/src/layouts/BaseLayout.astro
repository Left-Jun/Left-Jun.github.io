---
import "../styles/global.css";
import Sidebar from "../components/Sidebar.astro";
import SiteTopChrome from "../components/SiteTopChrome.astro";
import ResponsiveImage from "../components/ResponsiveImage.astro";
import { config, siteText } from "../lib/content.js";
import { resolveLanguageSwitchUrl } from "../lib/navigation.js";
import { resolveVisualTheme } from "../lib/visual-themes";
import {
  buildAlternateLinks,
  buildStructuredData,
  languageCode,
  resolveSiteUrl,
  serializeJsonLd
} from "../lib/seo";
import type {
  BreadcrumbInput,
  CreativeWorkInput,
  OpenGraphType,
  SiteLanguage
} from "../lib/seo";

interface Props {
  lang?: SiteLanguage;
  title?: string;
  description?: string;
  image?: string;
  imageAlt?: string;
  priorityImage?: string;
  priorityImageSrcset?: string;
  priorityImageSizes?: string;
  priorityImageType?: string;
  active?: string;
  bodyClass?: string;
  canonicalUrl?: string;
  alternateUrl?: string;
  alternatePath?: string;
  alternateLang?: SiteLanguage;
  ogType?: OpenGraphType;
  creativeWork?: CreativeWorkInput;
  breadcrumbs?: BreadcrumbInput[];
  shellMode?: "full" | "minimal";
  visualTheme?: string;
}

const {
  lang = "zh-cn",
  title = config.title,
  description = config.description,
  image = `/${config.opengraph?.image || "img/avatar.jpg"}`,
  imageAlt = config.opengraph?.imageAlt || title,
  priorityImage = "",
  priorityImageSrcset = "",
  priorityImageSizes = "",
  priorityImageType = "",
  active = "",
  bodyClass = "",
  canonicalUrl = "",
  alternateUrl = "",
  alternatePath = "",
  alternateLang,
  ogType,
  creativeWork,
  breadcrumbs = [],
  shellMode = "full",
  visualTheme = ""
} = Astro.props as Props;

const text = siteText(lang);
const pageTitle = title === config.title ? title : `${title} - ${config.title}`;
const pageDescription = description || config.description;
const canonical = resolveSiteUrl(canonicalUrl || Astro.url.pathname, config.siteUrl);
const pageImageUrl = resolveSiteUrl(image, config.siteUrl);
const personImageUrl = resolveSiteUrl(
  `/${config.languages?.["zh-cn"]?.sidebar?.avatar || config.opengraph?.image || "img/avatar.jpg"}`,
  config.siteUrl
);
const priorityImageUrl = priorityImage;
const hreflangLinks = buildAlternateLinks({
  siteUrl: config.siteUrl,
  canonicalUrl: canonical,
  lang,
  alternateUrl,
  alternatePath,
  alternateLang
});
const resolvedOgType: OpenGraphType = ogType || (
  creativeWork?.type === "Article" || creativeWork?.type === "BlogPosting" ? "article" : "website"
);
const sameAs = (config.languages?.["zh-cn"]?.menus?.social || []).map((item) => item.url).filter(Boolean);
const structuredData = buildStructuredData({
  siteName: config.title,
  siteUrl: config.siteUrl,
  canonicalUrl: canonical,
  pageTitle,
  pageDescription,
  pageImageUrl,
  personImageUrl,
  lang,
  sameAs,
  creativeWork,
  breadcrumbs
});
const structuredDataJson = serializeJsonLd(structuredData);
const rssUrl = lang === "en" ? "/en/feed.xml" : "/feed.xml";
const footerText = text.isEn ? "Built with Astro" : "";
const hasRightSidebar = Astro.slots.has("right-sidebar");
const languageSwitchUrl = resolveLanguageSwitchUrl({
  lang,
  active,
  alternateUrl,
  alternatePath
});
const skipLinkLabel = text.isEn ? "Skip to main content" : "跳到主要内容";
const resolvedVisualTheme = resolveVisualTheme(visualTheme);
---
<!doctype html>
<html lang={lang === "en" ? "en" : "zh-CN"}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta id="theme-color" name="theme-color" content="#ebf5fc" />
    <script is:inline>
      (() => {
        const root = document.documentElement;
        const preferred = matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light";
        let scheme = preferred;
        try {
          const saved = localStorage.getItem("LeftJunColorScheme") || localStorage.getItem("LeftJunAstroColorScheme");
          if (saved === "dark" || saved === "light") scheme = saved;
        } catch {}
        root.dataset.scheme = scheme;
        document.querySelector("#theme-color")?.setAttribute("content", scheme === "dark" ? "#171b1a" : "#ebf5fc");
      })();
    </script>
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <meta name="keywords" content={(config.keywords || []).join(", ")} />
    <link rel="canonical" href={canonical} />
    {hreflangLinks.map((link) => <link rel="alternate" hreflang={link.hreflang} href={link.href} />)}
    <link rel="alternate" type="application/rss+xml" title={lang === "en" ? "Left Jun - Updates" : "Left Jun - Latest Updates"} href={rssUrl} />
    <link rel="icon" href={config.favicon || "/favicon.ico"} sizes="any" />
    <link rel="icon" type="image/png" href="/favicon-48.png" sizes="48x48" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" sizes="180x180" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content={config.title} />
    <meta property="og:type" content={resolvedOgType} />
    <meta property="og:locale" content={languageCode(lang).replace("-", "_")} />
    {hreflangLinks.length > 0 && <meta property="og:locale:alternate" content={languageCode(lang === "en" ? "zh-cn" : "en").replace("-", "_")} />}
    <meta property="og:image" content={pageImageUrl} />
    <meta property="og:image:alt" content={imageAlt} />
    <meta name="twitter:card" content={config.opengraph?.twitter?.card || "summary_large_image"} />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={pageImageUrl} />
    <meta name="twitter:image:alt" content={imageAlt} />
    <script type="application/ld+json" is:inline set:html={structuredDataJson}></script>
    <script is:inline>
      (() => {
        try {
          if (
            sessionStorage.getItem("LeftJunLanguageTransition") === "1" &&
            !matchMedia("(prefers-reduced-motion: reduce)").matches
          ) {
            document.documentElement.classList.add("language-transition-running", "language-transition-entering");
          }
        } catch {}
      })();
    </script>
    {priorityImageUrl && (
      <link
        rel="preload"
        as="image"
        href={priorityImageUrl}
        imagesrcset={priorityImageSrcset || undefined}
        imagesizes={priorityImageSizes || undefined}
        type={priorityImageType || undefined}
        fetchpriority="high"
      />
    )}
    <slot name="head" />
  </head>
  <body class={bodyClass} data-visual-theme={resolvedVisualTheme?.id}>
    {resolvedVisualTheme && (
      <div class="visual-theme-backdrop" aria-hidden="true" data-visual-theme-backdrop>
        <ResponsiveImage
          src={resolvedVisualTheme.background}
          alt=""
          class="visual-theme-backdrop__image"
          pictureClass="visual-theme-backdrop__picture"
          sizes="100vw"
          loading="eager"
          fetchpriority="low"
          style={`object-position: ${resolvedVisualTheme.backgroundPosition};`}
        />
      </div>
    )}
    <a class="skip-link" href="#main-content">{skipLinkLabel}</a>
    {shellMode === "minimal" ? (
      <div class="container main-container standalone-shell">
        <main class="main full-width main-column standalone-main" id="main-content" tabindex="-1">
          <slot />
        </main>
      </div>
    ) : (
      <div class="container main-container flex on-phone--column extended site-shell">
        <Sidebar lang={lang} active={active} switchUrl={languageSwitchUrl} />
        <div class:list={["site-content-layout", hasRightSidebar && "has-right-sidebar"]}>
          <main class="main full-width main-column" id="main-content" tabindex="-1">
            <SiteTopChrome lang={lang} active={active} />
            <slot />
            <footer class="site-footer">
              <section class="copyright footer-single-line">
                &copy; {new Date().getFullYear()} {config.title}{footerText && <span> · {footerText}</span>}
              </section>
            </footer>
          </main>
          {hasRightSidebar && <slot name="right-sidebar" />}
        </div>
      </div>
    )}
    <script is:inline>
      (() => {
        const root = document.documentElement;
        const reduceMotionQuery = matchMedia("(prefers-reduced-motion: reduce)");
        const reduceMotion = reduceMotionQuery.matches;
        const languageTransitionKey = "LeftJunLanguageTransition";
        const languageRectsKey = "LeftJunLanguageRects";
        const normalClick = (event) => event.button === 0 && !event.metaKey && !event.ctrlKey && !event.shiftKey && !event.altKey;

        const languageTransitionSelectors = [
          ".left-sidebar",
          ".home-topbar",
          ".home-hero__content",
          ".home-hero__stage",
          ".home-tech-stack__pills",
          ".mobile-bottom-nav",
          ".right-sidebar",
          ".project-card",
          ".home-plan-card",
          ".post-card",
          ".main-article"
        ].join(",");

        const languageTransitionName = (element) => {
          if (element.matches(".left-sidebar")) return "lj-sidebar";
          if (element.matches(".home-topbar")) return "lj-topbar";
          if (element.matches(".home-hero__content")) return "lj-home-hero-copy";
          if (element.matches(".home-hero__stage")) return "lj-home-hero-stage";
          if (element.matches(".home-tech-stack__pills")) return "lj-tech-stack";
          if (element.matches(".mobile-bottom-nav")) return "lj-mobile-bottom-nav";
          if (element.matches(".right-sidebar")) return "lj-right-sidebar";
          return getComputedStyle(element).getPropertyValue("--leftjun-language-transition-name").trim();
        };

        const minLanguageRectSize = 4;
        const minLanguageScale = 0.72;
        const maxLanguageScale = 1.38;
        const languageLayoutWaitBudget = 120;
        const languageLayoutAnimationDuration = 820;
        const languageTransitionCleanupDelay = languageLayoutWaitBudget + languageLayoutAnimationDuration + 80;

        const isUsableLanguageRect = (rect) =>
          rect &&
          Number.isFinite(rect.left) &&
          Number.isFinite(rect.top) &&
          Number.isFinite(rect.width) &&
          Number.isFinite(rect.height) &&
          rect.width >= minLanguageRectSize &&
          rect.height >= minLanguageRectSize;

        const isVisibleLanguageElement = (element) => {
          const style = getComputedStyle(element);
          return style.display !== "none" && style.visibility !== "hidden" && element.getClientRects().length > 0;
        };

        const nextLanguageFrame = () => new Promise((resolve) => requestAnimationFrame(resolve));

        const waitForLanguageLayout = async () => {
          await nextLanguageFrame();
          await nextLanguageFrame();
          if (!document.fonts?.ready) return;
          await Promise.race([
            document.fonts.ready.catch(() => undefined),
            new Promise((resolve) => window.setTimeout(resolve, languageLayoutWaitBudget))
          ]);
        };

        const collectLanguageRects = () => {
          const rects = {};
          document.querySelectorAll(languageTransitionSelectors).forEach((element) => {
            const name = languageTransitionName(element);
            if (!name || name === "none") return;
            if (!isVisibleLanguageElement(element)) return;
            const rect = element.getBoundingClientRect();
            if (!isUsableLanguageRect(rect)) return;
            rects[name] = {
              left: rect.left,
              top: rect.top,
              width: rect.width,
              height: rect.height
            };
          });
          return rects;
        };

        const animateLanguageRects = (previousRects) => {
          if (reduceMotionQuery.matches || !previousRects) return;
          document.querySelectorAll(languageTransitionSelectors).forEach((element) => {
            const name = languageTransitionName(element);
            const previous = name ? previousRects[name] : null;
            if (!isUsableLanguageRect(previous) || !isVisibleLanguageElement(element)) return;
            const rect = element.getBoundingClientRect();
            if (!isUsableLanguageRect(rect)) return;
            const deltaX = previous.left - rect.left;
            const deltaY = previous.top - rect.top;
            const scaleX = previous.width / rect.width;
            const scaleY = previous.height / rect.height;
            const stableScale =
              Number.isFinite(scaleX) &&
              Number.isFinite(scaleY) &&
              scaleX >= minLanguageScale &&
              scaleX <= maxLanguageScale &&
              scaleY >= minLanguageScale &&
              scaleY <= maxLanguageScale;
            const fromTransform = stableScale
              ? `translate(${deltaX}px, ${deltaY}px) scale(${scaleX}, ${scaleY})`
              : `translate(${deltaX}px, ${deltaY}px)`;
            if (
              Math.abs(deltaX) < 0.5 &&
              Math.abs(deltaY) < 0.5 &&
              (!stableScale || (Math.abs(scaleX - 1) < 0.005 && Math.abs(scaleY - 1) < 0.005))
            ) return;
            const animation = element.animate(
              [
                {
                  transform: fromTransform,
                  transformOrigin: "top left"
                },
                {
                  transform: "translate(0, 0) scale(1, 1)",
                  transformOrigin: "top left"
                }
              ],
              {
                duration: 820,
                easing: "cubic-bezier(0.22, 1, 0.36, 1)",
                fill: "none",
                composite: "add"
              }
            );
            animation.finished.catch(() => undefined);
          });
        };

        const finishLanguagePageTurn = () => {
          if (!root.classList.contains("language-transition-running")) return;
          window.setTimeout(() => {
            root.classList.remove("language-transition-running", "language-transition-entering", "language-transition-exiting");
          }, reduceMotion ? 0 : languageTransitionCleanupDelay);
        };

        try {
          if (sessionStorage.getItem(languageTransitionKey) === "1") {
            let previousRects = {};
            try {
              previousRects = JSON.parse(sessionStorage.getItem(languageRectsKey) || "{}");
            } catch {}
            sessionStorage.removeItem(languageTransitionKey);
            sessionStorage.removeItem(languageRectsKey);
            waitForLanguageLayout().then(() => animateLanguageRects(previousRects));
            finishLanguagePageTurn();
          }
        } catch {}

        document.addEventListener("click", (event) => {
          const link = event.target.closest("a[data-language-transition]");
          if (!(link instanceof HTMLAnchorElement) || event.defaultPrevented || !normalClick(event)) return;
          const target = new URL(link.href, window.location.href);
          if (target.origin !== window.location.origin || reduceMotionQuery.matches) return;
          event.preventDefault();
          try {
            sessionStorage.setItem(languageTransitionKey, "1");
            sessionStorage.setItem(languageRectsKey, JSON.stringify(collectLanguageRects()));
          } catch {}
          root.classList.add("language-transition-running", "language-transition-exiting");
          window.setTimeout(() => {
            window.location.href = target.href;
          }, 190);
        });

        window.LeftJunTransitions = {
          runThemeTransition(trigger, update) {
            if (reduceMotionQuery.matches || typeof document.startViewTransition !== "function") {
              update();
              return;
            }

            const rect = trigger?.getBoundingClientRect?.();
            const x = rect ? rect.left + rect.width / 2 : window.innerWidth / 2;
            const y = rect ? rect.top + rect.height / 2 : window.innerHeight / 2;
            const radius = Math.hypot(
              Math.max(x, window.innerWidth - x),
              Math.max(y, window.innerHeight - y)
            );

            root.style.setProperty("--theme-transition-x", `${x}px`);
            root.style.setProperty("--theme-transition-y", `${y}px`);
            root.style.setProperty("--theme-transition-radius", `${radius}px`);
            root.classList.add("theme-transition-running");

            const transition = document.startViewTransition(() => update());
            transition.ready
              .then(() => {
                root.animate(
                  [
                    { clipPath: `circle(0px at ${x}px ${y}px)` },
                    { clipPath: `circle(${radius}px at ${x}px ${y}px)` }
                  ],
                  {
                    duration: 420,
                    easing: "cubic-bezier(0.2, 0.84, 0.2, 1)",
                    fill: "both",
                    pseudoElement: "::view-transition-new(root)"
                  }
                );
              })
              .catch(() => {});

            transition.finished.finally(() => {
              root.classList.remove("theme-transition-running");
              root.style.removeProperty("--theme-transition-x");
              root.style.removeProperty("--theme-transition-y");
              root.style.removeProperty("--theme-transition-radius");
            });
          }
        };

        const anchorSelector = [
          ".right-sidebar a[href^='#']",
          ".article-toc a[href^='#']",
          ".project-index-list a[href^='#']"
        ].join(",");
        const tocLinks = Array.from(document.querySelectorAll(".right-sidebar .toc-nav a[href^='#'], .article-toc .toc-nav a[href^='#']"));

        const findTarget = (hash) => {
          if (!hash || hash === "#") return null;
          const rawId = hash.slice(1);
          let decodedId = rawId;
          try {
            decodedId = decodeURIComponent(rawId);
          } catch {
            decodedId = rawId;
          }
          return document.getElementById(decodedId) || document.getElementById(rawId);
        };

        const normalizeHash = (hash) => {
          if (!hash) return "";
          try {
            return `#${decodeURIComponent(hash.slice(1))}`;
          } catch {
            return hash;
          }
        };

        const keepSidebarTocLinkVisible = (link) => {
          const nav = link.closest(".right-sidebar .toc-nav");
          if (!nav) return;
          const padding = 18;
          const linkTop = link.offsetTop;
          const linkBottom = linkTop + link.offsetHeight;
          const viewTop = nav.scrollTop;
          const viewBottom = viewTop + nav.clientHeight;
          let nextTop = viewTop;

          if (linkTop < viewTop + padding) {
            nextTop = Math.max(0, linkTop - padding);
          } else if (linkBottom > viewBottom - padding) {
            nextTop = Math.min(nav.scrollHeight - nav.clientHeight, linkBottom - nav.clientHeight + padding);
          }

          if (Math.abs(nextTop - viewTop) < 1) return;
          nav.scrollTo({
            top: nextTop,
            behavior: reduceMotion ? "auto" : "smooth"
          });
        };

        let activeTocHash = "";
        const setActiveToc = (hash) => {
          const normalized = normalizeHash(hash);
          let activeSidebarLink = null;
          tocLinks.forEach((link) => {
            const isActive = normalizeHash(link.hash) === normalized;
            link.classList.toggle("is-active", isActive);
            if (isActive && link.closest(".right-sidebar")) activeSidebarLink = link;
          });
          if (activeSidebarLink && normalized !== activeTocHash) keepSidebarTocLinkVisible(activeSidebarLink);
          activeTocHash = normalized;
        };

        const tocTargets = tocLinks
          .map((link) => ({ link, hash: link.hash, target: findTarget(link.hash) }))
          .filter((item, index, list) => item.target && list.findIndex((other) => other.target === item.target) === index);

        document.addEventListener("click", (event) => {
          const link = event.target.closest(anchorSelector);
          if (!link) return;
          const url = new URL(link.href, window.location.href);
          if (url.pathname !== window.location.pathname || !url.hash) return;
          const target = findTarget(url.hash);
          if (!target) return;
          event.preventDefault();
          const scrollToTarget = () => {
            target.scrollIntoView({
              behavior: reduceMotion ? "auto" : "smooth",
              block: "start"
            });
          };
          const settleTarget = () => {
            const top = Math.abs(target.getBoundingClientRect().top);
            if (top > 96) scrollToTarget();
          };
          scrollToTarget();
          window.setTimeout(settleTarget, 520);
          window.setTimeout(settleTarget, 1350);
          history.pushState(null, "", url.hash);
          setActiveToc(url.hash);
          const mobileToc = link.closest(".article-toc");
          if (mobileToc && matchMedia("(max-width: 767px)").matches) {
            const details = mobileToc.querySelector("details");
            window.setTimeout(() => {
              if (details) details.open = false;
            }, reduceMotion ? 0 : 260);
          }
        });

        if (tocTargets.length > 0) {
          let ticking = false;
          const updateActiveToc = () => {
            ticking = false;
            const offset = parseFloat(getComputedStyle(document.documentElement).getPropertyValue("--main-top-padding")) || 0;
            let active = tocTargets[0].hash;
            for (const item of tocTargets) {
              if (item.target.getBoundingClientRect().top <= offset + 120) active = item.hash;
            }
            setActiveToc(active);
          };
          setActiveToc(location.hash || tocTargets[0].hash);
          updateActiveToc();
          window.addEventListener("scroll", () => {
            if (ticking) return;
            ticking = true;
            requestAnimationFrame(updateActiveToc);
          }, { passive: true });
          window.addEventListener("resize", updateActiveToc, { passive: true });
        }

        const initLocalFilters = () => {
          const localButtons = Array.from(document.querySelectorAll("[data-local-filter][data-local-filter-kind]"));
          const recordButtons = Array.from(document.querySelectorAll("[data-record-filter]"));
          const filterLists = Array.from(document.querySelectorAll("[data-local-filter-list]"));
          const recordSections = Array.from(document.querySelectorAll("[data-record-section]"));
          if (localButtons.length === 0 && recordButtons.length === 0) return;

          const cards = filterLists.length > 0
            ? Array.from(document.querySelectorAll("[data-local-filter-list] .post-card"))
            : Array.from(document.querySelectorAll(".post-card[data-entry-tags], .post-card[data-entry-categories]"));
          const allowedRecords = new Set(recordButtons.map((button) => button.dataset.recordFilter).filter(Boolean));
          let activeRecord = "";
          let activeLocalKind = "";
          let activeLocalValue = "";

          const termList = (card, kind) => String(card.dataset[`entry${kind === "categories" ? "Categories" : "Tags"}`] || "")
            .split(/\s+/)
            .filter(Boolean);

          const cardMatches = (card) => {
            const recordMatch = !activeRecord || card.closest("[data-record-section]")?.dataset.recordSection === activeRecord;
            const localMatch = !activeLocalKind || termList(card, activeLocalKind).includes(activeLocalValue);
            return recordMatch && localMatch;
          };

          const applyFilters = () => {
            localButtons.forEach((button) => {
              const active = button.dataset.localFilterKind === activeLocalKind && button.dataset.localFilter === activeLocalValue;
              button.classList.toggle("is-active", active);
              button.setAttribute("aria-pressed", active ? "true" : "false");
            });

            recordButtons.forEach((button) => {
              const active = Boolean(activeRecord && button.dataset.recordFilter === activeRecord);
              button.classList.toggle("is-active", active);
              button.setAttribute("aria-pressed", active ? "true" : "false");
            });

            cards.forEach((card) => {
              card.hidden = !cardMatches(card);
            });

            recordSections.forEach((section) => {
              const sectionCards = Array.from(section.querySelectorAll(".post-card"));
              const hasVisibleCard = sectionCards.some((card) => !card.hidden);
              const recordMismatch = Boolean(activeRecord && section.dataset.recordSection !== activeRecord);
              section.hidden = recordMismatch || !hasVisibleCard;
            });
          };

          localButtons.forEach((button) => {
            button.addEventListener("click", () => {
              const nextKind = button.dataset.localFilterKind || "";
              const nextValue = button.dataset.localFilter || "";
              if (activeLocalKind === nextKind && activeLocalValue === nextValue) {
                activeLocalKind = "";
                activeLocalValue = "";
              } else {
                activeLocalKind = nextKind;
                activeLocalValue = nextValue;
              }
              applyFilters();
            });
          });

          recordButtons.forEach((button) => {
            button.addEventListener("click", () => {
              const next = button.dataset.recordFilter || "";
              activeRecord = activeRecord === next || !allowedRecords.has(next) ? "" : next;
              applyFilters();
            });
          });

          applyFilters();
        };

        if (document.readyState === "loading") {
          document.addEventListener("DOMContentLoaded", initLocalFilters, { once: true });
        } else {
          requestAnimationFrame(initLocalFilters);
        }
      })();
    </script>
  </body>
</html>
