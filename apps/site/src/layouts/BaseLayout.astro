---
import "../styles/global.css";
import Sidebar from "../components/Sidebar.astro";
import SiteTopChrome from "../components/SiteTopChrome.astro";
import { config, siteText } from "../lib/content.js";

const {
  lang = "zh-cn",
  title = config.title,
  description = config.description,
  image = `/${config.opengraph?.image || "img/avatar.jpg"}`,
  active = "home",
  bodyClass = ""
} = Astro.props;

const text = siteText(lang);
const pageTitle = title === config.title ? title : `${title} - ${config.title}`;
const canonical = new URL(Astro.url.pathname, config.siteUrl).toString();
const footerText = text.isEn ? "Built with Astro" : "自定义静态作品集";
const hasRightSidebar = Astro.slots.has("right-sidebar");
---
<!doctype html>
<html lang={lang === "en" ? "en" : "zh-CN"}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description || config.description} />
    <meta name="keywords" content={(config.keywords || []).join(", ")} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href={config.favicon || "/favicon.ico"} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description || config.description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content={config.title} />
    <meta property="og:image" content={new URL(image, config.siteUrl).toString()} />
    <meta name="twitter:card" content={config.opengraph?.twitter?.card || "summary_large_image"} />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description || config.description} />
    <meta name="theme-color" content="#ebf5fc" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#171b1a" media="(prefers-color-scheme: dark)" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Lato:wght@300;400;700&display=swap" />
  </head>
  <body class={bodyClass}>
    <div class="container main-container flex on-phone--column extended site-shell">
      <Sidebar lang={lang} active={active} />
      <div class:list={["site-content-layout", hasRightSidebar && "has-right-sidebar"]}>
        <main class="main full-width main-column">
          <SiteTopChrome lang={lang} active={active} />
          <slot />
          <footer class="site-footer">
            <section class="copyright footer-single-line">
              &copy; {new Date().getFullYear()} {config.title} · {footerText}
            </section>
          </footer>
        </main>
        {hasRightSidebar && <slot name="right-sidebar" />}
      </div>
    </div>
    <script is:inline>
      (() => {
        const reduceMotion = matchMedia("(prefers-reduced-motion: reduce)").matches;
        const anchorSelector = [
          ".right-sidebar a[href^='#']",
          ".article-toc a[href^='#']",
          ".project-index-list a[href^='#']"
        ].join(",");
        const tocLinks = Array.from(document.querySelectorAll(".right-sidebar .toc-nav a[href^='#'], .article-toc .toc-nav a[href^='#']"));

        const findTarget = (hash) => {
          if (!hash || hash === "#") return null;
          const rawId = hash.slice(1);
          let decodedId = rawId;
          try {
            decodedId = decodeURIComponent(rawId);
          } catch {
            decodedId = rawId;
          }
          return document.getElementById(decodedId) || document.getElementById(rawId);
        };

        const normalizeHash = (hash) => {
          if (!hash) return "";
          try {
            return `#${decodeURIComponent(hash.slice(1))}`;
          } catch {
            return hash;
          }
        };

        const keepSidebarTocLinkVisible = (link) => {
          const nav = link.closest(".right-sidebar .toc-nav");
          if (!nav) return;
          const padding = 18;
          const linkTop = link.offsetTop;
          const linkBottom = linkTop + link.offsetHeight;
          const viewTop = nav.scrollTop;
          const viewBottom = viewTop + nav.clientHeight;
          let nextTop = viewTop;

          if (linkTop < viewTop + padding) {
            nextTop = Math.max(0, linkTop - padding);
          } else if (linkBottom > viewBottom - padding) {
            nextTop = Math.min(nav.scrollHeight - nav.clientHeight, linkBottom - nav.clientHeight + padding);
          }

          if (Math.abs(nextTop - viewTop) < 1) return;
          nav.scrollTo({
            top: nextTop,
            behavior: reduceMotion ? "auto" : "smooth"
          });
        };

        let activeTocHash = "";
        const setActiveToc = (hash) => {
          const normalized = normalizeHash(hash);
          let activeSidebarLink = null;
          tocLinks.forEach((link) => {
            const isActive = normalizeHash(link.hash) === normalized;
            link.classList.toggle("is-active", isActive);
            if (isActive && link.closest(".right-sidebar")) activeSidebarLink = link;
          });
          if (activeSidebarLink && normalized !== activeTocHash) keepSidebarTocLinkVisible(activeSidebarLink);
          activeTocHash = normalized;
        };

        const tocTargets = tocLinks
          .map((link) => ({ link, hash: link.hash, target: findTarget(link.hash) }))
          .filter((item, index, list) => item.target && list.findIndex((other) => other.target === item.target) === index);

        document.addEventListener("click", (event) => {
          const link = event.target.closest(anchorSelector);
          if (!link) return;
          const url = new URL(link.href, window.location.href);
          if (url.pathname !== window.location.pathname || !url.hash) return;
          const target = findTarget(url.hash);
          if (!target) return;
          event.preventDefault();
          const scrollToTarget = () => {
            target.scrollIntoView({
              behavior: reduceMotion ? "auto" : "smooth",
              block: "start"
            });
          };
          const settleTarget = () => {
            const top = Math.abs(target.getBoundingClientRect().top);
            if (top > 96) scrollToTarget();
          };
          scrollToTarget();
          window.setTimeout(settleTarget, 520);
          window.setTimeout(settleTarget, 1350);
          history.pushState(null, "", url.hash);
          setActiveToc(url.hash);
          const mobileToc = link.closest(".article-toc");
          if (mobileToc && matchMedia("(max-width: 767px)").matches) {
            const details = mobileToc.querySelector("details");
            window.setTimeout(() => {
              if (details) details.open = false;
            }, reduceMotion ? 0 : 260);
          }
        });

        if (tocTargets.length > 0) {
          let ticking = false;
          const updateActiveToc = () => {
            ticking = false;
            const offset = parseFloat(getComputedStyle(document.documentElement).getPropertyValue("--main-top-padding")) || 0;
            let active = tocTargets[0].hash;
            for (const item of tocTargets) {
              if (item.target.getBoundingClientRect().top <= offset + 120) active = item.hash;
            }
            setActiveToc(active);
          };
          setActiveToc(location.hash || tocTargets[0].hash);
          updateActiveToc();
          window.addEventListener("scroll", () => {
            if (ticking) return;
            ticking = true;
            requestAnimationFrame(updateActiveToc);
          }, { passive: true });
          window.addEventListener("resize", updateActiveToc, { passive: true });
        }
      })();
    </script>
  </body>
</html>
