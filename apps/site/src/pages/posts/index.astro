---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PostCard from "../../components/PostCard.astro";
import RightSidebar from "../../components/RightSidebar.astro";
import { getEntries, getSectionPage } from "../../lib/content.js";

const lang = "zh-cn";
const section = await getSectionPage("posts", lang);
const posts = await getEntries("posts", { lang });
const columnDefinitions = [
  {
    id: "technical",
    label: "技术集合",
    badge: "专栏 · 技术集合",
    eyebrow: "专栏",
    title: "技术集合",
    description: "收录建站、工具链与技术实现相关的阶段性笔记。",
    terms: ["Astro", "建站", "技术"]
  }
];
const columnSections = columnDefinitions
  .map((column) => {
    const termSet = new Set(column.terms.map((term) => term.toLowerCase()));
    const entries = posts.filter((entry: (typeof posts)[number]) => {
      const terms = [...(entry.data.categories || []), ...(entry.data.tags || [])].map((term) =>
        String(term).toLowerCase()
      );
      return terms.some((term) => termSet.has(term));
    });
    return { ...column, entries };
  })
  .filter((column) => column.entries.length > 0);
const columnBadgesBySlug = new Map(
  posts.map((entry: (typeof posts)[number]) => [
    entry.slug,
    columnSections
      .filter((column) => column.entries.some((item: (typeof posts)[number]) => item.slug === entry.slug))
      .map((column) => column.badge)
  ])
);
const hasColumns = columnSections.length > 0;
const postColumnBadges = (entry: (typeof posts)[number]) => columnBadgesBySlug.get(entry.slug) || [];
---
<BaseLayout lang={lang} title={section.data.title} description={section.data.description} active="posts" bodyClass="list-page posts-index-page">
  <header>
    <h3 class="section-title">文章与专栏</h3>
    <section class="section-card posts-section-card">
      <div class="section-details">
        <h3 class="section-count">{posts.length} 篇内容</h3>
        <h1 class="section-term">{section.data.title}</h1>
        <h2 class="section-description">{section.data.description}</h2>
        {hasColumns && (
          <div class="project-section-actions posts-section-actions" data-posts-view-controls>
            <div class="project-filter-toggle posts-view-toggle" role="group" aria-label="切换文章与专栏视图">
              <button class="project-filter-toggle__button is-active" type="button" data-posts-view-target="all" aria-pressed="true">全部文章</button>
              <button class="project-filter-toggle__button" type="button" data-posts-view-target="columns" aria-pressed="false">专栏</button>
            </div>
          </div>
        )}
      </div>
    </section>
  </header>

  <section class="records-section posts-all-section posts-view-panel" data-posts-view-panel="all" aria-labelledby="all-posts-title">
    <div class="records-section__header">
      <div>
        <p class="records-section__eyebrow">全部</p>
        <h2 id="all-posts-title">全部文章</h2>
      </div>
      <span>{posts.length}</span>
    </div>
    <div class="article-list--compact" id="posts-list" data-local-filter-list>
      {posts.map((entry: (typeof posts)[number]) => <PostCard entry={entry} columnBadges={postColumnBadges(entry)} />)}
    </div>
  </section>

  {hasColumns && (
    <div class="posts-columns-panel posts-view-panel" data-posts-view-panel="columns" hidden>
      {columnSections.map((column) => (
        <section class="posts-column-section" aria-labelledby={`${column.id}-column-title`}>
          <div class="posts-column-section__header">
            <div>
              <p class="posts-column-section__eyebrow">{column.eyebrow}</p>
              <h2 id={`${column.id}-column-title`}>{column.title}</h2>
            </div>
            <span>{column.entries.length} 篇收录</span>
          </div>
          <p class="posts-column-section__description">{column.description}</p>
          <div class="article-list--compact posts-column-list">
            {column.entries.map((entry: (typeof posts)[number]) => <PostCard entry={entry} columnBadges={postColumnBadges(entry)} />)}
          </div>
        </section>
      ))}
    </div>
  )}

  <Fragment slot="right-sidebar">
    <RightSidebar lang={lang} entries={posts} />
  </Fragment>
  {hasColumns && (
    <script is:inline>
      (() => {
        const initPostsViewToggle = () => {
          const buttons = Array.from(document.querySelectorAll("[data-posts-view-target]"));
          const panels = Array.from(document.querySelectorAll("[data-posts-view-panel]"));
          if (buttons.length === 0 || panels.length === 0) return;
          const allowedViews = new Set(buttons.map((button) => button.dataset.postsViewTarget).filter(Boolean));

          const setView = (view) => {
            const nextView = allowedViews.has(view) ? view : "all";
            buttons.forEach((button) => {
              const active = button.dataset.postsViewTarget === nextView;
              button.classList.toggle("is-active", active);
              button.setAttribute("aria-pressed", active ? "true" : "false");
            });
            panels.forEach((panel) => {
              panel.hidden = panel.dataset.postsViewPanel !== nextView;
            });
          };

          buttons.forEach((button) => {
            button.addEventListener("click", () => setView(button.dataset.postsViewTarget || "all"));
          });

          document.querySelectorAll("[data-local-filter][data-local-filter-kind]").forEach((button) => {
            button.addEventListener("click", () => setView("all"));
          });

          setView("all");
        };

        if (document.readyState === "loading") {
          document.addEventListener("DOMContentLoaded", initPostsViewToggle, { once: true });
        } else {
          initPostsViewToggle();
        }
      })();
    </script>
  )}
</BaseLayout>
