---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PostCard from "../../components/PostCard.astro";
import RightSidebar from "../../components/RightSidebar.astro";
import { getEntries, getSectionPage } from "../../lib/content.js";

const section = await getSectionPage("retrospectives", "zh-cn");
const entries = await getEntries("retrospectives");
---
<BaseLayout title={section.data.title} description={section.data.description} active="retrospectives">
  <header>
    <h3 class="section-title">项目复盘</h3>
    <section class="section-card">
      <div class="section-details">
        <h3 class="section-count">{entries.length} 篇复盘</h3>
        <h1 class="section-term">{section.data.title}</h1>
        <h2 class="section-description">{section.data.description}</h2>
      </div>
    </section>
  </header>

  <section class="article-list--compact" id="retrospectives-list">
    {entries.map((entry) => <PostCard entry={entry} />)}
  </section>
  <Fragment slot="right-sidebar">
    <RightSidebar entries={entries} />
  </Fragment>
</BaseLayout>
