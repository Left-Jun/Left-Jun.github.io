---
import RecordsPage from "../../../components/RecordsPage.astro";
import { getEntries } from "../../../lib/content.js";

const lang = "en";
const [projects, retrospectives, plans] = await Promise.all([
  getEntries("projects", { lang }),
  getEntries("retrospectives", { lang }),
  getEntries("plans", { lang })
]);
---
<RecordsPage
  lang={lang}
  title="Project Retrospectives and Development Plans"
  description="Project-centered threads connecting evidence from completed work with the next validation plan, including decisions, tradeoffs, feedback, and iteration direction."
  alternatePath="/retrospectives/"
  active="retrospectives"
  initialView="all"
  projects={projects}
  retrospectives={retrospectives}
  plans={plans}
/>
