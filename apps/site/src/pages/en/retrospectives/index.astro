---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import PostCard from "../../../components/PostCard.astro";
import RightSidebar from "../../../components/RightSidebar.astro";
import { getEntries, getSectionPage } from "../../../lib/content.js";

type ListingEntry = {
  slug: string;
  url: string;
  data: {
    title: string;
    description?: string;
    categories?: string[];
    tags?: string[];
    date?: Date;
    image?: string;
    imagePosition?: string;
    [key: string]: unknown;
  };
  asset: (value: string) => string;
  formattedDate?: string;
  [key: string]: unknown;
};

const lang = "en";
const retrospectiveSection = await getSectionPage("retrospectives", lang);
const planSection = await getSectionPage("plans", lang);
const retrospectiveEntries = await getEntries("retrospectives", { lang }) as ListingEntry[];
const planEntries = await getEntries("plans", { lang }) as ListingEntry[];
const entries = [...retrospectiveEntries, ...planEntries];
const title = "Project Retrospectives and Development Plans";
const description = "A record line for completed project retrospectives and follow-up development plans.";
---
<BaseLayout lang={lang} title={title} description={description} alternatePath="/retrospectives/" active="retrospectives" bodyClass="list-page records-page">
  <header>
    <h3 class="section-title">{title}</h3>
    <section class="section-card">
      <div class="section-details">
        <h3 class="section-count">{retrospectiveEntries.length} retrospectives / {planEntries.length} plans</h3>
        <h1 class="section-term">{title}</h1>
        <h2 class="section-description">{description}</h2>
        <div class="project-section-actions records-section-actions">
          <div class="project-filter-toggle records-filter-toggle" role="group" aria-label="Filter project records">
            <button class="project-filter-toggle__button records-filter-button" type="button" data-record-filter="retrospectives">Retrospectives</button>
            <button class="project-filter-toggle__button records-filter-button" type="button" data-record-filter="plans">Development Plans</button>
          </div>
        </div>
      </div>
    </section>
  </header>

  <section class="records-section records-section--retrospectives" id="retrospectives-list" data-record-section="retrospectives" aria-labelledby="retrospectives-title">
    <div class="records-section__header">
      <div>
        <p class="records-section__eyebrow">Retrospectives</p>
        <h2 id="retrospectives-title">{retrospectiveSection.data.title}</h2>
      </div>
      <span>{retrospectiveEntries.length} posts</span>
    </div>
    <div class="article-list--compact records-section__list">
      {retrospectiveEntries.map((entry) => <PostCard entry={entry} />)}
    </div>
  </section>

  <section class="records-section records-section--plans" id="plans-list" data-record-section="plans" aria-labelledby="plans-title">
    <div class="records-section__header">
      <div>
        <p class="records-section__eyebrow">Plans</p>
        <h2 id="plans-title">{planSection.data.title}</h2>
      </div>
      <span>{planEntries.length} plans</span>
    </div>
    <div class="article-list--compact records-section__list">
      {planEntries.map((entry) => <PostCard entry={entry} />)}
    </div>
  </section>

  <Fragment slot="right-sidebar">
    <RightSidebar lang={lang} type="records" entries={entries} />
  </Fragment>
</BaseLayout>
