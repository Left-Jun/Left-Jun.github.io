---
import ArticleLayout from "../../../components/ArticleLayout.astro";
import { getEntries } from "../../../lib/content.js";
import type { SiteEntry } from "../../../lib/content.js";

type PathEntry = { slug: string; [key: string]: unknown };

export async function getStaticPaths() {
  const entries = await getEntries("retrospectives", { lang: "en" }) as PathEntry[];
  return entries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry }
  }));
}

const { entry } = Astro.props as { entry: SiteEntry };
---
<ArticleLayout entry={entry} active="retrospectives" />
