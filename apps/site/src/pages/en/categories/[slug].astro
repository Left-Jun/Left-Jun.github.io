---
import TaxonomyPage from "../../../components/TaxonomyPage.astro";
import { getTaxonomyTerm, getTaxonomyTerms } from "../../../lib/content.js";

export async function getStaticPaths() {
  const terms = await getTaxonomyTerms("categories", "en");
  return terms.map((term) => ({ params: { slug: term.slug } }));
}

const term = await getTaxonomyTerm("categories", Astro.params.slug, "en");
---
<TaxonomyPage kind="categories" term={term} lang="en" />
