---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ProjectCard from "../../components/ProjectCard.astro";
import PostCard from "../../components/PostCard.astro";
import Icon from "../../components/Icon.astro";
import {
  getEntries,
  getEntryBySlug,
  relatedEntries,
  siteText,
  workflowItems,
  taxonomyTermUrl
} from "../../lib/content.js";

const lang = "en";
const text = siteText(lang);
const projects = await getEntries("projects", { lang });
const preferredSlugs = ["ashe-lament", "emotion-mask", "smart-boat"];
const heroProjects = preferredSlugs
  .map((slug) => projects.find((entry) => entry.slug === slug))
  .filter(Boolean);
const featured = heroProjects;
const posts = (await getEntries("posts", { lang })).slice(0, 2);
const plans = (await getEntries("plans")).slice(0, 2);
const planCards = await Promise.all(plans.map(async (entry) => ({
  entry,
  retrospective: (await relatedEntries(entry)).find((item) => item.section === "retrospectives")
})));
const workflows = await Promise.all(workflowItems.map(async (item) => ({
  ...item,
  linked: (await Promise.all(item.slugs.map((slug) => getEntryBySlug("projects", slug, lang)))).filter(Boolean)
})));
const techStack = [
  { label: "C# / .NET", href: taxonomyTermUrl("tags", "C#", lang) },
  { label: "Unity", href: taxonomyTermUrl("tags", "Unity", lang) },
  { label: "STM32", href: taxonomyTermUrl("tags", "STM32", lang) },
  { label: "C / C++", href: taxonomyTermUrl("tags", "C", lang) },
  { label: "Photoshop", href: taxonomyTermUrl("tags", "Photoshop", lang) }
];
---
<BaseLayout lang={lang} title="Left Jun - Gameplay Programmer & Embedded Developer" active="home" bodyClass="home-page">
  <section class="home-hero" data-hero-carousel aria-label="Featured project carousel">
    <div class="home-hero__content">
      <p class="home-hero__eyebrow">Sichuan University · Electronic Information · Class of 2029</p>
      <h1 class="home-hero__title">Left Jun</h1>
      <p class="home-hero__role">Game Client / Gameplay Programmer / Embedded Developer</p>
      <p class="home-hero__subtitle">I build Unity / C# gameplay systems, playable jam prototypes, and STM32 hardware-software projects. This portfolio tracks what I implemented, how each system landed, and what still needs iteration.</p>
      <div class="home-hero__actions">
        <a class="home-action home-action--primary" href="/en/projects/"><Icon name="link" /><span>View Projects</span></a>
        <a class="home-action" href="/files/left-jun-portfolio.pdf" target="_blank" rel="noopener noreferrer"><Icon name="briefcase" /><span>Portfolio PDF</span></a>
        <a class="home-action" href="/en/about/"><Icon name="user" /><span>About</span></a>
      </div>

      <div class="home-hero__summary-list" aria-live="polite">
        {heroProjects.map((entry, index) => (
          <article class:list={["home-hero__summary", index === 0 && "is-active"]} data-hero-summary aria-hidden={index === 0 ? "false" : "true"}>
            <span>{index === 0 ? "Representative Project" : "Featured Project"}</span>
            <strong>{entry.data.title}</strong>
            {entry.data.description && <small>{entry.data.description}</small>}
            <div class="home-hero__summary-tags" aria-label="Project tags">
              {[...(entry.data.roleTags || []), ...(entry.data.tags || [])].slice(0, 4).map((tag) => <em>{tag}</em>)}
            </div>
          </article>
        ))}
      </div>
    </div>

    <div class="home-hero__stage">
      {heroProjects.map((entry, index) => {
        const image = entry.data.image ? entry.asset(entry.data.image) : "";
        const mediaPosition = entry.data.imagePosition || "center right";
        return (
          <article class:list={["home-hero__slide", index === 0 && "is-active"]} data-hero-slide aria-hidden={index === 0 ? "false" : "true"}>
            <a class="home-hero__media-link" href={entry.url} tabindex={index === 0 ? "0" : "-1"} aria-label={`View ${entry.data.title}`}>
              {image && (
                <span class="home-hero__media-blur" aria-hidden="true">
                  <img src={image} alt="" loading={index === 0 ? "eager" : "lazy"} style={`object-position: ${mediaPosition};`} />
                </span>
              )}
              <span class="home-hero__media-frame">
                {entry.data.coverVideo ? (
                  <video
                    autoplay={index === 0}
                    muted
                    loop
                    playsinline
                    preload={index === 0 ? "metadata" : "none"}
                    controlslist="nodownload noplaybackrate noremoteplayback"
                    disablepictureinpicture
                    disableRemotePlayback
                    poster={image || undefined}
                    style={`object-position: ${mediaPosition};`}
                    data-hero-video
                  >
                    <source src={entry.asset(entry.data.coverVideo)} type="video/mp4" />
                  </video>
                ) : image && (
                  <img src={image} alt={entry.data.title} loading={index === 0 ? "eager" : "lazy"} style={`object-position: ${mediaPosition};`} />
                )}
              </span>
              <span class="home-hero__project-link">
                <small>Representative Project</small>
                <strong>{entry.data.title}</strong>
                <Icon name="chevron-right" />
              </span>
            </a>
          </article>
        );
      })}
      <div class="home-hero__dots" role="tablist" aria-label="Switch featured project">
        {heroProjects.map((entry, index) => (
          <button type="button" data-hero-dot aria-label={`Switch to ${entry.data.title}`} aria-current={index === 0 ? "true" : undefined}>
            <span>{entry.data.title}</span>
          </button>
        ))}
      </div>
    </div>

    <a class="home-hero__scroll" href="#home-featured-work">
      <span>Scroll down</span>
      <Icon name="chevron-right" />
    </a>
  </section>

  <section class="home-dashboard" id="home-featured-work">
    <section class="home-section home-featured-projects">
      <div class="home-section__header">
        <div>
          <p class="home-section__eyebrow">{text.selectedWork}</p>
          <h2>{text.representativeProjects}</h2>
        </div>
        <a class="home-section__link" href="/en/projects/">{text.allProjects}</a>
      </div>
      <div class="home-project-grid">
        {featured.map((entry) => <ProjectCard entry={entry} compact />)}
      </div>
    </section>

    {planCards.length > 0 && (
      <section class="home-section home-development-plans">
        <div class="home-section__header">
          <div>
            <p class="home-section__eyebrow">{text.inProgress}</p>
            <h2>{text.developmentPlans}</h2>
          </div>
          <a class="home-section__link" href="/plans/">{text.allPlans}</a>
        </div>
        <div class="home-plan-grid">
          {planCards.map(({ entry, retrospective }) => (
            <article class="home-plan-card">
              <a class="home-plan-card__main" href={entry.url}>
                {entry.formattedDate && <span class="home-plan-card__meta">{entry.formattedDate}</span>}
                <span class="home-plan-card__title">{entry.data.title}</span>
                {entry.data.description && <span class="home-plan-card__description">{entry.data.description}</span>}
                {entry.data.tags?.length > 0 && (
                  <span class="home-plan-card__tags" aria-label="Plan tags">
                    {entry.data.tags.slice(0, 3).map((tag) => <span class="home-plan-card__tag">{tag}</span>)}
                  </span>
                )}
              </a>
              <span class="home-plan-card__actions">
                {retrospective && <a class="home-plan-card__pill home-plan-card__pill--retrospective" href={retrospective.url}>{text.viewRetrospective}</a>}
                <a class="home-plan-card__pill home-plan-card__pill--plan" href={entry.url}>{text.viewPlan}</a>
              </span>
            </article>
          ))}
        </div>
      </section>
    )}
  </section>

  {posts.length > 0 && (
    <section class="home-section home-latest-posts">
      <div class="home-section__header">
        <div>
          <p class="home-section__eyebrow">{text.latestNotes}</p>
          <h2>{text.postsAndRecords}</h2>
        </div>
        <a class="home-section__link" href="/en/posts/">{text.allPosts}</a>
      </div>
      <section class="article-list--compact home-post-list">
        {posts.map((entry) => <PostCard entry={entry} />)}
      </section>
    </section>
  )}

  <section class="home-section home-workflow">
    <div class="home-section__header">
      <div>
        <p class="home-section__eyebrow">{text.howIWork}</p>
        <h2>{text.fromIdea}</h2>
      </div>
    </div>
    <div class="home-workflow__grid">
      {workflows.map((item) => (
        <article class="home-workflow__item">
          <div class="home-workflow__body">
            <div class="home-workflow__icon"><Icon name={item.icon} /></div>
            <h3>{item.title.en}</h3>
            <p>{item.body.en}</p>
          </div>
          <div class="home-workflow__projects" aria-label="Representative projects">
            {item.linked.map((project) => (
              <a class="home-workflow__project" href={project.url}>
                <span class="home-workflow__project-label">{project.data.title}</span>
                {project.data.image && (
                  <span class="home-workflow__preview" aria-hidden="true">
                    <span class="home-workflow__preview-media">
                      <img src={project.asset(project.data.image)} loading="lazy" alt="" />
                    </span>
                    {project.data.description && <span class="home-workflow__preview-caption">{project.data.description}</span>}
                  </span>
                )}
              </a>
            ))}
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="home-section home-tech-stack" aria-labelledby="home-tech-stack-title">
    <div class="home-section__header">
      <div>
        <p class="home-section__eyebrow">Tools I use</p>
        <h2 id="home-tech-stack-title">Tech Stack</h2>
      </div>
    </div>
    <div class="home-tech-stack__pills" aria-label="Tech Stack">
      {techStack.map((item) => <a href={item.href}>{item.label}</a>)}
    </div>
  </section>

  <script is:inline>
    (() => {
      const hero = document.querySelector("[data-hero-carousel]");
      if (hero) {
        const slides = [...hero.querySelectorAll("[data-hero-slide]")];
        const summaries = [...hero.querySelectorAll("[data-hero-summary]")];
        const dots = [...hero.querySelectorAll("[data-hero-dot]")];
        const reduceMotion = matchMedia("(prefers-reduced-motion: reduce)").matches;
        let active = 0;
        let timer = null;
        let isPointerInside = false;
        let isFocusInside = false;
        const isPaused = () => isPointerInside || isFocusInside || hero.matches(":hover, :focus-within");

        const setSlide = (next) => {
          if (slides.length === 0) return;
          active = (next + slides.length) % slides.length;
          slides.forEach((slide, index) => {
            const isActive = index === active;
            slide.classList.toggle("is-active", isActive);
            slide.setAttribute("aria-hidden", isActive ? "false" : "true");
            slide.querySelectorAll("a").forEach((link) => link.setAttribute("tabindex", isActive ? "0" : "-1"));
            slide.querySelectorAll("video").forEach((video) => {
              if (isActive) video.play?.().catch(() => {});
              else video.pause?.();
            });
          });
          summaries.forEach((summary, index) => {
            const isActive = index === active;
            summary.classList.toggle("is-active", isActive);
            summary.setAttribute("aria-hidden", isActive ? "false" : "true");
          });
          dots.forEach((dot, index) => {
            if (index === active) dot.setAttribute("aria-current", "true");
            else dot.removeAttribute("aria-current");
          });
        };

        const stop = () => {
          if (timer) window.clearInterval(timer);
          timer = null;
        };

        const start = () => {
          stop();
          if (!reduceMotion && slides.length > 1 && !isPaused()) {
            timer = window.setInterval(() => {
              if (!isPaused()) setSlide(active + 1);
            }, 6000);
          }
        };

        dots.forEach((dot, index) => dot.addEventListener("click", () => {
          setSlide(index);
          start();
        }));
        hero.addEventListener("mouseenter", () => {
          isPointerInside = true;
          stop();
        });
        hero.addEventListener("mouseleave", () => {
          isPointerInside = false;
          start();
        });
        hero.addEventListener("focusin", () => {
          isFocusInside = true;
          stop();
        });
        hero.addEventListener("focusout", () => {
          isFocusInside = hero.matches(":focus-within");
          start();
        });

        const stage = hero.querySelector(".home-hero__stage");
        if (stage) {
          const swipeThreshold = 46;
          let startX = 0;
          let startY = 0;
          let isDragging = false;
          let suppressClick = false;

          const endDrag = (event) => {
            if (!isDragging) return;
            const deltaX = event.clientX - startX;
            const deltaY = event.clientY - startY;
            isDragging = false;
            stage.classList.remove("is-swiping");
            if (Math.abs(deltaX) > swipeThreshold && Math.abs(deltaX) > Math.abs(deltaY) * 1.2) {
              suppressClick = true;
              setSlide(active + (deltaX < 0 ? 1 : -1));
              window.setTimeout(() => {
                suppressClick = false;
              }, 0);
            }
            start();
          };

          stage.addEventListener("pointerdown", (event) => {
            if (event.pointerType === "mouse" && event.button !== 0) return;
            if (event.isPrimary === false) return;
            startX = event.clientX;
            startY = event.clientY;
            isDragging = true;
            stop();
            stage.setPointerCapture?.(event.pointerId);
          });
          stage.addEventListener("pointermove", (event) => {
            if (!isDragging) return;
            const deltaX = event.clientX - startX;
            const deltaY = event.clientY - startY;
            stage.classList.toggle("is-swiping", Math.abs(deltaX) > 12 && Math.abs(deltaX) > Math.abs(deltaY));
          });
          stage.addEventListener("pointerup", endDrag);
          stage.addEventListener("pointercancel", () => {
            isDragging = false;
            stage.classList.remove("is-swiping");
            start();
          });
          stage.addEventListener("click", (event) => {
            if (suppressClick) {
              event.preventDefault();
              event.stopPropagation();
              return;
            }
            const activeLink = stage.querySelector(".home-hero__slide.is-active .home-hero__media-link");
            if (activeLink?.href) {
              event.preventDefault();
              window.location.href = activeLink.href;
            }
          }, true);
        }

        setSlide(0);
        start();
      }

      if (!matchMedia("(hover: hover) and (pointer: fine)").matches) return;
      document.querySelectorAll(".home-workflow__item").forEach((card) => {
        card.addEventListener("pointermove", (event) => {
          const rect = card.getBoundingClientRect();
          const x = ((event.clientX - rect.left) / rect.width) * 100;
          const y = ((event.clientY - rect.top) / rect.height) * 100;
          card.style.setProperty("--cursor-x", `${x}%`);
          card.style.setProperty("--cursor-y", `${y}%`);
        });
        card.addEventListener("pointerleave", () => {
          card.style.removeProperty("--cursor-x");
          card.style.removeProperty("--cursor-y");
        });
      });
    })();
  </script>
</BaseLayout>
