---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ProjectCard from "../../components/ProjectCard.astro";
import PostCard from "../../components/PostCard.astro";
import Icon from "../../components/Icon.astro";
import {
  getEntries,
  getEntryBySlug,
  relatedEntries,
  siteText,
  workflowItems
} from "../../lib/content.js";

const lang = "en";
const text = siteText(lang);
const projects = await getEntries("projects", { lang });
const preferredSlugs = ["ashe-lament", "emotion-mask", "smart-boat"];
const preferredFeatured = preferredSlugs
  .map((slug) => projects.find((entry) => entry.slug === slug))
  .filter(Boolean);
const featured = [
  ...preferredFeatured,
  ...projects
    .filter((item) => item.data.featured && !preferredSlugs.includes(item.slug))
    .sort((a, b) => (a.data.featuredWeight || 0) - (b.data.featuredWeight || 0))
].slice(0, 3);
const heroProject = await getEntryBySlug("projects", "ashe-lament", lang) || featured[0];
const posts = (await getEntries("posts", { lang })).slice(0, 3);
const plans = (await getEntries("plans")).slice(0, 2);
const planCards = await Promise.all(plans.map(async (entry) => ({
  entry,
  retrospective: (await relatedEntries(entry)).find((item) => item.section === "retrospectives")
})));
const workflows = await Promise.all(workflowItems.map(async (item) => ({
  ...item,
  linked: (await Promise.all(item.slugs.map((slug) => getEntryBySlug("projects", slug, lang)))).filter(Boolean)
})));
const heroSkills = ["Unity", "C#", "STM32", "Game Design"];
const homeStats = [
  { icon: "briefcase", value: "5+", label: "Complete Projects" },
  { icon: "code", value: "20+", label: "Tech Demos" },
  { icon: "trophy", value: "3", label: "Game Jams" },
  { icon: "display", value: "2", label: "Exhibitions" }
];
---
<BaseLayout lang={lang} title="Left Jun - Gameplay Programmer & Indie Game Developer" active="home" bodyClass="home-page">
  <section class="home-hero">
    {heroProject && (
      <div class="home-hero__media" aria-hidden="true">
        {heroProject.data.coverVideo ? (
          <video
            autoplay
            muted
            loop
            playsinline
            preload="metadata"
            controlslist="nodownload noplaybackrate noremoteplayback"
            disablepictureinpicture
            disableRemotePlayback
            poster={heroProject.data.image ? heroProject.asset(heroProject.data.image) : undefined}
            style={`object-position: ${heroProject.data.imagePosition || "center"};`}
          >
            <source src={heroProject.asset(heroProject.data.coverVideo)} type="video/mp4" />
          </video>
        ) : heroProject.data.image && (
          <img src={heroProject.asset(heroProject.data.image)} alt="" loading="eager" style={`object-position: ${heroProject.data.imagePosition || "center"};`} />
        )}
      </div>
    )}
    <div class="home-hero__content">
      <p class="home-hero__eyebrow">Gameplay Programmer</p>
      <h1 class="home-hero__title">Left Jun</h1>
      <p class="home-hero__subtitle">Building Interactive Worlds Through Code and Design.</p>
      <div class="home-hero__skills" aria-label="Technical focus">
        {heroSkills.map((skill) => <span>{skill}</span>)}
      </div>
      <div class="home-hero__actions">
        <a class="home-action home-action--primary" href="/en/projects/"><Icon name="link" /><span>View My Work</span></a>
        <a class="home-action" href="/en/about/"><Icon name="user" /><span>Learn More</span></a>
      </div>
    </div>
    <div class="home-hero__project">
      <span>Featured Project</span>
      <strong>{heroProject?.data.title || "Elegy of Asherah"}</strong>
      <small>2D Platform Adventure / World Exploration / Narrative-Driven</small>
      <div class="home-hero__dots" aria-hidden="true"><span></span><span></span><span></span></div>
    </div>
  </section>

  <section class="home-stats" aria-label="Portfolio stats">
    {homeStats.map((stat) => (
      <div class="home-stat">
        <Icon name={stat.icon} />
        <strong>{stat.value}</strong>
        <span>{stat.label}</span>
      </div>
    ))}
  </section>

  <section class="home-section home-featured-projects">
    <div class="home-section__header">
      <div>
        <p class="home-section__eyebrow">{text.selectedWork}</p>
        <h2>{text.representativeProjects}</h2>
      </div>
      <a class="home-section__link" href="/en/projects/">{text.allProjects}</a>
    </div>
    <div class="home-project-grid">
      {featured.map((entry) => <ProjectCard entry={entry} compact />)}
    </div>
  </section>

  {planCards.length > 0 && (
    <section class="home-section home-development-plans">
      <div class="home-section__header">
        <div>
          <p class="home-section__eyebrow">{text.inProgress}</p>
          <h2>{text.developmentPlans}</h2>
        </div>
        <a class="home-section__link" href="/plans/">{text.allPlans}</a>
      </div>
      <div class="home-plan-grid">
        {planCards.map(({ entry, retrospective }) => (
          <article class="home-plan-card">
            <a class="home-plan-card__main" href={entry.url}>
              {entry.formattedDate && <span class="home-plan-card__meta">{entry.formattedDate}</span>}
              <span class="home-plan-card__title">{entry.data.title}</span>
              {entry.data.description && <span class="home-plan-card__description">{entry.data.description}</span>}
              {entry.data.tags?.length > 0 && (
                <span class="home-plan-card__tags" aria-label="Plan tags">
                  {entry.data.tags.slice(0, 3).map((tag) => <span class="home-plan-card__tag">{tag}</span>)}
                </span>
              )}
            </a>
            <span class="home-plan-card__actions">
              {retrospective && <a class="home-plan-card__pill home-plan-card__pill--retrospective" href={retrospective.url}>{text.viewRetrospective}</a>}
              <a class="home-plan-card__pill home-plan-card__pill--plan" href={entry.url}>{text.viewPlan}</a>
            </span>
          </article>
        ))}
      </div>
    </section>
  )}

  {posts.length > 0 && (
    <section class="home-section home-latest-posts">
      <div class="home-section__header">
        <div>
          <p class="home-section__eyebrow">{text.latestNotes}</p>
          <h2>{text.postsAndRecords}</h2>
        </div>
        <a class="home-section__link" href="/en/posts/">{text.allPosts}</a>
      </div>
      <section class="article-list--compact home-post-list">
        {posts.map((entry) => <PostCard entry={entry} />)}
      </section>
    </section>
  )}

  <section class="home-section home-workflow">
    <div class="home-section__header">
      <div>
        <p class="home-section__eyebrow">{text.howIWork}</p>
        <h2>{text.fromIdea}</h2>
      </div>
    </div>
    <div class="home-workflow__grid">
      {workflows.map((item) => (
        <article class="home-workflow__item">
          <div class="home-workflow__body">
            <div class="home-workflow__icon"><Icon name={item.icon} /></div>
            <h3>{item.title.en}</h3>
            <p>{item.body.en}</p>
          </div>
          <div class="home-workflow__projects" aria-label="Representative projects">
            {item.linked.map((project) => (
              <a class="home-workflow__project" href={project.url}>
                <span class="home-workflow__project-label">{project.data.title}</span>
                {project.data.image && (
                  <span class="home-workflow__preview" aria-hidden="true">
                    <span class="home-workflow__preview-media">
                      <img src={project.asset(project.data.image)} loading="lazy" alt="" />
                    </span>
                    {project.data.description && <span class="home-workflow__preview-caption">{project.data.description}</span>}
                  </span>
                )}
              </a>
            ))}
          </div>
        </article>
      ))}
    </div>
  </section>
  <script is:inline>
    (() => {
      if (!matchMedia("(hover: hover) and (pointer: fine)").matches) return;
      document.querySelectorAll(".home-workflow__item").forEach((card) => {
        card.addEventListener("pointermove", (event) => {
          const rect = card.getBoundingClientRect();
          const x = ((event.clientX - rect.left) / rect.width) * 100;
          const y = ((event.clientY - rect.top) / rect.height) * 100;
          card.style.setProperty("--cursor-x", `${x}%`);
          card.style.setProperty("--cursor-y", `${y}%`);
        });
        card.addEventListener("pointerleave", () => {
          card.style.removeProperty("--cursor-x");
          card.style.removeProperty("--cursor-y");
        });
      });
    })();
  </script>
</BaseLayout>
