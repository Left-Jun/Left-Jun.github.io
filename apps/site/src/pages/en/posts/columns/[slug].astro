---
import PostColumnPage from "../../../../components/PostColumnPage.astro";
import { getEntries, getSectionPage } from "../../../../lib/content.js";
import { getPostColumns } from "../../../../lib/post-columns.js";

const lang = "en";

export async function getStaticPaths() {
  const pathLang = "en";
  const posts = await getEntries("posts", { lang: pathLang });
  return getPostColumns(posts, pathLang).map((column) => ({
    params: { slug: column.id },
    props: { column }
  }));
}

const { column } = Astro.props;
const section = await getSectionPage("posts", lang);
---

<PostColumnPage
  lang={lang}
  section={section}
  column={column}
  alternatePath={`/posts/columns/${column.id}/`}
/>
