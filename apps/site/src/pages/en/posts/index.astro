---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import PostCard from "../../../components/PostCard.astro";
import RightSidebar from "../../../components/RightSidebar.astro";
import { getEntries, getSectionPage } from "../../../lib/content.js";

const lang = "en";
const section = await getSectionPage("posts", lang);
const posts = await getEntries("posts", { lang });
const technicalTerms = new Set(["Astro", "Site Building", "Technical Notes"].map((term) => term.toLowerCase()));
const technicalPosts = posts.filter((entry: (typeof posts)[number]) => {
  const terms = [...(entry.data.categories || []), ...(entry.data.tags || [])].map((term) =>
    String(term).toLowerCase()
  );
  return terms.some((term) => technicalTerms.has(term));
});
---
<BaseLayout lang={lang} title={section.data.title} description={section.data.description} active="posts" bodyClass="list-page posts-index-page">
  <header>
    <h3 class="section-title">Articles & Columns</h3>
    <section class="section-card">
      <div class="section-details">
        <h3 class="section-count">{posts.length} entries</h3>
        <h1 class="section-term">{section.data.title}</h1>
        <h2 class="section-description">{section.data.description}</h2>
      </div>
    </section>
  </header>

  {technicalPosts.length > 0 && (
    <section class="posts-column-section" aria-labelledby="technical-column-title">
      <div class="posts-column-section__header">
        <div>
          <p class="posts-column-section__eyebrow">Column</p>
          <h2 id="technical-column-title">Technical Collection</h2>
        </div>
        <span>{technicalPosts.length} saved</span>
      </div>
      <p class="posts-column-section__description">Site-building, tooling, and implementation notes collected as a technical column.</p>
      <div class="article-list--compact posts-column-list">
        {technicalPosts.map((entry: (typeof technicalPosts)[number]) => <PostCard entry={entry} />)}
      </div>
    </section>
  )}

  <section class="records-section posts-all-section" aria-labelledby="all-posts-title">
    <div class="records-section__header">
      <div>
        <p class="records-section__eyebrow">All</p>
        <h2 id="all-posts-title">All articles</h2>
      </div>
      <span>{posts.length}</span>
    </div>
    <div class="article-list--compact" id="posts-list" data-local-filter-list>
      {posts.map((entry: (typeof posts)[number]) => <PostCard entry={entry} />)}
    </div>
  </section>
  <Fragment slot="right-sidebar">
    <RightSidebar lang={lang} entries={posts} />
  </Fragment>
</BaseLayout>
