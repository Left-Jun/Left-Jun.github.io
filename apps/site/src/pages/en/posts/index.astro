---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import PostCard from "../../../components/PostCard.astro";
import RightSidebar from "../../../components/RightSidebar.astro";
import { getEntries, getSectionPage } from "../../../lib/content.js";

const lang = "en";
const section = await getSectionPage("posts", lang);
const posts = await getEntries("posts", { lang });
---
<BaseLayout lang={lang} title={section.data.title} description={section.data.description} active="posts" bodyClass="list-page">
  <header>
    <h3 class="section-title">Records</h3>
    <section class="section-card">
      <div class="section-details">
        <h3 class="section-count">{posts.length} posts</h3>
        <h1 class="section-term">{section.data.title}</h1>
        <h2 class="section-description">{section.data.description}</h2>
      </div>
    </section>
  </header>

  <section class="article-list--compact" id="posts-list">
    {posts.map((entry) => <PostCard entry={entry} />)}
  </section>
  <Fragment slot="right-sidebar">
    <RightSidebar lang={lang} entries={posts} />
  </Fragment>
</BaseLayout>
