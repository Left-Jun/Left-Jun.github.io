---
import ArticleLayout from "../../components/ArticleLayout.astro";
import AboutPage from "../../components/AboutPage.astro";
import ContactPage from "../../components/ContactPage.astro";
import { getEntries } from "../../lib/content.js";
import type { SiteEntry } from "../../lib/content.js";

interface Props {
  entry: SiteEntry;
}

export async function getStaticPaths() {
  return (await getEntries("pages", { lang: "en" })).map((entry) => ({
    params: { slug: entry.slug },
    props: { entry }
  }));
}

const { entry } = Astro.props as Props;
---
{entry.slug === "about" ? (
  <AboutPage entry={entry} />
) : entry.slug === "contact" ? (
  <ContactPage entry={entry} />
) : (
  <ArticleLayout entry={entry} active="about" />
)}
