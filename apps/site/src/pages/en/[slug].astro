---
import ArticleLayout from "../../components/ArticleLayout.astro";
import { getEntries } from "../../lib/content.js";

interface Props {
  entry: any;
}

export async function getStaticPaths() {
  return (await getEntries("pages", { lang: "en" })).map((entry) => ({
    params: { slug: entry.slug },
    props: { entry }
  }));
}

const { entry } = Astro.props as Props;
---
<ArticleLayout entry={entry} active={entry.slug === "contact" ? "contact" : "about"} />
