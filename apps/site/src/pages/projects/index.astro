---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ProjectCard from "../../components/ProjectCard.astro";
import { getEntries, getSectionPage } from "../../lib/content.js";

const lang = "zh-cn";
const section = await getSectionPage("projects", lang);
const projects = await getEntries("projects", { lang });
---
<BaseLayout lang={lang} title={section.data.title} description={section.data.description} active="projects">
  <section class="section-hero glass">
    <p class="eyebrow">{projects.length} 个项目</p>
    <h1>{section.data.title}</h1>
    <p>{section.data.description}</p>
    <div class="tag-row">
      <span class="tag">游戏开发</span>
      <span class="tag">嵌入式开发</span>
    </div>
  </section>
  <section class="project-list">
    {projects.map((entry) => <ProjectCard entry={entry} />)}
  </section>
</BaseLayout>
