---
import ProjectsPage from "../../components/ProjectsPage.astro";
import { getEntries, getSectionPage } from "../../lib/content.js";

const lang = "zh-cn";
const section = await getSectionPage("projects", lang);
const projects = await getEntries("projects", { lang });
---

<ProjectsPage lang={lang} section={section} projects={projects} alternatePath="/en/projects/" />
