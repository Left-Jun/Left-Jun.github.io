---
import RecordsPage from "../../components/RecordsPage.astro";
import { getEntries, getSectionPage } from "../../lib/content.js";

const lang = "zh-cn";
const section = await getSectionPage("plans", lang);
const [projects, retrospectives, plans] = await Promise.all([
  getEntries("projects", { lang }),
  getEntries("retrospectives", { lang }),
  getEntries("plans", { lang })
]);
---
<RecordsPage
  lang={lang}
  title={section.data.title}
  description={section.data.description || "项目版本计划、试玩反馈、风险点与下一轮验证目标。"}
  alternatePath="/en/plans/"
  active="plans"
  initialView="plans"
  projects={projects}
  retrospectives={retrospectives}
  plans={plans}
/>
