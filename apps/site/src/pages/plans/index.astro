---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PostCard from "../../components/PostCard.astro";
import { getEntries, getSectionPage } from "../../lib/content.js";

const section = await getSectionPage("plans", "zh-cn");
const entries = await getEntries("plans");
---
<BaseLayout title={section.data.title} description={section.data.description} active="plans">
  <header>
    <h3 class="section-title">开发计划</h3>
    <section class="section-card">
      <div class="section-details">
        <h3 class="section-count">{entries.length} 份计划</h3>
        <h1 class="section-term">{section.data.title}</h1>
        <h2 class="section-description">{section.data.description}</h2>
      </div>
    </section>
  </header>

  <section class="article-list--compact">
    {entries.map((entry) => <PostCard entry={entry} />)}
  </section>
</BaseLayout>
