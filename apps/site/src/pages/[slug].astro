---
import ArticleLayout from "../components/ArticleLayout.astro";
import AboutPage from "../components/AboutPage.astro";
import { getEntries } from "../lib/content.js";
import type { SiteEntry } from "../lib/content.js";

interface Props {
  entry: SiteEntry;
}

export async function getStaticPaths() {
  return (await getEntries("pages", { lang: "zh-cn" })).map((entry) => ({
    params: { slug: entry.slug },
    props: { entry }
  }));
}

const { entry } = Astro.props as Props;
---
{entry.slug === "about" ? (
  <AboutPage entry={entry} />
) : (
  <ArticleLayout entry={entry} active={entry.slug === "contact" ? "contact" : "about"} />
)}
