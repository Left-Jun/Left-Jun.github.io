---
import BaseLayout from "../layouts/BaseLayout.astro";
import ProjectCard from "./ProjectCard.astro";
import PostCard from "./PostCard.astro";
import RightSidebar from "./RightSidebar.astro";
import { getAllEntries } from "../lib/content.js";

const { kind, term, lang = "zh-cn" } = Astro.props as {
  kind: "tags" | "categories";
  term: { slug: string; name: string; entries: Array<any> };
  lang?: "zh-cn" | "en";
};
const isEn = lang === "en";
const isTag = kind === "tags";
const label = isEn ? (isTag ? "Tag" : "Category") : (isTag ? "\u6807\u7b7e" : "\u5206\u7c7b");
const countLabel = isEn ? `${term.entries.length} entries` : `${term.entries.length} \u4e2a\u9875\u9762`;
const description = isEn
  ? `Entries filed under ${label.toLowerCase()} "${term.name}".`
  : `\u6536\u5f55\u300c${term.name}\u300d\u4e0b\u7684\u9879\u76ee\u3001\u6587\u7ae0\u4e0e\u8bb0\u5f55\u3002`;
const projectEntries = term.entries.filter((entry: any) => entry.section === "projects");
const recordEntries = term.entries.filter((entry: any) => entry.section !== "projects");
const activeSection = projectEntries.length > 0 && recordEntries.length === 0 ? "projects" : "posts";
const resetUrl = lang === "en" ? `/en/${activeSection}/` : `/${activeSection}/`;
const categoryEntries = await getAllEntries({ lang });
---
<BaseLayout lang={lang} title={`${label}: ${term.name}`} description={description} active={activeSection} bodyClass="list-page taxonomy-page">
  <header>
    <h3 class="section-title">{label}</h3>
    <section class="section-card">
      <div class="section-details">
        <h3 class="section-count">{countLabel}</h3>
        <h1 class="section-term">{term.name}</h1>
        <h2 class="section-description">{description}</h2>
      </div>
    </section>
  </header>

  {projectEntries.length > 0 && (
    <section class="taxonomy-result-section taxonomy-result-section--projects">
      <div class="taxonomy-result-section__header">
        <p>{isEn ? "Project Matches" : "\u76f8\u5173\u9879\u76ee"}</p>
        <span>{projectEntries.length}</span>
      </div>
      <div class="project-showcase taxonomy-project-showcase" data-view="single">
        <div class="project-list">
          {projectEntries.map((entry: any) => <ProjectCard entry={entry} />)}
        </div>
      </div>
    </section>
  )}

  {recordEntries.length > 0 && (
    <section class="taxonomy-result-section taxonomy-result-section--records">
      <div class="taxonomy-result-section__header">
        <p>{isEn ? "Records" : "\u9879\u76ee\u8bb0\u5f55"}</p>
        <span>{recordEntries.length}</span>
      </div>
      <section class="article-list--compact taxonomy-record-list">
        {recordEntries.map((entry: any) => <PostCard entry={entry} />)}
      </section>
    </section>
  )}

  <Fragment slot="right-sidebar">
    <RightSidebar lang={lang} entries={term.entries} categoryEntries={categoryEntries} activeKind={kind} activeSlug={term.slug} resetUrl={resetUrl} />
  </Fragment>
</BaseLayout>
