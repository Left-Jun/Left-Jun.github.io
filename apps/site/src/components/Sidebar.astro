---
import BrandLogo from "./BrandLogo.astro";
import Icon from "./Icon.astro";
import { config, siteText } from "../lib/content.js";
import { resolveAboutUrl } from "../lib/navigation.js";

const { lang = "zh-cn", active = "", switchUrl = "" } = Astro.props;
const isEn = lang === "en";
const text = siteText(lang);
const sidebar = text.sidebar;
const avatar = sidebar.avatar?.startsWith("/") ? sidebar.avatar : `/${sidebar.avatar || "img/avatar.jpg"}`;
const menu = [...(text.menus.main || [])]
  .sort((a, b) => (a.weight || 0) - (b.weight || 0))
  .map((item) => ({
    ...item,
    icon: item.params?.icon || "link",
    newTab: Boolean(item.params && "newTab" in item.params && item.params.newTab)
  }));
const aboutUrl = resolveAboutUrl(menu, lang);
const aboutLinkLabel = isEn ? "About Left Jun" : "关于 Left Jun";
const activeMenu = active === "plans" ? "retrospectives" : active;
const social = [...(text.menus.social || [])]
  .sort((a, b) => (a.weight || 0) - (b.weight || 0))
  .map((item) => ({
    ...item,
    icon: item.params?.icon || "link",
    newTab: Boolean(item.params && "newTab" in item.params && item.params.newTab)
  }));
const status = sidebar.status || {};
const statusEmoji = status.emoji || sidebar.emoji || "💻";
const statusTitle = status.title || "";
const statusDescription = status.description || "";
const statusLabel = [statusTitle, statusDescription].filter(Boolean).join(": ");
const rolePill = lang === "en" ? "Founder / Lead Creator at Limenauts" : "Limenauts 主创";
const identityLines = String(sidebar.identity || "").split(/\n/).filter(Boolean);
const portfolioPdfUrl = "/files/left-jun-portfolio.pdf";
const portfolioPdfLabel = text.isEn ? "Portfolio PDF" : "作品集 PDF";
const portfolioDownloadLabel = text.isEn ? "Download" : "下载";
const portfolioOpenAria = text.isEn ? "Open portfolio PDF" : "打开作品集 PDF";
const portfolioDownloadAria = text.isEn ? "Download portfolio PDF" : "下载作品集 PDF";
const mobileSearchCopy = isEn
  ? {
      search: "Search projects, updates, articles...",
      searchLabel: "Search site content",
      empty: "No matching results",
      dark: "Dark Mode",
      light: "Light Mode"
    }
  : {
      search: "搜索项目、动态、文章...",
      searchLabel: "搜索站内内容",
      empty: "没有匹配结果",
      dark: "暗色模式",
      light: "浅色模式"
    };
const mobileMenuCopy = isEn
  ? {
      open: "Open navigation menu",
      close: "Close navigation menu"
    }
  : {
      open: "打开导航菜单",
      close: "关闭导航菜单"
    };
const collapseCopy = isEn
  ? {
      collapseAria: "Collapse sidebar",
      expandAria: "Expand sidebar",
      collapse: "Collapse",
      expand: "Expand"
    }
  : {
      collapseAria: "收起侧栏",
      expandAria: "展开侧栏",
      collapse: "收起",
      expand: "展开"
    };
const avatarAlt = isEn ? "Portrait of Left Jun" : "Left Jun 的个人头像";
const socialLabel = isEn ? "Social links" : "社交链接";
const languageSwitchUrl = switchUrl || text.switchUrl;
const searchIndexUrl = isEn ? "/en/search-index.json" : "/search-index.json";
---
<aside class="sidebar left-sidebar sticky is-expanded" id="site-sidebar">
  <div class="sidebar-profile-card">
    <BrandLogo href={text.homeUrl} />
    <button
      class="hamburger hamburger--spin"
      type="button"
      id="toggle-menu"
      aria-label={mobileMenuCopy.open}
      data-open-label={mobileMenuCopy.open}
      data-close-label={mobileMenuCopy.close}
      aria-expanded="false"
      aria-controls="main-menu"
    >
      <span class="hamburger-box">
        <span class="hamburger-inner"></span>
      </span>
    </button>

    <header>
      <figure class="site-avatar">
        <a href={aboutUrl} aria-label={aboutLinkLabel}>
          <img class="site-logo" src={avatar} alt={avatarAlt} width="120" height="120" loading="eager" />
        </a>
        <span class="emoji status-emoji" tabindex="0" aria-label={statusLabel || undefined}>
          {statusEmoji}
          {(statusTitle || statusDescription) && (
            <span class="status-tooltip" role="tooltip">
              {statusTitle && <strong>{statusTitle}</strong>}
              {statusDescription && <small>{statusDescription}</small>}
            </span>
          )}
        </span>
      </figure>

      <div class="site-meta">
        <div class="site-name"><a href={aboutUrl} aria-label={aboutLinkLabel}>{config.title}</a></div>
        <div class="site-role-pill">{rolePill}</div>
        {identityLines.length > 0 && (
          <div class="site-identity">
            {identityLines.map((line, index) => (
              <Fragment>
                {index > 0 && <br />}
                {line}
              </Fragment>
            ))}
          </div>
        )}
        {sidebar.subtitle && <h2 class="site-description">{sidebar.subtitle}</h2>}
        <div class="sidebar-portfolio-pdf" aria-label={portfolioPdfLabel}>
          <a class="sidebar-portfolio-pdf__main" href={portfolioPdfUrl} target="_blank" rel="noopener noreferrer" aria-label={portfolioOpenAria}>
            <Icon name="briefcase" label="" />
            <span>{portfolioPdfLabel}</span>
          </a>
          <a class="sidebar-portfolio-pdf__download" href={portfolioPdfUrl} download aria-label={portfolioDownloadAria}>
            {portfolioDownloadLabel}
          </a>
        </div>
      </div>
    </header>

    {social.length > 0 && (
      <ol class="menu-social" aria-label={socialLabel}>
        {social.map((item) => (
          <li>
            <a href={item.url} target={item.newTab ? "_blank" : undefined} rel={item.newTab ? "me noopener noreferrer" : "me"} title={item.name}>
              <Icon name={item.icon} label={item.name} />
            </a>
          </li>
        ))}
        <li class="mobile-social-language">
          <a href={languageSwitchUrl} title={text.switchLabel} aria-label={text.switchLabel} data-language-transition>
            <Icon name="language" label="" />
            <span>{text.switchLabel}</span>
          </a>
        </li>
      </ol>
    )}
  </div>

  <div
    class="mobile-sidebar-search"
    data-mobile-sidebar-search
    data-search-shell
    data-search-variant="mobile"
    data-search-index-url={searchIndexUrl}
    data-empty={mobileSearchCopy.empty}
  >
    <label class="mobile-sidebar-search__field">
      <Icon name="search" label="" />
      <span class="sr-only">{mobileSearchCopy.searchLabel}</span>
      <input
        type="search"
        placeholder={mobileSearchCopy.search}
        autocomplete="off"
        spellcheck="false"
        data-mobile-sidebar-search-input
        data-search-input
      />
    </label>
    <button
      class="mobile-sidebar-search__theme"
      type="button"
      data-mobile-theme-toggle
      data-dark-label={mobileSearchCopy.dark}
      data-light-label={mobileSearchCopy.light}
      aria-label={mobileSearchCopy.dark}
    >
      <span class="mobile-sidebar-search__theme-icon" aria-hidden="true">
        <Icon name="toggle-left" label="" />
        <Icon name="toggle-right" label="" />
      </span>
    </button>
    <div class="mobile-sidebar-search__results" data-mobile-sidebar-search-results data-search-results hidden></div>
  </div>

  <ol class="menu" id="main-menu">
    {menu.map((item) => (
      <li class:list={[activeMenu === item.identifier && "current"]}>
        <a
          href={item.url}
          target={item.newTab ? "_blank" : undefined}
          rel={item.newTab ? "noopener noreferrer" : undefined}
          aria-current={activeMenu === item.identifier ? "page" : undefined}
        >
          <span class="menu-icon" aria-hidden="true"><Icon name={item.icon} label="" /></span>
          <span class="menu-label">{item.name}</span>
        </a>
      </li>
    ))}
  </ol>

  <div class="sidebar-bottom-actions">
    <a id="i18n-switch" href={languageSwitchUrl} data-language-transition>
      <span class="menu-icon" aria-hidden="true"><Icon name="language" label="" /></span>
      <span class="menu-label">{text.switchLabel}</span>
    </a>
    <button
      id="dark-mode-toggle"
      type="button"
      data-dark-label={text.darkMode}
      data-light-label={text.lightMode}
      aria-label={text.darkMode}
    >
      <span class="theme-toggle__icon menu-icon" aria-hidden="true">
        <Icon name="toggle-left" label="" />
        <Icon name="toggle-right" label="" />
      </span>
      <span class="theme-toggle__label">{text.darkMode}</span>
    </button>
    <button
      id="sidebar-collapse-toggle"
      type="button"
      data-expanded-label={collapseCopy.collapseAria}
      data-collapsed-label={collapseCopy.expandAria}
      data-expanded-short-label={collapseCopy.collapse}
      data-collapsed-short-label={collapseCopy.expand}
      aria-label={collapseCopy.collapseAria}
      aria-expanded="true"
    >
      <span class="menu-icon" aria-hidden="true"><Icon name="chevron-left" label="" /></span>
      <span class="sidebar-collapse-toggle__label">{collapseCopy.collapse}</span>
    </button>
  </div>
</aside>

<script is:inline>
  (() => {
    const root = document.documentElement;
    const body = document.body;
    const sidebar = document.querySelector("#site-sidebar");
    const toggle = document.querySelector("#toggle-menu");
    const mainMenu = document.querySelector("#main-menu");
    const themeButton = document.querySelector("#dark-mode-toggle");
    const themeLabel = themeButton?.querySelector(".theme-toggle__label");
    const mobileThemeButtons = document.querySelectorAll("[data-mobile-theme-toggle]");
    const collapseButton = document.querySelector("#sidebar-collapse-toggle");
    const collapseLabel = collapseButton?.querySelector(".sidebar-collapse-toggle__label");
    const menuLinks = document.querySelectorAll("#main-menu a");
    const themeKey = "LeftJunColorScheme";
    const sidebarKey = "LeftJunSidebarCollapsed";
    const desktopQuery = matchMedia("(min-width: 768px)");

    const applyTheme = (scheme) => {
      const isDark = scheme === "dark";
      root.dataset.scheme = scheme;
      document.querySelector("#theme-color")?.setAttribute("content", isDark ? "#171b1a" : "#ebf5fc");
      themeButton?.setAttribute("data-scheme-state", scheme);
      if (themeLabel && themeButton) {
        themeLabel.textContent = isDark ? themeButton.dataset.lightLabel || "Light Mode" : themeButton.dataset.darkLabel || "Dark Mode";
        themeButton.setAttribute("aria-label", themeLabel.textContent);
      }
      mobileThemeButtons.forEach((button) => {
        const label = isDark ? button.dataset.lightLabel || "Light Mode" : button.dataset.darkLabel || "Dark Mode";
        button.setAttribute("data-scheme-state", scheme);
        button.setAttribute("aria-label", label);
      });
    };

    const setMenuOpen = (open) => {
      const mobile = !desktopQuery.matches;
      const next = Boolean(open && mobile);
      body.classList.toggle("show-menu", next);
      sidebar?.classList.toggle("is-open", next);
      toggle?.classList.toggle("is-active", next);
      toggle?.setAttribute("aria-expanded", next ? "true" : "false");
      if (toggle instanceof HTMLElement) {
        toggle.setAttribute("aria-label", next ? toggle.dataset.closeLabel || "Close menu" : toggle.dataset.openLabel || "Open menu");
      }
      if (mainMenu instanceof HTMLElement) {
        mainMenu.inert = mobile && !next;
        if (mobile) mainMenu.setAttribute("aria-hidden", next ? "false" : "true");
        else mainMenu.removeAttribute("aria-hidden");
      }
    };

    const updateCollapseButton = (collapsed) => {
      if (!collapseButton) return;
      const label = collapsed
        ? collapseButton.dataset.collapsedLabel || "Expand sidebar"
        : collapseButton.dataset.expandedLabel || "Collapse sidebar";
      collapseButton.setAttribute("aria-label", label);
      collapseButton.setAttribute("aria-expanded", collapsed ? "false" : "true");
      if (collapseLabel) {
        collapseLabel.textContent = collapsed
          ? collapseButton.dataset.collapsedShortLabel || "Expand"
          : collapseButton.dataset.expandedShortLabel || "Collapse";
      }
    };

    const setSidebarCollapsed = (collapsed, persist = true) => {
      const canCollapse = desktopQuery.matches;
      const next = Boolean(collapsed && canCollapse);
      body.classList.toggle("sidebar-collapsed", next);
      sidebar?.classList.toggle("is-collapsed", next);
      sidebar?.classList.toggle("is-expanded", !next);
      updateCollapseButton(next);
      if (persist) localStorage.setItem(sidebarKey, collapsed ? "1" : "0");
    };

    const saved = localStorage.getItem(themeKey) || localStorage.getItem("LeftJunAstroColorScheme");
    const initial = saved || (matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light");
    applyTheme(initial);
    setSidebarCollapsed(localStorage.getItem(sidebarKey) === "1", false);

    const toggleTheme = (trigger) => {
      const next = root.dataset.scheme === "dark" ? "light" : "dark";
      const applyNext = () => {
        localStorage.setItem(themeKey, next);
        applyTheme(next);
        window.dispatchEvent(new CustomEvent("leftjun:theme-change", { detail: { scheme: next } }));
      };
      if (window.LeftJunTransitions?.runThemeTransition) {
        window.LeftJunTransitions.runThemeTransition(trigger, applyNext);
      } else {
        applyNext();
      }
    };

    themeButton?.addEventListener("click", (event) => toggleTheme(event.currentTarget));

    mobileThemeButtons.forEach((button) => {
      button.addEventListener("click", (event) => toggleTheme(event.currentTarget));
    });

    window.addEventListener("leftjun:theme-change", (event) => {
      if (event.detail?.scheme) applyTheme(event.detail.scheme);
    });

    collapseButton?.addEventListener("click", () => setSidebarCollapsed(!body.classList.contains("sidebar-collapsed")));

    desktopQuery.addEventListener?.("change", () => {
      setSidebarCollapsed(localStorage.getItem(sidebarKey) === "1", false);
      setMenuOpen(false);
    });

    toggle?.addEventListener("click", () => setMenuOpen(!body.classList.contains("show-menu")));
    menuLinks.forEach((link) => link.addEventListener("click", () => setMenuOpen(false)));

    document.addEventListener("keydown", (event) => {
      if (event.key !== "Escape" || !body.classList.contains("show-menu")) return;
      event.preventDefault();
      setMenuOpen(false);
      toggle?.focus();
    });

    setMenuOpen(false);
  })();
</script>

<script>
  import { initSiteSearch } from "../scripts/search-client.js";
  initSiteSearch();
  document.addEventListener("astro:page-load", () => initSiteSearch());
</script>
