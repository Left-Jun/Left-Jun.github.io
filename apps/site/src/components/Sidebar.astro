---
import Icon from "./Icon.astro";
import { config, siteText } from "../lib/content.js";

const { lang = "zh-cn", active = "home" } = Astro.props;
const text = siteText(lang);
const sidebar = text.sidebar;
const avatar = sidebar.avatar?.startsWith("/") ? sidebar.avatar : `/${sidebar.avatar || "img/avatar.jpg"}`;
const menu = [...(text.menus.main || [])]
  .sort((a, b) => (a.weight || 0) - (b.weight || 0))
  .map((item) => ({
    ...item,
    icon: item.params?.icon || "link",
    newTab: Boolean(item.params && "newTab" in item.params && item.params.newTab)
  }));
const social = [...(text.menus.social || [])]
  .sort((a, b) => (a.weight || 0) - (b.weight || 0))
  .map((item) => ({
    ...item,
    icon: item.params?.icon || "link",
    newTab: Boolean(item.params && "newTab" in item.params && item.params.newTab)
  }));
const status = sidebar.status || {};
const statusEmoji = status.emoji || sidebar.emoji || "💻";
const statusTitle = status.title || "";
const statusDescription = status.description || "";
const statusLabel = [statusTitle, statusDescription].filter(Boolean).join(": ");
---
<aside class="sidebar left-sidebar sticky" id="site-sidebar">
  <button class="hamburger hamburger--spin" type="button" id="toggle-menu" aria-label="Toggle menu">
    <span class="hamburger-box">
      <span class="hamburger-inner"></span>
    </span>
  </button>

  <header>
    <figure class="site-avatar">
      <a href={text.homeUrl}>
        <img class="site-logo" src={avatar} alt="Avatar" width="120" height="120" loading="eager" />
      </a>
      <span class="emoji status-emoji" tabindex="0" aria-label={statusLabel || undefined}>
        {statusEmoji}
        {(statusTitle || statusDescription) && (
          <span class="status-tooltip" role="tooltip">
            {statusTitle && <strong>{statusTitle}</strong>}
            {statusDescription && <small>{statusDescription}</small>}
          </span>
        )}
      </span>
    </figure>

    <div class="site-meta">
      <div class="site-name"><a href={text.homeUrl}>{config.title}</a></div>
      <div class="site-role-pill">阈限开拓者主创</div>
      {sidebar.identity && <div class="site-identity">{sidebar.identity}</div>}
      {sidebar.subtitle && <h2 class="site-description">{sidebar.subtitle}</h2>}
    </div>
  </header>

  {social.length > 0 && (
    <ol class="menu-social" aria-label="social links">
      {social.map((item) => (
        <li>
          <a href={item.url} target={item.newTab ? "_blank" : undefined} rel={item.newTab ? "me noopener noreferrer" : "me"} title={item.name}>
            <Icon name={item.icon} label={item.name} />
          </a>
        </li>
      ))}
    </ol>
  )}

  <ol class="menu" id="main-menu">
    {menu.map((item) => (
      <li class:list={[active === item.identifier && "current"]}>
        <a href={item.url} target={item.newTab ? "_blank" : undefined} rel={item.newTab ? "noopener noreferrer" : undefined}>
          <Icon name={item.icon} label="" />
          <span>{item.name}</span>
        </a>
      </li>
    ))}
  </ol>

  <div class="sidebar-bottom-actions">
    <a id="i18n-switch" href={text.switchUrl}>
      <Icon name="language" label="" />
      <span>{text.switchLabel}</span>
    </a>
    <button
      id="dark-mode-toggle"
      type="button"
      data-dark-label={text.darkMode}
      data-light-label={text.lightMode}
      aria-label={text.darkMode}
    >
      <span class="theme-toggle__icon" aria-hidden="true">
        <Icon name="toggle-left" label="" />
        <Icon name="toggle-right" label="" />
      </span>
      <span class="theme-toggle__label">{text.darkMode}</span>
    </button>
    <button
      id="sidebar-collapse-toggle"
      type="button"
      data-expanded-label="收起侧栏"
      data-collapsed-label="展开侧栏"
      aria-label="收起侧栏"
      aria-expanded="true"
    >
      <Icon name="chevron-left" label="" />
      <span class="sidebar-collapse-toggle__label">收起</span>
    </button>
  </div>
</aside>

<script is:inline>
  (() => {
    const root = document.documentElement;
    const body = document.body;
    const sidebar = document.querySelector("#site-sidebar");
    const toggle = document.querySelector("#toggle-menu");
    const themeButton = document.querySelector("#dark-mode-toggle");
    const themeLabel = themeButton?.querySelector(".theme-toggle__label");
    const collapseButton = document.querySelector("#sidebar-collapse-toggle");
    const collapseLabel = collapseButton?.querySelector(".sidebar-collapse-toggle__label");
    const menuLinks = document.querySelectorAll("#main-menu a");
    const themeKey = "LeftJunColorScheme";
    const sidebarKey = "LeftJunSidebarCollapsed";
    const desktopQuery = matchMedia("(min-width: 768px)");

    const applyTheme = (scheme) => {
      root.dataset.scheme = scheme;
      themeButton?.setAttribute("data-scheme-state", scheme);
      if (themeLabel && themeButton) {
        const isDark = scheme === "dark";
        themeLabel.textContent = isDark ? themeButton.dataset.lightLabel || "Light Mode" : themeButton.dataset.darkLabel || "Dark Mode";
        themeButton.setAttribute("aria-label", themeLabel.textContent);
      }
    };

    const setMenuOpen = (open) => {
      body.classList.toggle("show-menu", open);
      sidebar?.classList.toggle("is-open", open);
      toggle?.classList.toggle("is-active", open);
      toggle?.setAttribute("aria-expanded", open ? "true" : "false");
    };

    const updateCollapseButton = (collapsed) => {
      if (!collapseButton) return;
      const label = collapsed
        ? collapseButton.dataset.collapsedLabel || "展开侧栏"
        : collapseButton.dataset.expandedLabel || "收起侧栏";
      collapseButton.setAttribute("aria-label", label);
      collapseButton.setAttribute("aria-expanded", collapsed ? "false" : "true");
      if (collapseLabel) collapseLabel.textContent = collapsed ? "展开" : "收起";
    };

    const setSidebarCollapsed = (collapsed, persist = true) => {
      const canCollapse = desktopQuery.matches;
      const next = Boolean(collapsed && canCollapse);
      body.classList.toggle("sidebar-collapsed", next);
      sidebar?.classList.toggle("is-collapsed", next);
      updateCollapseButton(next);
      if (persist) localStorage.setItem(sidebarKey, collapsed ? "1" : "0");
    };

    const saved = localStorage.getItem(themeKey) || localStorage.getItem("LeftJunAstroColorScheme");
    const initial = saved || (matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light");
    applyTheme(initial);
    setSidebarCollapsed(localStorage.getItem(sidebarKey) === "1", false);

    themeButton?.addEventListener("click", () => {
      const next = root.dataset.scheme === "dark" ? "light" : "dark";
      localStorage.setItem(themeKey, next);
      applyTheme(next);
      window.dispatchEvent(new CustomEvent("leftjun:theme-change", { detail: { scheme: next } }));
    });

    window.addEventListener("leftjun:theme-change", (event) => {
      if (event.detail?.scheme) applyTheme(event.detail.scheme);
    });

    collapseButton?.addEventListener("click", () => setSidebarCollapsed(!body.classList.contains("sidebar-collapsed")));

    desktopQuery.addEventListener?.("change", () => setSidebarCollapsed(localStorage.getItem(sidebarKey) === "1", false));

    toggle?.addEventListener("click", () => setMenuOpen(!body.classList.contains("show-menu")));
    menuLinks.forEach((link) => link.addEventListener("click", () => sessionStorage.setItem("LeftJunMenuNavigation", "1")));

    const isHome = location.pathname === "/" || location.pathname === "/en/";
    const cameFromMenu = sessionStorage.getItem("LeftJunMenuNavigation") === "1";
    sessionStorage.removeItem("LeftJunMenuNavigation");
    if (isHome || cameFromMenu) {
      root.classList.add("mobile-menu-preopen");
      setMenuOpen(true);
      setTimeout(() => {
        root.classList.remove("mobile-menu-preopen");
        setMenuOpen(false);
      }, isHome ? 650 : 180);
    }
  })();
</script>
