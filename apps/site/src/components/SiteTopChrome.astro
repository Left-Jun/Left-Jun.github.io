---
import Icon from "./Icon.astro";

const { lang = "zh-cn", active = "home" } = Astro.props;
const isEn = lang === "en";
const activeKey = active === "plans" ? "retrospectives" : active;
const copy = isEn
  ? {
      navLabel: "Site navigation",
      home: "Home",
      projects: "Projects",
      updates: "Updates",
      plans: "Retrospectives & Plans",
      posts: "Articles & Columns",
      about: "About",
      search: "Search projects, updates, articles...",
      searchLabel: "Search site content",
      empty: "No matching results",
      dark: "Dark Mode",
      light: "Light Mode",
      github: "GitHub profile"
    }
  : {
      navLabel: "站点导航",
      home: "首页",
      projects: "项目",
      updates: "动态",
      plans: "复盘&计划",
      posts: "文章与专栏",
      about: "关于我",
      search: "搜索项目、动态、文章...",
      searchLabel: "搜索站内内容",
      empty: "没有匹配结果",
      dark: "暗色模式",
      light: "浅色模式",
      github: "GitHub 主页"
    };

const navItems = [
  { key: "home", label: copy.home, href: isEn ? "/en/" : "/", icon: "home" },
  { key: "projects", label: copy.projects, href: isEn ? "/en/projects/" : "/projects/", icon: "briefcase" },
  { key: "updates", label: copy.updates, href: isEn ? "/en/updates/" : "/updates/", icon: "clock" },
  { key: "retrospectives", label: copy.plans, href: isEn ? "/en/retrospectives/" : "/retrospectives/", icon: "infinity" },
  { key: "posts", label: copy.posts, href: isEn ? "/en/posts/" : "/posts/", icon: "messages" },
  { key: "about", label: copy.about, href: isEn ? "/en/about/" : "/about/", icon: "user" }
];
const mobileNavItems = [
  { key: "home", label: copy.home, href: isEn ? "/en/" : "/", icon: "home" },
  { key: "projects", label: copy.projects, href: isEn ? "/en/projects/" : "/projects/", icon: "briefcase" },
  { key: "updates", label: copy.updates, href: isEn ? "/en/updates/" : "/updates/", icon: "clock" },
  { key: "posts", label: copy.posts, href: isEn ? "/en/posts/" : "/posts/", icon: "archives" }
];

const portfolioPdfLabel = isEn ? "Portfolio PDF" : "作品集 PDF";
const portfolioPdfAria = isEn ? "Open portfolio PDF" : "打开作品集 PDF";

const searchIndexUrl = isEn ? "/en/search-index.json" : "/search-index.json";
const searchResultsId = `site-search-results-${isEn ? "en" : "zh"}`;
---
<nav
  class="home-topbar"
  data-home-topbar
  data-search-shell
  data-search-variant="top"
  data-search-index-url={searchIndexUrl}
  data-empty={copy.empty}
  aria-label={copy.navLabel}
>
  <div class="home-topbar__nav">
    {navItems.map((item) => (
      <a class:list={[activeKey === item.key && "is-active"]} href={item.href}>{item.label}</a>
    ))}
  </div>

  <div class="home-topbar__tools">
    <label class="home-topbar__search" data-home-search>
      <Icon name="search" />
      <span class="sr-only">{copy.searchLabel}</span>
      <input
        type="search"
        placeholder={copy.search}
        autocomplete="off"
        spellcheck="false"
        data-home-search-input
        data-search-input
        aria-controls={searchResultsId}
        aria-expanded="false"
      />
      <div
        class="home-topbar__results"
        id={searchResultsId}
        data-home-search-results
        data-search-results
        aria-live="polite"
        aria-atomic="false"
        hidden
      ></div>
    </label>

    {activeKey === "projects" && (
      <a class="home-topbar__portfolio-pdf" href="/files/left-jun-portfolio.pdf" target="_blank" rel="noopener noreferrer" aria-label={portfolioPdfAria}>
        <Icon name="briefcase" label="" />
        <span>{portfolioPdfLabel}</span>
      </a>
    )}

    <button
      class="home-topbar__theme"
      type="button"
      id="home-topbar-theme"
      data-dark-label={copy.dark}
      data-light-label={copy.light}
      aria-label={copy.dark}
    >
      <span class="home-topbar__theme-icon" aria-hidden="true">
        <Icon name="toggle-left" label="" />
        <Icon name="toggle-right" label="" />
      </span>
    </button>

    <a class="home-topbar__github" href="https://github.com/Left-Jun" target="_blank" rel="me noopener noreferrer" aria-label={copy.github}>
      <Icon name="brand-github" label="" />
    </a>
  </div>
</nav>

<nav class="mobile-bottom-nav" aria-label={copy.navLabel}>
  {mobileNavItems.map((item) => (
    <a
      class:list={[activeKey === item.key && "is-active"]}
      href={item.href}
      aria-current={activeKey === item.key ? "page" : undefined}
    >
      <Icon name={item.icon} label="" />
      <span>{item.label}</span>
    </a>
  ))}
</nav>

<script is:inline>
  (() => {
    const root = document.documentElement;
    const themeKey = "LeftJunColorScheme";

    const setThemeButtonState = (button, scheme) => {
      if (!button) return;
      const isDark = scheme === "dark";
      button.setAttribute("data-scheme-state", scheme);
      button.setAttribute("aria-label", isDark ? button.dataset.lightLabel || "Light Mode" : button.dataset.darkLabel || "Dark Mode");
    };

    const syncThemeControls = (scheme) => {
      root.dataset.scheme = scheme;
      setThemeButtonState(document.querySelector("#home-topbar-theme"), scheme);
      const sidebarButton = document.querySelector("#dark-mode-toggle");
      setThemeButtonState(sidebarButton, scheme);
      const sidebarLabel = sidebarButton?.querySelector(".theme-toggle__label");
      if (sidebarButton && sidebarLabel) {
        const isDark = scheme === "dark";
        sidebarLabel.textContent = isDark ? sidebarButton.dataset.lightLabel || "Light Mode" : sidebarButton.dataset.darkLabel || "Dark Mode";
      }
    };

    const saved = localStorage.getItem(themeKey) || localStorage.getItem("LeftJunAstroColorScheme");
    syncThemeControls(saved || root.dataset.scheme || (matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light"));

    document.querySelector("#home-topbar-theme")?.addEventListener("click", (event) => {
      const next = root.dataset.scheme === "dark" ? "light" : "dark";
      const applyNext = () => {
        localStorage.setItem(themeKey, next);
        syncThemeControls(next);
        window.dispatchEvent(new CustomEvent("leftjun:theme-change", { detail: { scheme: next } }));
      };
      if (window.LeftJunTransitions?.runThemeTransition) {
        window.LeftJunTransitions.runThemeTransition(event.currentTarget, applyNext);
      } else {
        applyNext();
      }
    });

    window.addEventListener("leftjun:theme-change", (event) => {
      if (event.detail?.scheme) syncThemeControls(event.detail.scheme);
    });

  })();
</script>

<script>
  import { initSiteSearch } from "../scripts/search-client.js";
  initSiteSearch();
  document.addEventListener("astro:page-load", () => initSiteSearch());
</script>
