---
const { entry, compact = false } = Astro.props;
const image = entry.data.image;
const video = entry.data.coverVideo;
const roleTags: string[] = entry.data.roleTags || [];
const tags: string[] = entry.data.tags || [];
const allDisplayTags = [...roleTags, ...tags].filter(Boolean);
const visibleRoleTags = compact ? [] : roleTags;
const visibleTags = compact ? allDisplayTags.slice(0, 3) : tags;
const projectType = entry.data.portfolioType || "other";
const imagePosition = entry.data.imagePosition || "center";
const projectFacts = entry.data.projectFacts || {};
const cardMeta = compact
  ? [
      projectFacts.duration,
      projectFacts.team || projectFacts.type || entry.data.portfolioType,
      projectFacts.tools || projectFacts.engine || projectFacts.developmentTime
    ].filter(Boolean).slice(0, 3).map(String)
  : [];
---
<article
  id={`project-${entry.slug}`}
  class:list={["project-card", (image || video) && "has-image", compact && "project-card--compact"]}
  data-project-type={projectType}
  style={`--leftjun-language-transition-name: lj-project-${entry.slug};`}
>
  <a href={entry.url}>
    {(image || video) && (
      <div class="project-card__image">
        {video ? (
          <video
            autoplay
            muted
            loop
            playsinline
            preload="none"
            data-lazy-video={entry.asset(video)}
            data-lazy-video-type="video/mp4"
            controlslist="nodownload noplaybackrate noremoteplayback"
            disablepictureinpicture
            disableRemotePlayback
            translate="no"
            poster={image ? entry.asset(image) : undefined}
            style={`object-position: ${imagePosition};`}
            aria-label={`Video preview of project ${entry.data.title}`}
          ></video>
        ) : (
          <img src={entry.asset(image)} alt={`Featured image of project ${entry.data.title}`} loading="lazy" decoding="async" style={`object-position: ${imagePosition};`} />
        )}
      </div>
    )}
    <div class="project-card__content">
      <h2 class="project-card__title">{entry.data.title}</h2>
      {entry.data.description && <p class="project-card__description">{entry.data.description}</p>}
      {visibleRoleTags.length > 0 && (
        <div class="project-card__roles">
          {visibleRoleTags.map((tag) => <span class="project-card__role">{tag}</span>)}
        </div>
      )}
      {visibleTags.length > 0 && (
        <div class="project-card__tags">
          {visibleTags.map((tag) => <span class="project-card__tag">{tag}</span>)}
        </div>
      )}
      {cardMeta.length > 0 && (
        <p class="project-card__meta">
          {cardMeta.map((item, index) => (
            <>
              {index > 0 && <span aria-hidden="true">·</span>}
              <span>{item}</span>
            </>
          ))}
        </p>
      )}
    </div>
  </a>
</article>

<script is:inline>
  (() => {
    if (window.__leftJunLazyProjectVideoInit) return;
    window.__leftJunLazyProjectVideoInit = true;

    const videos = () => Array.from(document.querySelectorAll("video[data-lazy-video]"));
    const loadVideo = (video) => {
      if (video.dataset.lazyVideoLoaded || !video.dataset.lazyVideo) return;
      const source = document.createElement("source");
      source.src = video.dataset.lazyVideo;
      source.type = video.dataset.lazyVideoType || "video/mp4";
      video.append(source);
      video.dataset.lazyVideoLoaded = "1";
      video.load();
    };
    const playVideo = (video) => {
      loadVideo(video);
      const playback = video.play();
      if (playback?.catch) playback.catch(() => {});
    };

    if (!("IntersectionObserver" in window)) {
      videos().forEach(playVideo);
      return;
    }

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        const video = entry.target;
        if (entry.isIntersecting) {
          playVideo(video);
        } else {
          video.pause();
        }
      });
    }, { rootMargin: "240px 0px", threshold: 0.01 });

    videos().forEach((video) => observer.observe(video));
    document.addEventListener("astro:after-swap", () => {
      videos().forEach((video) => observer.observe(video));
    });
  })();
</script>
