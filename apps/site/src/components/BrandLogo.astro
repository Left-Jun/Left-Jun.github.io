---
import { brand } from "../config/brand";

const { href = "/" } = Astro.props;
const brandLabel = `${brand.group} / ${brand.name}`;
---

<a class="brand" href={href} aria-label={brandLabel}>
  <img
    class="brand-logo brand-logo-mark"
    src={brand.logos.mark}
    alt=""
    width="4096"
    height="3855"
    aria-hidden="true"
    loading="eager"
    decoding="async"
  />
  <img
    class="brand-logo brand-logo-lockup"
    src={brand.logos.lockup}
    alt=""
    width="2048"
    height="684"
    aria-hidden="true"
    loading="eager"
    decoding="async"
  />
</a>
