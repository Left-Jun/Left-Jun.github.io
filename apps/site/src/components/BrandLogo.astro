---
import { brand } from "../config/brand";

const { href = "/" } = Astro.props;
---

<a class="brand" href={href} aria-label={`${brand.group} / ${brand.name}`}>
  <img
    class="brand-logo brand-logo-mark brand-logo--light"
    src={brand.logos.mark}
    alt=""
    width="80"
    height="72"
    aria-hidden="true"
    loading="eager"
    decoding="async"
  />
  <img
    class="brand-logo brand-logo-mark brand-logo--dark"
    src={brand.logos.markDark}
    alt=""
    width="80"
    height="72"
    aria-hidden="true"
    loading="eager"
    decoding="async"
  />
  <img
    class="brand-logo brand-logo-lockup brand-logo--light"
    src={brand.logos.lockup}
    alt=""
    width="286"
    height="62"
    aria-hidden="true"
    loading="eager"
    decoding="async"
  />
  <img
    class="brand-logo brand-logo-lockup brand-logo--dark"
    src={brand.logos.lockupDark}
    alt=""
    width="286"
    height="62"
    aria-hidden="true"
    loading="eager"
    decoding="async"
  />
</a>
