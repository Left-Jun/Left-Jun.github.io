---
import { readFileSync } from "node:fs";

const { name, label = "" } = Astro.props;
const safeName = /^[a-z0-9-]+$/i.test(name) ? name : "link";

let svg = "";
try {
  svg = readFileSync(new URL(`../../public/icons/${safeName}.svg`, import.meta.url), "utf8");
} catch {
  svg = readFileSync(new URL("../../public/icons/link.svg", import.meta.url), "utf8");
}
---
<span class="inline-icon" role={label ? "img" : undefined} aria-label={label || undefined} aria-hidden={label ? undefined : "true"} set:html={svg} />
