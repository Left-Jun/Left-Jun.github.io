---
import Icon from "./Icon.astro";
import { getAllEntries } from "../lib/content.js";

const { lang = "zh-cn" } = Astro.props;
const isEn = lang === "en";
const copy = isEn
  ? {
      navLabel: "Home navigation",
      home: "Home",
      projects: "Projects",
      plans: "Retrospectives & Plans",
      posts: "Articles and Records",
      about: "About",
      search: "Search projects, systems, articles...",
      searchLabel: "Search site content",
      empty: "No matching results",
      dark: "Dark Mode",
      light: "Light Mode",
      github: "GitHub profile"
    }
  : {
      navLabel: "首页导航",
      home: "首页",
      projects: "项目",
      plans: "复盘&计划",
      posts: "文章与记录",
      about: "关于我",
      search: "搜索项目、系统、文章...",
      searchLabel: "搜索站内内容",
      empty: "没有匹配结果",
      dark: "暗色模式",
      light: "浅色模式",
      github: "GitHub 主页"
    };

const navItems = [
  { label: copy.home, href: isEn ? "/en/" : "/" },
  { label: copy.projects, href: isEn ? "/en/projects/" : "/projects/" },
  { label: copy.plans, href: "/retrospectives/" },
  { label: copy.posts, href: isEn ? "/en/posts/" : "/posts/" },
  { label: copy.about, href: isEn ? "/en/about/" : "/about/" }
];

const sectionLabels = isEn
  ? {
      projects: "Project",
      posts: "Article",
      retrospectives: "Retrospective",
      plans: "Roadmap"
    }
  : {
      projects: "项目",
      posts: "文章",
      retrospectives: "复盘",
      plans: "计划"
    };

const searchEntries = (await getAllEntries({ lang })).map((entry) => {
  const tags = [
    ...(entry.data.tags || []),
    ...(entry.data.roleTags || []),
    ...(entry.data.categories || [])
  ]
    .filter(Boolean)
    .slice(0, 8);
  const description = entry.data.description || entry.data.summary || "";
  const search = [entry.data.title, description, ...tags, entry.section]
    .join(" ")
    .toLowerCase();
  return {
    title: entry.data.title,
    description,
    url: entry.url,
    section: sectionLabels[entry.section] || entry.section,
    tags,
    search
  };
});

const searchIndexId = `home-search-index-${isEn ? "en" : "zh"}`;
const searchJson = JSON.stringify(searchEntries).replace(/</g, "\\u003c");
---
<nav class="home-topbar" data-home-topbar data-search-index-id={searchIndexId} data-empty={copy.empty} aria-label={copy.navLabel}>
  <div class="home-topbar__nav">
    {navItems.map((item, index) => (
      <a class:list={[index === 0 && "is-active"]} href={item.href}>{item.label}</a>
    ))}
  </div>

  <div class="home-topbar__tools">
    <label class="home-topbar__search" data-home-search>
      <Icon name="search" />
      <span class="sr-only">{copy.searchLabel}</span>
      <input
        type="search"
        placeholder={copy.search}
        autocomplete="off"
        spellcheck="false"
        data-home-search-input
      />
      <div class="home-topbar__results" data-home-search-results hidden></div>
    </label>

    <button
      class="home-topbar__theme"
      type="button"
      id="home-topbar-theme"
      data-dark-label={copy.dark}
      data-light-label={copy.light}
      aria-label={copy.dark}
    >
      <span class="home-topbar__theme-icon" aria-hidden="true">
        <Icon name="toggle-left" label="" />
        <Icon name="toggle-right" label="" />
      </span>
    </button>

    <a class="home-topbar__github" href="https://github.com/Left-Jun" target="_blank" rel="me noopener noreferrer" aria-label={copy.github}>
      <Icon name="brand-github" label="" />
    </a>
  </div>
</nav>

<script type="application/json" id={searchIndexId} set:html={searchJson} is:inline></script>

<script is:inline>
  (() => {
    const root = document.documentElement;
    const themeKey = "LeftJunColorScheme";

    const setThemeButtonState = (button, scheme) => {
      if (!button) return;
      const isDark = scheme === "dark";
      button.setAttribute("data-scheme-state", scheme);
      button.setAttribute("aria-label", isDark ? button.dataset.lightLabel || "Light Mode" : button.dataset.darkLabel || "Dark Mode");
    };

    const syncThemeControls = (scheme) => {
      root.dataset.scheme = scheme;
      setThemeButtonState(document.querySelector("#home-topbar-theme"), scheme);
      const sidebarButton = document.querySelector("#dark-mode-toggle");
      setThemeButtonState(sidebarButton, scheme);
      const sidebarLabel = sidebarButton?.querySelector(".theme-toggle__label");
      if (sidebarButton && sidebarLabel) {
        const isDark = scheme === "dark";
        sidebarLabel.textContent = isDark ? sidebarButton.dataset.lightLabel || "Light Mode" : sidebarButton.dataset.darkLabel || "Dark Mode";
      }
    };

    const saved = localStorage.getItem(themeKey) || localStorage.getItem("LeftJunAstroColorScheme");
    syncThemeControls(saved || root.dataset.scheme || (matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light"));

    document.querySelector("#home-topbar-theme")?.addEventListener("click", () => {
      const next = root.dataset.scheme === "dark" ? "light" : "dark";
      localStorage.setItem(themeKey, next);
      syncThemeControls(next);
      window.dispatchEvent(new CustomEvent("leftjun:theme-change", { detail: { scheme: next } }));
    });

    window.addEventListener("leftjun:theme-change", (event) => {
      if (event.detail?.scheme) syncThemeControls(event.detail.scheme);
    });

    document.querySelectorAll("[data-home-topbar]").forEach((bar) => {
      const input = bar.querySelector("[data-home-search-input]");
      const results = bar.querySelector("[data-home-search-results]");
      const indexNode = document.getElementById(bar.dataset.searchIndexId);
      if (!input || !results || !indexNode) return;

      let entries = [];
      try {
        entries = JSON.parse(indexNode.textContent || "[]");
      } catch {
        entries = [];
      }

      const closeResults = () => {
        results.hidden = true;
        results.replaceChildren();
        bar.classList.remove("is-search-open");
      };

      const makeText = (tag, className, text) => {
        const node = document.createElement(tag);
        if (className) node.className = className;
        node.textContent = text;
        return node;
      };

      const renderResults = () => {
        const raw = input.value.trim();
        results.replaceChildren();
        if (!raw) {
          closeResults();
          return;
        }

        const tokens = raw.toLowerCase().split(/\s+/).filter(Boolean);
        const matches = entries
          .filter((entry) => tokens.every((token) => entry.search.includes(token)))
          .slice(0, 8);

        if (matches.length === 0) {
          results.append(makeText("p", "home-topbar__empty", bar.dataset.empty || "No matching results"));
        } else {
          matches.forEach((entry) => {
            const link = document.createElement("a");
            link.href = entry.url;
            link.className = "home-topbar__result";
            link.append(makeText("span", "home-topbar__result-section", entry.section));
            link.append(makeText("strong", "", entry.title));
            if (entry.description) link.append(makeText("small", "", entry.description));
            if (entry.tags?.length) link.append(makeText("em", "", entry.tags.slice(0, 3).join(" / ")));
            results.append(link);
          });
        }

        results.hidden = false;
        bar.classList.add("is-search-open");
      };

      input.addEventListener("input", renderResults);
      input.addEventListener("focus", () => {
        if (input.value.trim()) renderResults();
      });
      input.addEventListener("keydown", (event) => {
        if (event.key === "Escape") {
          event.preventDefault();
          input.value = "";
          closeResults();
          input.blur();
        }
      });

      document.addEventListener("keydown", (event) => {
        if ((event.metaKey || event.ctrlKey) && event.key.toLowerCase() === "k") {
          event.preventDefault();
          input.focus();
          input.select();
        }
      });

      document.addEventListener("click", (event) => {
        if (!bar.contains(event.target)) closeResults();
      });
    });
  })();
</script>
