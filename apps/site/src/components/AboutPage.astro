---
import BaseLayout from "../layouts/BaseLayout.astro";
import CoverMedia from "./CoverMedia.astro";
import Icon from "./Icon.astro";
import {
  config,
  getEntries,
  getEntryBySlug,
  siteText
} from "../lib/content.js";
import type { SiteEntry, SiteLanguage } from "../lib/content.js";

interface Props {
  entry: SiteEntry;
}

const { entry } = Astro.props as Props;
const lang = entry.lang;
const text = siteText(lang);
const isEn = text.isEn;
const alternateLang: SiteLanguage = isEn ? "zh-cn" : "en";
const [contactEntry, alternateEntry, allProjects] = await Promise.all([
  getEntryBySlug("pages", "contact", lang),
  getEntryBySlug("pages", "about", alternateLang),
  getEntries("projects", { lang })
]);
const featuredProjects = allProjects
  .filter((project) => Number.isFinite(project.data.homeHeroWeight) && Boolean(project.data.image))
  .sort((a, b) => Number(a.data.homeHeroWeight) - Number(b.data.homeHeroWeight))
  .slice(0, 3);
const firstSectionIndex = entry.html.search(/<h2(?:\s|>)/i);
const introductionHtml = firstSectionIndex >= 0 ? entry.html.slice(0, firstSectionIndex) : entry.html;
const sectionsHtml = firstSectionIndex >= 0 ? entry.html.slice(firstSectionIndex) : "";
const sectionLinks = (entry.toc || []).filter((item) => item.depth === 2);
const resolvedConfig = config as typeof config & { contact?: { email?: string } };
const contactEmail = String(resolvedConfig.contact?.email || "").trim();
const projectsUrl = isEn ? "/en/projects/" : "/projects/";
const labels = {
  eyebrow: isEn ? "Left Jun / Limenauts" : "Left Jun / Limenauts",
  selectedWork: text.selectedWork,
  representativeProjects: text.representativeProjects,
  projectRole: isEn ? "Role" : "职责",
  sections: isEn ? "On this page" : "本页内容",
  contactEyebrow: isEn ? "Start a conversation" : "开始交流",
  contactTitle: contactEntry?.data.title || text.contact,
  contactDescription: contactEntry?.data.description || "",
  contactPage: isEn ? "Contact details" : "查看联系方式",
  email: isEn ? "Email Left Jun" : "发送邮件",
  allProjects: text.allProjects
};
---

<BaseLayout
  lang={lang}
  title={entry.data.title}
  description={entry.data.description}
  alternateUrl={alternateEntry?.url}
  alternateLang={alternateEntry?.lang}
  active="about"
  bodyClass="about-story-page"
  creativeWork={{
    type: "CreativeWork",
    name: entry.data.title,
    description: entry.data.description,
    url: entry.url,
    datePublished: entry.data.date,
    dateModified: entry.data.updatedAt || entry.data.date
  }}
  breadcrumbs={[
    { name: isEn ? "Home" : "首页", url: text.homeUrl },
    { name: entry.data.title, url: entry.url }
  ]}
>
  <article class="about-story" style="--leftjun-language-transition-name: lj-about-story;">
    <header class="about-story__hero">
      <div class="about-story__heading">
        <p class="about-story__eyebrow">{labels.eyebrow}</p>
        <h1>{entry.data.title}</h1>
        {entry.data.description && <p class="about-story__description">{entry.data.description}</p>}
        <div class="about-story__signature" aria-hidden="true">
          <strong>LEFT JUN</strong>
          <span>LIMENAUTS</span>
        </div>
      </div>
      {introductionHtml && <div class="about-story__introduction" set:html={introductionHtml}></div>}
    </header>

    {featuredProjects.length > 0 && (
      <section class="about-story__work" aria-labelledby="about-story-work-title">
        <header class="about-story__section-heading">
          <div>
            <p>{labels.selectedWork}</p>
            <h2 id="about-story-work-title">{labels.representativeProjects}</h2>
          </div>
          <a href={projectsUrl}>
            <span>{labels.allProjects}</span>
            <Icon name="chevron-right" />
          </a>
        </header>
        <div class="about-story__media-rail">
          {featuredProjects.map((project, index) => {
            const imageUrl = project.asset(String(project.data.image));
            const videoUrl = project.data.coverVideo
              ? project.asset(String(project.data.coverVideo))
              : "";

            return (
              <a class="about-story__project" href={project.url}>
                <span class="about-story__project-media">
                  <CoverMedia
                    imageSrc={imageUrl}
                    videoSrc={videoUrl}
                    alt={project.data.title}
                    class="about-story__project-image"
                    sizes="(max-width: 767px) 82vw, (max-width: 1000px) min(70vw, 300px), 33vw"
                    loading={index === 0 ? "eager" : "lazy"}
                    fetchpriority={index === 0 ? "high" : "auto"}
                    style={`object-position: ${project.data.imagePosition || "center"};`}
                  />
                </span>
                <span class="about-story__project-copy">
                  <strong>{project.data.title}</strong>
                  {project.data.projectFacts?.role && (
                    <small><span>{labels.projectRole}</span>{project.data.projectFacts.role}</small>
                  )}
                </span>
              </a>
            );
          })}
        </div>
      </section>
    )}

    {sectionsHtml && (
      <div class="about-story__body">
        {sectionLinks.length > 0 && (
          <nav class="about-story__index" aria-label={labels.sections}>
            <p>{labels.sections}</p>
            <div>
              {sectionLinks.map((item) => <a href={`#${item.id}`}>{item.text}</a>)}
            </div>
          </nav>
        )}
        <section class="about-story__sections" set:html={sectionsHtml}></section>
      </div>
    )}

    {contactEntry && (
      <section class="about-story__contact" aria-labelledby="about-story-contact-title">
        <div>
          <p class="about-story__contact-eyebrow">{labels.contactEyebrow}</p>
          <h2 id="about-story-contact-title">{labels.contactTitle}</h2>
          {labels.contactDescription && <p>{labels.contactDescription}</p>}
        </div>
        <div class="about-story__contact-actions">
          {contactEmail && (
            <a class="about-story__contact-action about-story__contact-action--primary" href={`mailto:${contactEmail}`}>
              <Icon name="messages" />
              <span>{labels.email}</span>
            </a>
          )}
          <a class="about-story__contact-action" href={contactEntry.url}>
            <span>{labels.contactPage}</span>
            <Icon name="chevron-right" />
          </a>
        </div>
      </section>
    )}
  </article>
</BaseLayout>

<style>
  .about-story {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: 52px;
    width: 100%;
    min-width: 0;
    max-width: 100%;
  }

  .about-story__hero {
    display: grid;
    grid-template-columns: minmax(250px, 0.72fr) minmax(0, 1.28fr);
    gap: clamp(34px, 5vw, 72px);
    width: 100%;
    min-width: 0;
    max-width: 100%;
    padding: 16px 0 40px;
    border-bottom: 1px solid var(--card-separator-color);
  }

  .about-story__heading {
    align-self: start;
    min-width: 0;
  }

  .about-story__eyebrow,
  .about-story__section-heading p,
  .about-story__contact-eyebrow {
    margin: 0 0 8px;
    color: var(--leftjun-primary);
    font-size: 12px;
    font-weight: 820;
    line-height: 1.4;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  .about-story__heading h1 {
    max-width: 640px;
    margin: 0;
    color: var(--card-text-color-main);
    font-size: 40px;
    line-height: 1.08;
    letter-spacing: 0;
  }

  .about-story__description {
    max-width: 560px;
    margin: 16px 0 0;
    color: var(--card-text-color-secondary);
    font-size: 16px;
    line-height: 1.7;
  }

  .about-story__signature {
    display: flex;
    align-items: baseline;
    flex-wrap: wrap;
    gap: 7px 12px;
    margin-top: 30px;
    padding: 18px 0 0 18px;
    border-left: 3px solid var(--leftjun-primary);
  }

  .about-story__signature strong {
    color: var(--card-text-color-main);
    font-size: 22px;
    line-height: 1;
    letter-spacing: 0;
  }

  .about-story__signature span {
    color: var(--card-text-color-tertiary);
    font-size: 13px;
    font-weight: 760;
    line-height: 1.2;
    letter-spacing: 0;
  }

  .about-story__introduction {
    align-self: end;
    min-width: 0;
    padding-left: clamp(22px, 3vw, 42px);
    border-left: 1px solid var(--card-separator-color);
  }

  .about-story__introduction :global(p) {
    margin: 0;
    color: var(--card-text-color-secondary);
    font-size: 15px;
    line-height: 1.75;
  }

  .about-story__introduction :global(p:first-child) {
    color: var(--card-text-color-main);
    font-size: 17px;
  }

  .about-story__introduction :global(p + p) {
    margin-top: 14px;
  }

  .about-story__introduction :global(a),
  .about-story__sections :global(a) {
    color: var(--accent-color-darker);
    text-underline-offset: 0.18em;
  }

  .about-story__section-heading {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 24px;
    margin-bottom: 18px;
    padding-bottom: 14px;
    border-bottom: 1px solid var(--card-separator-color);
  }

  .about-story__work,
  .about-story__body {
    width: 100%;
    min-width: 0;
    max-width: 100%;
  }

  .about-story__section-heading h2 {
    margin: 0;
    color: var(--card-text-color-main);
    font-size: 26px;
    line-height: 1.25;
    letter-spacing: 0;
  }

  .about-story__section-heading > a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 7px;
    min-height: 44px;
    padding: 0 4px 0 12px;
    color: var(--accent-color-darker);
    font-size: 14px;
    font-weight: 760;
    text-decoration: none;
  }

  .about-story__section-heading > a :global(.inline-icon) {
    width: 20px;
    height: 20px;
  }

  .about-story__media-rail {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 16px;
    min-width: 0;
  }

  .about-story__project {
    display: grid;
    grid-template-rows: auto 1fr;
    min-width: 0;
    overflow: hidden;
    border: 1px solid var(--card-separator-color);
    border-radius: 16px;
    background: var(--leftjun-surface-strong);
    color: inherit;
    text-decoration: none;
    box-shadow: var(--shadow-l1);
    transition: transform var(--leftjun-hover-duration) ease, border-color var(--leftjun-hover-duration) ease, box-shadow var(--leftjun-hover-duration) ease;
  }

  .about-story__project:hover,
  .about-story__project:focus-visible {
    transform: translateY(var(--leftjun-hover-lift));
    border-color: var(--leftjun-hover-border);
    box-shadow: var(--leftjun-hover-shadow);
  }

  .about-story__project-media {
    display: block;
    aspect-ratio: 16 / 9;
    min-width: 0;
    overflow: hidden;
    background: var(--leftjun-surface-muted);
  }

  .about-story__project-media :global(picture) {
    display: block;
    width: 100%;
    height: 100%;
  }

  .about-story__project-media :global(video) {
    display: block;
    width: 100%;
    height: 100%;
  }

  .about-story__project-media :global(.about-story__project-image) {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .about-story__project-copy {
    display: grid;
    align-content: start;
    gap: 8px;
    padding: 15px 16px 17px;
  }

  .about-story__project-copy > strong {
    color: var(--card-text-color-main);
    font-size: 16px;
    line-height: 1.35;
  }

  .about-story__project-copy small {
    display: grid;
    gap: 2px;
    color: var(--card-text-color-secondary);
    font-size: 12px;
    line-height: 1.5;
  }

  .about-story__project-copy small span {
    color: var(--card-text-color-tertiary);
    font-size: 12px;
    font-weight: 760;
  }

  .about-story__body {
    display: grid;
    grid-template-columns: 190px minmax(0, 1fr);
    align-items: start;
    gap: clamp(34px, 4vw, 58px);
  }

  .about-story__index {
    position: sticky;
    top: var(--main-top-padding);
    min-width: 0;
    padding-left: 16px;
    border-left: 2px solid color-mix(in srgb, var(--leftjun-primary) 48%, var(--card-separator-color));
  }

  .about-story__index > p {
    margin: 0 0 8px;
    color: var(--card-text-color-tertiary);
    font-size: 12px;
    font-weight: 800;
    line-height: 1.4;
  }

  .about-story__index > div {
    display: grid;
    gap: 2px;
  }

  .about-story__index a {
    display: flex;
    align-items: center;
    min-height: 44px;
    padding: 8px 10px;
    border-radius: 10px;
    color: var(--card-text-color-secondary);
    font-size: 13px;
    font-weight: 680;
    line-height: 1.35;
    text-decoration: none;
  }

  .about-story__index a:hover,
  .about-story__index a:focus-visible {
    background: var(--leftjun-hover-surface);
    color: var(--accent-color-darker);
  }

  .about-story__sections {
    width: 100%;
    min-width: 0;
    max-width: 920px;
  }

  .about-story__sections :global(h2) {
    margin: 48px 0 18px;
    padding-top: 30px;
    border-top: 1px solid var(--card-separator-color);
    color: var(--card-text-color-main);
    font-size: 26px;
    line-height: 1.25;
    letter-spacing: 0;
    scroll-margin-top: 32px;
  }

  .about-story__sections :global(h2:first-child) {
    margin-top: 0;
  }

  .about-story__sections :global(h3) {
    margin: 30px 0 12px;
    color: var(--card-text-color-main);
    font-size: 19px;
    line-height: 1.35;
    letter-spacing: 0;
  }

  .about-story__sections :global(p),
  .about-story__sections :global(li) {
    color: var(--card-text-color-secondary);
    font-size: 15px;
    line-height: 1.75;
  }

  .about-story__sections :global(p) {
    margin: 0 0 16px;
  }

  .about-story__sections :global(ul),
  .about-story__sections :global(ol) {
    display: grid;
    gap: 10px;
    margin: 0;
    padding-left: 1.45em;
  }

  .about-story__sections :global(li::marker) {
    color: var(--leftjun-primary);
  }

  .about-story__sections :global(strong) {
    color: var(--card-text-color-main);
  }

  .about-story__contact {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: center;
    gap: 28px;
    padding: 32px 0;
    border-top: 1px solid var(--card-separator-color);
    border-bottom: 1px solid var(--card-separator-color);
  }

  .about-story__contact h2 {
    margin: 0;
    color: var(--card-text-color-main);
    font-size: 24px;
    line-height: 1.25;
    letter-spacing: 0;
  }

  .about-story__contact > div > p:last-child {
    max-width: 720px;
    margin: 9px 0 0;
    color: var(--card-text-color-secondary);
    font-size: 15px;
    line-height: 1.65;
  }

  .about-story__contact-actions {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    justify-content: flex-end;
    gap: 10px;
  }

  .about-story__contact-action {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    min-height: 44px;
    padding: 10px 14px;
    border: 1px solid var(--card-separator-color);
    border-radius: 10px;
    background: var(--leftjun-surface-strong);
    color: var(--card-text-color-main);
    font-size: 14px;
    font-weight: 760;
    line-height: 1.35;
    text-decoration: none;
  }

  .about-story__contact-action--primary {
    border-color: color-mix(in srgb, var(--leftjun-primary) 42%, var(--card-separator-color));
    background: var(--leftjun-primary);
    color: #fff;
  }

  .about-story__contact-action:hover,
  .about-story__contact-action:focus-visible {
    border-color: var(--leftjun-hover-border);
    box-shadow: var(--leftjun-surface-shadow-soft);
  }

  .about-story__contact-action :global(.inline-icon) {
    width: 18px;
    height: 18px;
  }

  @media (min-width: 768px) and (max-width: 1180px) {
    .about-story {
      gap: 44px;
    }

    .about-story__hero {
      grid-template-columns: minmax(220px, 0.68fr) minmax(0, 1.32fr);
      gap: 30px;
      padding-top: 10px;
    }

    .about-story__heading h1 {
      font-size: 34px;
    }

    .about-story__description {
      font-size: 15px;
    }

    .about-story__section-heading h2,
    .about-story__sections :global(h2) {
      font-size: 24px;
    }

    .about-story__body {
      grid-template-columns: minmax(0, 1fr);
      gap: 28px;
    }

    .about-story__index {
      position: relative;
      top: auto;
      padding: 0 0 12px;
      overflow-x: auto;
      border-left: 0;
      border-bottom: 1px solid var(--card-separator-color);
      scrollbar-width: thin;
    }

    .about-story__index > p {
      margin-bottom: 7px;
    }

    .about-story__index > div {
      display: flex;
      gap: 8px;
      width: max-content;
    }

    .about-story__index a {
      min-height: 44px;
      border: 1px solid var(--card-separator-color);
      background: var(--leftjun-surface-strong);
      white-space: nowrap;
    }
  }

  @media (min-width: 768px) and (max-width: 1000px) {
    .about-story__hero {
      grid-template-columns: minmax(0, 1fr);
      gap: 24px;
    }

    .about-story__introduction {
      padding: 24px 0 0;
      border-top: 1px solid var(--card-separator-color);
      border-left: 0;
    }

    .about-story__media-rail {
      display: flex;
      gap: 14px;
      padding-bottom: 14px;
      overflow-x: auto;
      scroll-snap-type: x proximity;
      scrollbar-width: thin;
    }

    .about-story__project {
      flex: 0 0 min(70%, 300px);
      scroll-snap-align: start;
    }
  }

  @media (max-width: 767px) {
    .about-story {
      gap: 32px;
      padding-bottom: 18px;
    }

    .about-story__hero {
      grid-template-columns: minmax(0, 1fr);
      gap: 24px;
      padding: 0 0 28px;
    }

    .about-story__heading h1 {
      font-size: 28px;
    }

    .about-story__description {
      margin-top: 11px;
      font-size: 15px;
    }

    .about-story__signature {
      margin-top: 20px;
      padding-top: 14px;
    }

    .about-story__signature strong {
      font-size: 20px;
    }

    .about-story__introduction {
      padding: 0;
      border-left: 0;
    }

    .about-story__introduction :global(p),
    .about-story__introduction :global(p:first-child) {
      font-size: 15px;
    }

    .about-story__section-heading {
      align-items: start;
      margin-bottom: 12px;
      padding-bottom: 10px;
    }

    .about-story__section-heading h2 {
      font-size: 22px;
    }

    .about-story__section-heading > a {
      min-width: 44px;
      padding: 0;
    }

    .about-story__section-heading > a span {
      position: absolute;
      width: 1px;
      height: 1px;
      padding: 0;
      overflow: hidden;
      clip: rect(0, 0, 0, 0);
      white-space: nowrap;
      border: 0;
    }

    .about-story__media-rail {
      display: flex;
      gap: 12px;
      margin-inline: calc(var(--leftjun-layout-gutter) * -1);
      padding: 2px var(--leftjun-layout-gutter) 16px;
      overflow-x: auto;
      scroll-snap-type: x proximity;
      scrollbar-width: thin;
    }

    .about-story__project {
      flex: 0 0 min(82vw, 340px);
      scroll-snap-align: start;
    }

    .about-story__project-copy > strong {
      font-size: 16px;
    }

    .about-story__body {
      grid-template-columns: minmax(0, 1fr);
      gap: 24px;
    }

    .about-story__index {
      position: relative;
      top: auto;
      margin-inline: calc(var(--leftjun-layout-gutter) * -1);
      padding: 0 var(--leftjun-layout-gutter) 10px;
      overflow-x: auto;
      border-left: 0;
      border-bottom: 1px solid var(--card-separator-color);
      scrollbar-width: thin;
    }

    .about-story__index > p {
      margin-bottom: 7px;
    }

    .about-story__index > div {
      display: flex;
      gap: 8px;
      width: max-content;
    }

    .about-story__index a {
      min-height: 44px;
      border: 1px solid var(--card-separator-color);
      background: var(--leftjun-surface-strong);
      white-space: nowrap;
    }

    .about-story__sections :global(h2) {
      margin-top: 38px;
      padding-top: 24px;
      font-size: 22px;
      scroll-margin-top: 20px;
    }

    .about-story__sections :global(p),
    .about-story__sections :global(li) {
      font-size: 15px;
    }

    .about-story__contact {
      grid-template-columns: 1fr;
      gap: 18px;
      padding: 26px 0;
    }

    .about-story__contact h2 {
      font-size: 22px;
    }

    .about-story__contact-actions {
      display: grid;
      grid-template-columns: 1fr;
      justify-content: stretch;
    }

    .about-story__contact-action {
      width: 100%;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .about-story__project {
      transition: none;
    }
  }
</style>
