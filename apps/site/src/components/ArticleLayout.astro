---
import BaseLayout from "../layouts/BaseLayout.astro";
import PostCard from "./PostCard.astro";
import {
  relatedEntries,
  siteText
} from "../lib/content.js";

const { entry, active = entry.section, lang = entry.lang } = Astro.props;
const text = siteText(lang);
const related = await relatedEntries(entry);
const facts = entry.data.projectFacts || {};
const projectLinks: Array<Record<string, string>> = entry.data.projectLinks || [];
const tocItems: Array<{ depth: number; text: string; id: string }> = entry.toc || [];
const factLabels = text.isEn
  ? { developmentTime: "Time", duration: "Duration", role: "Role", tools: "Tools", platform: "Platform", result: "Outcome" }
  : { developmentTime: "开发时间", duration: "开发周期", role: "职能", tools: "工具 / 技术", platform: "平台", result: "成果" };
const cover = entry.data.coverVideo || entry.data.image;
---
<BaseLayout lang={lang} title={entry.data.title} description={entry.data.description} image={entry.data.image ? entry.asset(entry.data.image) : undefined} active={active}>
  <div class="detail-grid">
    <article class="article-shell glass">
      {cover && (
        <div class="article-cover">
          {entry.data.coverVideo ? (
            <video src={entry.asset(entry.data.coverVideo)} poster={entry.data.image ? entry.asset(entry.data.image) : undefined} autoplay muted loop playsinline></video>
          ) : (
            <img src={entry.asset(entry.data.image)} alt={entry.data.title} loading="eager" />
          )}
        </div>
      )}
      <div class="article-inner">
        <h1 class="article-title">{entry.data.title}</h1>
        {entry.data.description && <p class="article-description">{entry.data.description}</p>}
        <div class="article-meta">
          {entry.formattedDate && <span>{entry.formattedDate}</span>}
          <span>{text.isEn ? `${entry.readingMinutes} ${text.readMinutes}` : `阅读时长: ${entry.readingMinutes} ${text.readMinutes}`}</span>
          {entry.lang === "zh-cn" && entry.section !== "retrospectives" && entry.section !== "plans" && (
            <a href={entry.section === "pages" ? `/en/${entry.slug}/` : `/en/${entry.section}/${entry.slug}/`}>English</a>
          )}
        </div>

        {entry.section === "projects" && Object.keys(facts).length > 0 && (
          <dl class="project-facts">
            {Object.entries(factLabels).map(([key, label]) => facts[key] && (
              <div>
                <dt>{label}</dt>
                <dd>{facts[key]}</dd>
              </div>
            ))}
          </dl>
        )}

        {entry.section === "projects" && projectLinks.length > 0 && (
          <section class="content-section" style="margin-top: 24px;">
            <div class="section-heading"><h2>{text.projectLinks}</h2></div>
            <div class="action-row">
              {projectLinks.map((link) => (
                <a class="action-button" href={link.url || link.website} target="_blank" rel="noopener noreferrer">{link.label || link.title || link.url || link.website}</a>
              ))}
            </div>
          </section>
        )}

        <div class="article-content" set:html={entry.html}></div>

        {related.length > 0 && (
          <section class="content-section" style="margin-top: 34px;">
            <div class="section-heading"><h2>{entry.section === "projects" ? text.relatedRecords : text.relatedReading}</h2></div>
            <div class="related-grid">
              {related.map((item) => <PostCard entry={item} />)}
            </div>
          </section>
        )}
      </div>
    </article>

    {tocItems.length > 0 && (
      <aside class="toc-card glass">
        <h2>{text.toc}</h2>
        {tocItems.map((item) => (
          <a href={`#${item.id}`} style={`padding-left:${Math.max(0, item.depth - 2) * 12}px`}>{item.text}</a>
        ))}
      </aside>
    )}
  </div>
</BaseLayout>
