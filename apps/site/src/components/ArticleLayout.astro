---
import BaseLayout from "../layouts/BaseLayout.astro";
import Icon from "./Icon.astro";
import RelatedCard from "./RelatedCard.astro";
import {
  getEntryBySlug,
  relatedEntries,
  siteText,
  taxonomyTermUrl
} from "../lib/content.js";

const { entry, active = entry.section, lang = entry.lang } = Astro.props;
const text = siteText(lang);
const related = await relatedEntries(entry);
const projectRecords = related.filter((item) => item.section === "retrospectives" || item.section === "plans");
const relatedReading = related.filter((item) => item.section !== "retrospectives" && item.section !== "plans");
const facts = entry.data.projectFacts || {};
const projectLinks: Array<Record<string, string>> = entry.data.projectLinks || [];
const tocItems: Array<{ depth: number; text: string; id: string }> = entry.toc || [];
const isProject = entry.section === "projects";
const isAboutPage = entry.section === "pages" && entry.slug === "about";
const contactEntry = isAboutPage ? await getEntryBySlug("pages", "contact", lang) : null;
const contactCardCta = text.isEn ? "Open contact page" : "查看完整联系页";
const projectQuickLinks = isProject
  ? projectLinks
    .map((link) => {
      const label = String(link.label || link.title || "");
      const href = String(link.url || link.website || "");
      const icon = String(link.icon || "");
      const target = `${label} ${href}`.toLowerCase();
      const kind = target.includes("taptap")
        ? "taptap"
        : /可执行|playable|executable|build|pan\.quark/.test(target)
          ? "build"
          : "";
      return { label, href, icon, kind };
    })
    .filter((link) => link.href && link.kind)
  : [];
const tagLinks: Array<{ name: string; url: string }> = (entry.data.tags || []).filter(Boolean).map((tag: string) => ({
  name: tag,
  url: taxonomyTermUrl("tags", tag, lang)
}));
const cover = entry.data.coverVideo || entry.data.image;
const imagePosition = entry.data.imagePosition || "center";
const alternateLang = text.isEn ? "zh-cn" : "en";
const alternateEntry = await getEntryBySlug(entry.section, entry.slug, alternateLang);
const alternateUrl = alternateEntry?.url;
const alternateLabel = text.isEn ? "中文" : "English";
const portfolioPdfUrl = "/files/left-jun-portfolio.pdf";
const portfolioPdfLabel = text.isEn ? "Portfolio PDF" : "作品集 PDF";
const portfolioDownloadLabel = text.isEn ? "Download" : "下载";
const portfolioOpenAria = text.isEn ? "Open portfolio PDF" : "打开作品集 PDF";
const portfolioDownloadAria = text.isEn ? "Download portfolio PDF" : "下载作品集 PDF";
const roleText = String(facts.role || "");
const developmentTimeText = String(facts.developmentTime || "").replace(/\s*[\(（].*?[)）]\s*$/, "");
const inferredTeam = text.isEn
  ? (roleText.toLowerCase().includes("solo") ? "Solo" : "Team project")
  : (roleText.includes("独立") || roleText.includes("单人") ? "独立开发" : "团队项目");
const projectInfoItems = isProject ? [
  { icon: "clock", label: text.isEn ? "Time" : "开发时间", value: developmentTimeText || facts.developmentTime, note: facts.duration },
  { icon: "users", label: text.isEn ? "Team" : "团队规模", value: facts.team || inferredTeam, note: facts.event || facts.competition },
  { icon: "user", label: text.isEn ? "My Role" : "我的角色", value: facts.role, note: facts.roleNote },
  { icon: "display", label: text.isEn ? "Platform" : "开发平台", value: facts.platform, note: facts.platformNote },
  { icon: "code", label: text.isEn ? "Tools" : "使用技术", value: facts.tools, note: facts.techNote }
].filter((item) => item.value) : [];
const projectPills = isProject
  ? [...new Set([...(entry.data.roleTags || []), ...(entry.data.tags || [])].filter(Boolean))]
  : [];
const projectSummaryItems = isProject ? [
  { label: text.isEn ? "Duration" : "开发周期", value: facts.duration },
  { label: text.isEn ? "Team" : "团队人数", value: facts.team || inferredTeam },
  { label: text.isEn ? "Event" : "比赛", value: facts.event || facts.competition || String(facts.developmentTime || "").match(/（(.+?)）/)?.[1] },
  { label: text.isEn ? "Finished" : "完成时间", value: facts.finishedAt || entry.formattedDate }
].filter((item) => item.value) : [];
---
<BaseLayout
  lang={lang}
  title={entry.data.title}
  description={entry.data.description}
  image={entry.data.image ? entry.asset(entry.data.image) : undefined}
  priorityImage={entry.data.image ? entry.asset(entry.data.image) : undefined}
  active={active}
  bodyClass={isProject ? "article-page project-detail-page" : "article-page"}
>
  <article class:list={["main-article", cover && "has-image"]}>
    <header class:list={["article-header", isProject && "project-detail-hero"]}>
      {cover && (
        <div class="article-image">
          {entry.data.coverVideo ? (
            <video
              autoplay
              muted
              loop
              playsinline
              preload="metadata"
              controlslist="nodownload noplaybackrate noremoteplayback"
              disablepictureinpicture
              disableRemotePlayback
              poster={entry.data.image ? entry.asset(entry.data.image) : undefined}
              style={`object-position: ${imagePosition};`}
            >
              <source src={entry.asset(entry.data.coverVideo)} type="video/mp4" />
            </video>
          ) : (
            <img
              src={entry.asset(entry.data.image)}
              alt={entry.data.title}
              loading="eager"
              decoding="async"
              fetchpriority="high"
              style={`object-position: ${imagePosition};`}
            />
          )}
        </div>
      )}
      <div class:list={["article-details", isProject && "project-detail-hero__details"]}>
        {isProject && <p class="project-detail-kicker">{text.isEn ? "Project Case" : "项目案例"}</p>}
        <h1 class="article-title">{entry.data.title}</h1>
        {entry.data.description && <h2 class="article-subtitle">{entry.data.description}</h2>}
        {isProject && projectPills.length > 0 && (
          <div class="project-detail-pills" aria-label={text.isEn ? "Project tags" : "项目标签"}>
            {projectPills.slice(0, 6).map((pill) => <span>{pill}</span>)}
          </div>
        )}
        {!isProject && (
          <footer class="article-time">
            {entry.formattedDate && <span>{entry.formattedDate}</span>}
            <span>{text.isEn ? `${entry.readingMinutes} ${text.readMinutes}` : `阅读时长：${entry.readingMinutes} ${text.readMinutes}`}</span>
            {alternateUrl && <a href={alternateUrl} data-language-transition>{alternateLabel}</a>}
          </footer>
        )}
        {isProject && (
          <footer class="project-detail-actions">
            <a class="project-detail-action project-detail-action--pdf" href={portfolioPdfUrl} target="_blank" rel="noopener noreferrer" aria-label={portfolioOpenAria}>
              <Icon name="briefcase" label="" />
              <span>{portfolioPdfLabel}</span>
            </a>
            <a class="project-detail-action project-detail-action--download" href={portfolioPdfUrl} download aria-label={portfolioDownloadAria}>
              {portfolioDownloadLabel}
            </a>
            {alternateUrl && <a class="project-detail-action project-detail-action--language" href={alternateUrl} data-language-transition>{alternateLabel}</a>}
          </footer>
        )}
        {isProject && (projectQuickLinks.length > 0 || alternateUrl) && (
          <div class="project-detail-mobile-actions" aria-label={text.isEn ? "Project quick links" : "项目快捷入口"}>
            {projectQuickLinks.map((link) => (
              <a
                class:list={["project-detail-mobile-action", `project-detail-mobile-action--${link.kind}`]}
                href={link.href}
                target="_blank"
                rel="noopener noreferrer"
              >
                <Icon name={link.icon || (link.kind === "build" ? "display" : "link")} label="" />
                <span>{link.label}</span>
              </a>
            ))}
            {alternateUrl && (
              <a class="project-detail-mobile-action project-detail-mobile-action--language" href={alternateUrl} data-language-transition>
                <Icon name="language" label="" />
                <span>{alternateLabel}</span>
              </a>
            )}
          </div>
        )}
      </div>
    </header>

    {isProject && projectInfoItems.length > 0 && (
      <section class="project-info-strip" aria-label={text.projectProfile}>
        <dl class="project-info-strip__grid">
          {projectInfoItems.map((item) => (
            <div class="project-info-strip__item">
              <dt><Icon name={item.icon} /><span>{item.label}</span></dt>
              <dd>{item.value}</dd>
              {item.note && <small>{item.note}</small>}
            </div>
          ))}
        </dl>
        {facts.result && <p class="project-info-strip__outcome">{facts.result}</p>}
      </section>
    )}

    {entry.section === "projects" && projectLinks.length > 0 && (
      <section class="project-links project-links--primary" aria-label={text.projectLinks}>
        <h2 class="project-links__title sr-only">{text.projectLinks}</h2>
        <div class="project-links__list">
          {projectLinks.map((link) => (
            <a class="project-links__button" href={link.url || link.website} target="_blank" rel="noopener noreferrer">
              <Icon name={link.icon || "link"} />
              <span>{link.label || link.title || link.url || link.website}</span>
            </a>
          ))}
        </div>
      </section>
    )}

    {entry.section === "projects" && projectRecords.length > 0 && (
      <section class="project-links project-record-pills" aria-label={text.relatedRecords}>
        <h2 class="project-links__title sr-only">{text.relatedRecords}</h2>
        <div class="project-links__list">
          {projectRecords.map((item) => {
            const isRetrospective = item.section === "retrospectives";
            return (
              <a class:list={["project-links__button", "project-record-pill", isRetrospective ? "project-record-pill--retrospective" : "project-record-pill--plan"]} href={item.url}>
                <Icon name={isRetrospective ? "infinity" : "clock"} />
                <span>{isRetrospective ? (text.isEn ? "Project Retrospective" : "项目复盘") : (text.isEn ? "Development Plan" : "开发计划")}</span>
              </a>
            );
          })}
        </div>
      </section>
    )}

    {tocItems.length > 0 && (
      <aside class="article-toc">
        <details>
          <summary>
            <div class="article-toc-title">
              <Icon name="chevron-right" />
              <span>{text.toc}</span>
            </div>
          </summary>
          <nav class="toc-nav">
            {tocItems.map((item) => (
              <a href={`#${item.id}`} style={`--toc-indent:${Math.max(0, item.depth - 2) * 12}px`}>{item.text}</a>
            ))}
          </nav>
        </details>
      </aside>
    )}

    <section class="article-content" set:html={entry.html}></section>

    {contactEntry && (
      <section class="about-contact-card" aria-labelledby="about-contact-card-title">
        <div class="about-contact-card__heading">
          <p class="about-contact-card__eyebrow">{text.isEn ? "Contact" : "联系我"}</p>
          <h2 id="about-contact-card-title">{contactEntry.data.title}</h2>
          {contactEntry.data.description && <p>{contactEntry.data.description}</p>}
        </div>
        <div class="about-contact-card__body" set:html={contactEntry.html}></div>
        <a class="about-contact-card__link" href={contactEntry.url}>
          <Icon name="link" label="" />
          <span>{contactCardCta}</span>
        </a>
      </section>
    )}

    {tagLinks.length > 0 && (
      <footer class="article-footer">
        <section class="article-tags" aria-label={text.isEn ? "Keywords" : "关键词"}>
          {tagLinks.map((tag) => <a href={tag.url}>{tag.name}</a>)}
        </section>
      </footer>
    )}
  </article>

  {relatedReading.length > 0 && (
    <aside class="related-content--wrapper" aria-label={text.relatedReading}>
      <h2 class="section-title">{text.relatedReading}</h2>
      <div class="related-content">
        <div class="related-grid">
          {relatedReading.map((item) => <RelatedCard entry={item} />)}
        </div>
      </div>
    </aside>
  )}

  {tocItems.length > 0 && (
    <Fragment slot="right-sidebar">
      <aside class="sidebar right-sidebar sticky">
        <section class="widget widget--toc">
          <h2 class="widget-title">{text.toc}</h2>
          <nav class="toc-nav">
            {tocItems.map((item) => (
              <a href={`#${item.id}`} style={`--toc-indent:${Math.max(0, item.depth - 2) * 12}px`}>{item.text}</a>
            ))}
          </nav>
        </section>
        {projectLinks.length > 0 && (
          <section class="widget project-download-widget">
            <h2 class="widget-title">{text.isEn ? "Downloads" : "项目资料下载"}</h2>
            <div class="project-download-list">
              {projectLinks.map((link) => (
                <a href={link.url || link.website} target="_blank" rel="noopener noreferrer">
                  <Icon name={link.icon || "link"} />
                  <span>{link.label || link.title || link.url || link.website}</span>
                  <Icon name="chevron-right" />
                </a>
              ))}
            </div>
          </section>
        )}
        {isProject && projectSummaryItems.length > 0 && (
          <section class="widget project-summary-widget">
            <h2 class="widget-title">{text.isEn ? "Project Info" : "项目信息"}</h2>
            <dl>
              {projectSummaryItems.map((item) => (
                <div>
                  <dt>{item.label}</dt>
                  <dd>{item.value}</dd>
                </div>
              ))}
            </dl>
          </section>
        )}
      </aside>
    </Fragment>
  )}
</BaseLayout>
