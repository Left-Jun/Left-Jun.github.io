---
import CoverMedia from "./CoverMedia.astro";
import { timelineEntryCopy } from "../lib/timeline.js";
import type { TimelineEntry } from "../lib/timeline.js";

interface Props {
  entry: TimelineEntry;
  lang?: "zh-cn" | "en";
  variant?: "spotlight" | "timeline" | "archive";
}

const { entry, lang = "zh-cn", variant = "timeline" } = Astro.props as Props;
const labels = timelineEntryCopy(entry, lang);
const image = entry.data.image || "";
const imageUrl = image ? entry.asset(image) : "";
const videoUrl = entry.data.coverVideo ? entry.asset(entry.data.coverVideo) : "";
const imagePosition = String(entry.data.imagePosition || "center");
const terms = [...(entry.data.categories || []), ...(entry.data.tags || [])].filter(Boolean).slice(0, 2);
const showKind = entry.source === "updates" && labels.kind !== labels.source;
const contribution = entry.source === "updates" && typeof entry.data.contribution === "string" ? entry.data.contribution.trim() : "";
const result = entry.source === "updates" && typeof entry.data.result === "string" ? entry.data.result.trim() : "";
const related = entry.source === "updates" ? (entry.timelineRelatedEntries || []).slice(0, 2) : [];
const evidence = entry.source === "updates" && Array.isArray(entry.data.projectLinks) ? entry.data.projectLinks[0] : null;
const detailLabels = {
  contribution: lang === "en" ? "Contribution" : "个人贡献",
  result: lang === "en" ? "Outcome" : "结果",
  related: lang === "en" ? "Related" : "关联内容",
  evidence: lang === "en" ? "Evidence" : "成果证据"
};
---

<article
  class:list={[
    "timeline-entry",
    `timeline-entry--${variant}`,
    `timeline-entry--${entry.timelineKind}`,
    `timeline-entry--group-${entry.filterGroup}`,
    image && "timeline-entry--has-media"
  ]}
  data-timeline-item
  data-timeline-group={entry.filterGroup}
  data-timeline-year={entry.year}
  data-timeline-kind={entry.timelineKind}
>
  <div class="timeline-entry__content">
    <div class="timeline-entry__meta">
      <span class="timeline-entry__source">{labels.source}</span>
      {showKind && <span class="timeline-entry__kind">{labels.kind}</span>}
      {labels.status && <span class="timeline-entry__status">{labels.status}</span>}
      {entry.formattedDate && (
        <time datetime={entry.data.date?.toISOString?.()}>{entry.formattedDate}</time>
      )}
    </div>

    <h3><a href={entry.url}>{entry.data.title}</a></h3>
    {entry.data.description && <p>{entry.data.description}</p>}

    {(contribution || result) && (
      <dl class="timeline-entry__outcomes">
        {contribution && <div><dt>{detailLabels.contribution}</dt><dd>{contribution}</dd></div>}
        {result && <div><dt>{detailLabels.result}</dt><dd>{result}</dd></div>}
      </dl>
    )}

    {terms.length > 0 && (
      <div class="timeline-entry__terms" aria-label={lang === "en" ? "Topics" : "主题"}>
        {terms.map((term) => <span>{term}</span>)}
      </div>
    )}

    {(related.length > 0 || evidence) && (
      <div class="timeline-entry__references" aria-label={detailLabels.related}>
        {related.map((item) => <a href={item.url}>{item.data.title}</a>)}
        {evidence && (
          <a href={evidence.url} target="_blank" rel="noopener noreferrer">
            {evidence.label || detailLabels.evidence}<span aria-hidden="true">↗</span>
          </a>
        )}
      </div>
    )}

    <a class="timeline-entry__cta" href={entry.url}>
      <span>{labels.cta}</span><span aria-hidden="true">→</span>
    </a>
  </div>

  {image && (
    <a class="timeline-entry__media" href={entry.url} aria-label={entry.data.title} tabindex="-1">
      <CoverMedia
        imageSrc={imageUrl}
        videoSrc={videoUrl}
        alt=""
        sizes={variant === "spotlight" ? "(max-width: 767px) 92vw, 520px" : "(max-width: 767px) 92vw, 320px"}
        loading={variant === "spotlight" ? "eager" : "lazy"}
        fetchpriority={variant === "spotlight" ? "high" : "auto"}
        style={`object-position: ${imagePosition};`}
      />
    </a>
  )}
</article>

<style>
  .timeline-entry {
    --timeline-accent: var(--leftjun-primary);
    position: relative;
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(190px, 240px);
    overflow: hidden;
    border: 1px solid color-mix(in srgb, var(--timeline-accent) 18%, var(--card-separator-color));
    border-radius: 16px;
    background: var(--leftjun-reading-surface);
    box-shadow: var(--leftjun-surface-shadow-soft);
    transition: transform var(--leftjun-hover-duration) ease, border-color var(--leftjun-hover-duration) ease, box-shadow var(--leftjun-hover-duration) ease;
  }

  .timeline-entry::before {
    position: absolute;
    inset: 0 auto 0 0;
    z-index: 1;
    width: 4px;
    background: var(--timeline-accent);
    content: "";
  }

  .timeline-entry:hover,
  .timeline-entry:focus-within {
    transform: translateY(var(--leftjun-hover-lift));
    border-color: color-mix(in srgb, var(--timeline-accent) 42%, var(--card-separator-color));
    box-shadow: var(--leftjun-hover-shadow);
  }

  .timeline-entry--group-project-progress { --timeline-accent: var(--leftjun-primary); }
  .timeline-entry--group-events-awards { --timeline-accent: #b78318; }
  .timeline-entry--group-learning-research { --timeline-accent: #168477; }
  .timeline-entry--group-publishing-writing { --timeline-accent: #c45f4a; }

  .timeline-entry__content {
    min-width: 0;
    padding: clamp(1.15rem, 2vw, 1.55rem);
  }

  .timeline-entry__meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
    color: var(--card-text-color-tertiary);
    font-size: 0.82rem;
    line-height: 1.35;
  }

  .timeline-entry__source,
  .timeline-entry__kind,
  .timeline-entry__status {
    display: inline-flex;
    align-items: center;
    min-height: 1.7rem;
    padding: 0.28rem 0.58rem;
    border: 1px solid color-mix(in srgb, var(--timeline-accent) 30%, var(--card-separator-color));
    border-radius: 10px;
    background: color-mix(in srgb, var(--timeline-accent) 9%, var(--leftjun-surface-strong));
    color: color-mix(in srgb, var(--timeline-accent) 86%, var(--card-text-color-main));
    font-weight: 730;
  }

  .timeline-entry__kind,
  .timeline-entry__status {
    border-color: var(--card-separator-color);
    background: var(--leftjun-surface-muted);
    color: var(--card-text-color-secondary);
    font-weight: 650;
  }

  .timeline-entry h3 {
    margin: 0.72rem 0 0;
    font-size: clamp(1.35rem, 2vw, 1.8rem);
    line-height: 1.25;
    letter-spacing: 0;
  }

  .timeline-entry h3 a {
    color: var(--card-text-color-main);
    text-decoration: none;
  }

  .timeline-entry h3 a:hover,
  .timeline-entry h3 a:focus-visible,
  .timeline-entry__cta:hover,
  .timeline-entry__cta:focus-visible {
    color: var(--timeline-accent);
  }

  .timeline-entry p {
    display: -webkit-box;
    margin: 0.62rem 0 0;
    overflow: hidden;
    color: var(--card-text-color-secondary);
    line-height: 1.65;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 3;
  }

  .timeline-entry__terms {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    margin-top: 0.85rem;
  }

  .timeline-entry__outcomes {
    display: grid;
    gap: 0.48rem;
    margin: 0.9rem 0 0;
  }

  .timeline-entry__outcomes div {
    display: grid;
    grid-template-columns: max-content minmax(0, 1fr);
    gap: 0.65rem;
  }

  .timeline-entry__outcomes dt {
    color: var(--timeline-accent);
    font-size: 0.78rem;
    font-weight: 780;
  }

  .timeline-entry__outcomes dd {
    margin: 0;
    color: var(--card-text-color-secondary);
    font-size: 0.86rem;
    line-height: 1.5;
  }

  .timeline-entry__references {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    margin-top: 0.8rem;
  }

  .timeline-entry__references a {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.4rem 0.62rem;
    border: 1px solid var(--card-separator-color);
    border-radius: 10px;
    background: var(--leftjun-surface-strong);
    color: var(--card-text-color-secondary);
    font-size: 0.76rem;
    font-weight: 680;
    text-decoration: none;
  }

  .timeline-entry__references a:hover,
  .timeline-entry__references a:focus-visible {
    border-color: color-mix(in srgb, var(--timeline-accent) 42%, var(--card-separator-color));
    color: var(--timeline-accent);
  }

  .timeline-entry__terms span {
    padding: 0.3rem 0.58rem;
    border-radius: 10px;
    background: var(--leftjun-surface-muted);
    color: var(--card-text-color-secondary);
    font-size: 0.76rem;
    line-height: 1.3;
  }

  .timeline-entry__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    margin-top: 1rem;
    color: color-mix(in srgb, var(--timeline-accent) 86%, var(--card-text-color-main));
    font-size: 0.9rem;
    font-weight: 760;
    text-decoration: none;
  }

  .timeline-entry__media {
    display: block;
    align-self: center;
    min-width: 0;
    overflow: hidden;
    margin: 0.7rem 0.7rem 0.7rem 0;
    border-radius: 16px;
    background: var(--leftjun-surface-muted);
    aspect-ratio: 16 / 10;
  }

  .timeline-entry__media :global(picture),
  .timeline-entry__media :global(img),
  .timeline-entry__media :global(video) {
    display: block;
    width: 100%;
    height: 100%;
  }

  .timeline-entry__media :global(img),
  .timeline-entry__media :global(video) {
    aspect-ratio: 16 / 10;
    object-fit: cover;
  }

  .timeline-entry--spotlight {
    grid-template-columns: minmax(250px, 0.92fr) minmax(0, 1.08fr);
    min-height: 290px;
    border-radius: 22px;
    border-color: color-mix(in srgb, var(--timeline-accent) 30%, var(--card-separator-color));
    background:
      linear-gradient(145deg, color-mix(in srgb, var(--timeline-accent) 8%, transparent), transparent 54%),
      var(--leftjun-reading-surface);
    box-shadow: var(--leftjun-surface-shadow);
  }

  .timeline-entry--spotlight .timeline-entry__media {
    grid-column: 1;
    grid-row: 1;
    margin: 0.7rem 0 0.7rem 0.7rem;
  }

  .timeline-entry--spotlight .timeline-entry__content {
    grid-column: 2;
    grid-row: 1;
    align-self: center;
    padding: clamp(1.4rem, 3vw, 2.2rem);
  }

  .timeline-entry--spotlight:not(.timeline-entry--has-media) {
    grid-template-columns: 1fr;
    min-height: 0;
  }

  .timeline-entry--spotlight:not(.timeline-entry--has-media) .timeline-entry__content {
    grid-column: 1;
  }

  .timeline-entry--spotlight h3 {
    font-size: clamp(1.65rem, 3vw, 2.35rem);
  }

  .timeline-entry--archive {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 112px;
    min-height: 0;
    border-radius: 16px;
    box-shadow: var(--shadow-l1);
  }

  .timeline-entry--archive .timeline-entry__content {
    padding: 0.95rem;
  }

  .timeline-entry--archive .timeline-entry__media {
    width: auto;
    margin: 0.52rem 0.52rem 0.52rem 0;
    border-radius: 10px;
  }

  .timeline-entry--archive h3 {
    margin-top: 0.5rem;
    font-size: 1.08rem;
  }

  .timeline-entry--archive p {
    margin-top: 0.4rem;
    font-size: 0.84rem;
    line-height: 1.5;
    -webkit-line-clamp: 2;
  }

  .timeline-entry--archive .timeline-entry__terms {
    display: none;
  }

  .timeline-entry--archive .timeline-entry__cta {
    margin-top: 0.65rem;
    font-size: 0.8rem;
  }

  .timeline-entry--archive:not(.timeline-entry--has-media) {
    grid-template-columns: 1fr;
  }

  @media (max-width: 767px) {
    .timeline-entry {
      display: flex;
      min-height: 0;
      flex-direction: column-reverse;
      border-radius: 16px;
    }

    .timeline-entry--spotlight {
      border-radius: 22px;
    }

    .timeline-entry__content,
    .timeline-entry--spotlight .timeline-entry__content {
      padding: 1.05rem;
    }

    .timeline-entry__media,
    .timeline-entry--spotlight .timeline-entry__media {
      width: auto;
      margin: 0.62rem 0.62rem 0;
    }

    .timeline-entry h3,
    .timeline-entry--spotlight h3 {
      font-size: 1.35rem;
    }

    .timeline-entry--archive,
    .timeline-entry--archive.timeline-entry--has-media {
      display: grid;
      grid-template-columns: minmax(0, 1fr) 92px;
      border-radius: 16px;
    }

    .timeline-entry--archive:not(.timeline-entry--has-media) {
      grid-template-columns: 1fr;
    }

    .timeline-entry--archive .timeline-entry__content {
      padding: 0.85rem;
    }

    .timeline-entry--archive .timeline-entry__media {
      grid-column: 2;
      grid-row: 1;
      width: auto;
      margin: 0.45rem 0.45rem 0.45rem 0;
    }

    .timeline-entry--archive h3 {
      font-size: 1rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .timeline-entry {
      transition: none;
    }

    .timeline-entry:hover,
    .timeline-entry:focus-within {
      transform: none;
    }
  }
</style>
