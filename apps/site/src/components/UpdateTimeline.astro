---
import TimelineEntryCard from "./TimelineEntryCard.astro";
import {
  groupTimelineArchiveByYear,
  groupTimelineByMonth,
  splitTimelineEntries
} from "../lib/timeline.js";
import type { TimelineEntry } from "../lib/timeline.js";

interface Props {
  entries?: TimelineEntry[];
  lang?: "zh-cn" | "en";
}

const { entries = [], lang = "zh-cn" } = Astro.props as Props;
const isEn = lang === "en";
const { spotlight, updates, archive } = splitTimelineEntries(entries);
const updateGroups = groupTimelineByMonth(updates, lang);
const archiveGroups = groupTimelineArchiveByYear(archive);
const labels = {
  spotlightEyebrow: isEn ? "Start here" : "优先阅读",
  spotlight: isEn ? "Spotlight" : "精选动态",
  spotlightHint: isEn ? "A current milestone worth opening first" : "优先了解的近期节点",
  timelineEyebrow: isEn ? "Chronology" : "按月记录",
  timeline: isEn ? "Development log" : "动态主线",
  timelineHint: isEn ? "Published updates, grouped by month" : "按月份整理的正式动态",
  archiveEyebrow: isEn ? "Browse all" : "回看全部",
  archive: isEn ? "Complete archive" : "完整档案",
  archiveHint: isEn
    ? "Projects, writing, retrospectives, and development plans in one chronology"
    : "项目、文章、复盘与开发计划的完整时间档案",
  empty: isEn ? "No entries match these filters." : "没有符合当前筛选条件的内容。",
  initialEmpty: isEn ? "New updates are being prepared." : "新的动态正在整理中。"
};
---

<div class="updates-experience" data-timeline-root>
  {entries.length > 0 ? (
    <>
      {spotlight && (
        <section class="updates-block updates-spotlight" data-timeline-section aria-labelledby="updates-spotlight-title">
          <div class="updates-block__heading">
            <div>
              <p>{labels.spotlightEyebrow}</p>
              <h2 id="updates-spotlight-title">{labels.spotlight}</h2>
            </div>
            <span>{labels.spotlightHint}</span>
          </div>
          <div data-timeline-cluster>
            <TimelineEntryCard entry={spotlight} lang={lang} variant="spotlight" />
          </div>
        </section>
      )}

      {updateGroups.length > 0 && (
        <section class="updates-block updates-stream" data-timeline-section aria-labelledby="updates-stream-title">
          <div class="updates-block__heading">
            <div>
              <p>{labels.timelineEyebrow}</p>
              <h2 id="updates-stream-title">{labels.timeline}</h2>
            </div>
            <span>{labels.timelineHint}</span>
          </div>
          <div class="updates-months">
            {updateGroups.map((group) => (
              <section class="updates-month" data-timeline-cluster aria-labelledby={`updates-month-${group.key}`}>
                <h3 id={`updates-month-${group.key}`}>{group.label}</h3>
                <div class="updates-month__entries">
                  {group.entries.map((entry) => <TimelineEntryCard entry={entry} lang={lang} variant="timeline" />)}
                </div>
              </section>
            ))}
          </div>
        </section>
      )}

      {archiveGroups.length > 0 && (
        <section class="updates-block updates-archive" data-timeline-section aria-labelledby="updates-archive-title">
          <div class="updates-block__heading">
            <div>
              <p>{labels.archiveEyebrow}</p>
              <h2 id="updates-archive-title">{labels.archive}</h2>
            </div>
            <span>{labels.archiveHint}</span>
          </div>
          <div class="updates-archive__years">
            {archiveGroups.map((group) => (
              <section class="updates-archive__year" data-timeline-cluster aria-labelledby={`updates-archive-${group.year}`}>
                <div class="updates-archive__year-heading">
                  <h3 id={`updates-archive-${group.year}`}>{group.year}</h3>
                  <span data-timeline-cluster-count>{group.entries.length}</span>
                </div>
                <div class="updates-archive__grid">
                  {group.entries.map((entry) => <TimelineEntryCard entry={entry} lang={lang} variant="archive" />)}
                </div>
              </section>
            ))}
          </div>
        </section>
      )}

      <p class="updates-filter-empty" data-timeline-filter-empty hidden>{labels.empty}</p>
    </>
  ) : (
    <p class="updates-filter-empty">{labels.initialEmpty}</p>
  )}
</div>

<style>
  .updates-experience {
    display: grid;
    gap: 48px;
  }

  .updates-block {
    min-width: 0;
  }

  .updates-block__heading {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 24px;
    margin-bottom: 16px;
    padding-bottom: 10px;
    border-bottom: 1px solid var(--card-separator-color);
  }

  .updates-block__heading p {
    margin: 0 0 4px;
    color: var(--leftjun-primary);
    font-size: 12px;
    font-weight: 800;
    line-height: 1.4;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  .updates-block__heading h2 {
    margin: 0;
    color: var(--card-text-color-main);
    font-size: 26px;
    line-height: 1.25;
    letter-spacing: 0;
  }

  .updates-block__heading > span {
    max-width: 31rem;
    color: var(--card-text-color-tertiary);
    font-size: 14px;
    line-height: 1.5;
    text-align: right;
  }

  .updates-months,
  .updates-archive__years {
    display: grid;
    gap: 28px;
  }

  .updates-month {
    display: grid;
    grid-template-columns: minmax(92px, 0.2fr) minmax(0, 1fr);
    gap: 18px;
  }

  .updates-month > h3 {
    position: sticky;
    top: calc(var(--main-top-padding) + 10px);
    align-self: start;
    margin: 0;
    padding-top: 4px;
    color: var(--card-text-color-secondary);
    font-size: 14px;
    line-height: 1.45;
  }

  .updates-month__entries {
    position: relative;
    display: grid;
    gap: 16px;
    padding-left: 18px;
  }

  .updates-month__entries::before {
    position: absolute;
    inset: 0 auto 0 0;
    width: 2px;
    border-radius: 10px;
    background: linear-gradient(180deg, var(--leftjun-primary), var(--card-separator-color));
    content: "";
  }

  .updates-archive__year {
    display: grid;
    gap: 12px;
  }

  .updates-archive__year-heading {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .updates-archive__year-heading h3 {
    margin: 0;
    color: var(--card-text-color-main);
    font-size: 18px;
    letter-spacing: 0;
  }

  .updates-archive__year-heading span {
    display: inline-flex;
    min-width: 24px;
    min-height: 24px;
    align-items: center;
    justify-content: center;
    border-radius: 10px;
    background: color-mix(in srgb, var(--leftjun-primary) 10%, var(--leftjun-surface-muted));
    color: var(--leftjun-primary);
    font-size: 12px;
    font-weight: 760;
  }

  .updates-archive__grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 16px;
  }

  .updates-filter-empty {
    margin: 0;
    padding: 18px;
    border: 1px dashed var(--card-separator-color);
    border-radius: 16px;
    background: var(--leftjun-surface-muted);
    color: var(--card-text-color-secondary);
    text-align: center;
  }

  @media (max-width: 1000px) {
    .updates-experience {
      gap: 36px;
    }

    .updates-block__heading {
      margin-bottom: 14px;
    }

    .updates-block__heading h2 {
      font-size: 24px;
    }

    .updates-month {
      grid-template-columns: 1fr;
      gap: 10px;
    }

    .updates-month > h3 {
      position: static;
      padding-top: 0;
    }

    .updates-month__entries {
      padding-left: 12px;
    }

    .updates-archive__grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 767px) {
    .updates-experience {
      gap: 28px;
    }

    .updates-block__heading {
      display: block;
      margin-bottom: 12px;
      padding-bottom: 8px;
    }

    .updates-block__heading p,
    .updates-block__heading > span {
      display: none;
    }

    .updates-block__heading h2 {
      font-size: 20px;
    }

    .updates-month {
      gap: 8px;
    }

    .updates-month__entries {
      padding-left: 10px;
    }

    .updates-months,
    .updates-archive__years {
      gap: 24px;
    }
  }
</style>
