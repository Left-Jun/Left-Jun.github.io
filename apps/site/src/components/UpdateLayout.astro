---
import BaseLayout from "../layouts/BaseLayout.astro";
import CoverMedia from "./CoverMedia.astro";
import Icon from "./Icon.astro";
import RelatedCard from "./RelatedCard.astro";
import { getResponsiveMedia, mediaSrcset, optimizedPoster } from "../lib/media";
import {
  getEntryBySlug,
  relatedEntries,
  siteText,
  taxonomyTermUrl
} from "../lib/content.js";
import type { ProjectLink, SiteEntry, SiteLanguage } from "../lib/content.js";

interface Props {
  entry: SiteEntry;
  lang?: SiteLanguage;
}

const props = Astro.props as Props;
const { entry, lang = entry.lang } = props;
const text = siteText(lang);
const isEn = text.isEn;
const related = await relatedEntries(entry);
const projectLinks: ProjectLink[] = entry.data.projectLinks || [];
const tocItems = entry.toc || [];
const tagLinks = (entry.data.tags || []).filter(Boolean).map((tag: string) => ({
  name: tag,
  url: taxonomyTermUrl("tags", tag, lang)
}));

const kind = String(entry.data.kind || "release");
const status = String(entry.data.status || "");
const kindLabels: Record<string, string> = isEn
  ? {
      project: "Project update",
      event: "Event",
      award: "Award",
      training: "Training",
      research: "Research",
      release: "Release",
      article: "Publication"
    }
  : {
      project: "项目进展",
      event: "活动",
      award: "奖项",
      training: "训练",
      research: "研究",
      release: "发布",
      article: "文章"
    };
const statusLabels: Record<string, string> = isEn
  ? {
      planned: "Planned",
      "in-progress": "In progress",
      completed: "Completed",
      paused: "Paused",
      archived: "Archived"
    }
  : {
      planned: "计划中",
      "in-progress": "进行中",
      completed: "已完成",
      paused: "已暂停",
      archived: "已归档"
    };
const kindLabel = kindLabels[kind] || kind;
const statusLabel = statusLabels[status] || status;
const hasStructuredOutcome = [entry.data.contribution, entry.data.result]
  .some((value) => typeof value === "string" && value.trim());
const summaryItems = hasStructuredOutcome
  ? [
      { label: isEn ? "What happened" : "发生事项", value: entry.data.description },
      { label: isEn ? "My contribution" : "我的贡献", value: entry.data.contribution },
      { label: isEn ? "Outcome" : "结果", value: entry.data.result }
    ].filter((item) => typeof item.value === "string" && item.value.trim())
  : [];

const imageUrl = entry.data.image ? entry.asset(entry.data.image) : "";
const videoUrl = entry.data.coverVideo ? entry.asset(entry.data.coverVideo) : "";
const optimizedImageUrl = imageUrl ? optimizedPoster(imageUrl) : "";
const responsiveImage = imageUrl ? getResponsiveMedia(imageUrl) : null;
const priorityVariants = videoUrl
  ? []
  : (responsiveImage?.avif?.length ? responsiveImage.avif : responsiveImage?.webp || []);
const priorityImageUrl = videoUrl
  ? optimizedImageUrl
  : (priorityVariants.findLast((variant) => variant.width <= 1200)?.src || priorityVariants.at(-1)?.src || imageUrl);
const priorityImageSrcset = priorityVariants.length > 0 ? mediaSrcset(priorityVariants) : "";
const priorityImageType = priorityVariants.length > 0
  ? (responsiveImage?.avif?.length ? "image/avif" : "image/webp")
  : "";
const priorityImageSizes = "(max-width: 767px) calc(100vw - 24px), 920px";
const imagePosition = entry.data.imagePosition || "center";

const alternateLang: SiteLanguage = isEn ? "zh-cn" : "en";
const alternateEntry = await getEntryBySlug("updates", entry.slug, alternateLang);
const alternateUrl = alternateEntry?.url;
const alternateLabel = isEn ? "中文" : "English";
const sectionLabel = text.sections?.updates || (isEn ? "Updates" : "动态");
const sectionUrl = isEn ? "/en/updates/" : "/updates/";
const dateIso = entry.data.date instanceof Date ? entry.data.date.toISOString() : "";
---

<BaseLayout
  lang={lang}
  title={entry.data.title}
  description={entry.data.description}
  image={optimizedImageUrl || undefined}
  imageAlt={entry.data.title}
  priorityImage={priorityImageUrl || undefined}
  priorityImageSrcset={priorityImageSrcset || undefined}
  priorityImageSizes={priorityImageSrcset ? priorityImageSizes : undefined}
  priorityImageType={priorityImageType || undefined}
  active="updates"
  bodyClass="article-page update-detail-page"
  alternateUrl={alternateUrl}
  alternateLang={alternateEntry?.lang}
  ogType="article"
  creativeWork={{
    type: "CreativeWork",
    name: entry.data.title,
    description: entry.data.description,
    url: entry.url,
    image: optimizedImageUrl || undefined,
    datePublished: entry.data.date,
    dateModified: entry.data.updatedAt || entry.data.date,
    keywords: entry.data.tags || []
  }}
  breadcrumbs={[
    { name: isEn ? "Home" : "首页", url: isEn ? "/en/" : "/" },
    { name: sectionLabel, url: sectionUrl },
    { name: entry.data.title, url: entry.url }
  ]}
>
  <article
    class:list={["main-article", "update-detail", imageUrl && "has-media"]}
    style={`--leftjun-language-transition-name: lj-article-updates-${entry.slug};`}
  >
    <header class="update-detail-hero">
      {imageUrl && (
        <div class="update-detail-hero__media">
          <CoverMedia
            imageSrc={imageUrl}
            videoSrc={videoUrl}
            alt={entry.data.title}
            sizes={priorityImageSizes}
            loading="eager"
            fetchpriority="high"
            style={`object-position: ${imagePosition};`}
          />
        </div>
      )}

      <div class="update-detail-hero__body">
        <div class="update-detail-meta" aria-label={isEn ? "Update metadata" : "动态信息"}>
          <span class:list={["update-detail-kind", `update-detail-kind--${kind}`]}>{kindLabel}</span>
          {statusLabel && <span class="update-detail-status">{statusLabel}</span>}
          {entry.formattedDate && (
            <time datetime={dateIso || undefined}>
              <Icon name="date" label="" />
              <span>{entry.formattedDate}</span>
            </time>
          )}
        </div>
        <h1>{entry.data.title}</h1>
        {entry.data.description && <p class="update-detail-lead">{entry.data.description}</p>}
        {alternateUrl && (
          <a class="update-detail-language" href={alternateUrl} data-language-transition>
            <Icon name="language" label="" />
            <span>{alternateLabel}</span>
          </a>
        )}
      </div>
    </header>

    {summaryItems.length > 0 && (
      <section class:list={["update-detail-summary", `update-detail-summary--${summaryItems.length}`]} aria-label={isEn ? "Update summary" : "动态摘要"}>
        {summaryItems.map((item) => (
          <div class="update-detail-summary__item">
            <h2>{item.label}</h2>
            <p>{item.value}</p>
          </div>
        ))}
      </section>
    )}

    {projectLinks.length > 0 && (
      <section class="update-detail-evidence" aria-labelledby="update-evidence-title">
        <div class="update-detail-section-heading">
          <p>{isEn ? "Evidence" : "成果证据"}</p>
          <h2 id="update-evidence-title">{isEn ? "Links and deliverables" : "链接与交付物"}</h2>
        </div>
        <div class="update-detail-evidence__links">
          {projectLinks.map((link) => (
            <a href={link.url} target="_blank" rel="noopener noreferrer">
              <Icon name={link.icon || "link"} label="" />
              <span>{link.label}</span>
              <Icon name="chevron-right" label="" />
            </a>
          ))}
        </div>
      </section>
    )}

    {tocItems.length > 0 && (
      <aside class="article-toc update-detail-mobile-toc">
        <details>
          <summary>
            <div class="article-toc-title">
              <Icon name="chevron-right" label="" />
              <span>{text.toc}</span>
            </div>
          </summary>
          <nav class="toc-nav">
            {tocItems.map((item) => (
              <a href={`#${item.id}`} style={`--toc-indent:${Math.max(0, item.depth - 2) * 12}px`}>{item.text}</a>
            ))}
          </nav>
        </details>
      </aside>
    )}

    {entry.html && <section class="article-content update-detail-content" set:html={entry.html}></section>}

    {tagLinks.length > 0 && (
      <footer class="update-detail-footer">
        <div class="update-detail-tags" aria-label={isEn ? "Keywords" : "关键词"}>
          {tagLinks.map((tag) => <a href={tag.url}>{tag.name}</a>)}
        </div>
      </footer>
    )}
  </article>

  {related.length > 0 && (
    <aside class="related-content--wrapper update-detail-related" aria-label={text.relatedReading}>
      <h2 class="section-title">{isEn ? "Related work" : "关联内容"}</h2>
      <div class="related-content">
        <div class="related-grid">
          {related.map((item) => <RelatedCard entry={item} />)}
        </div>
      </div>
    </aside>
  )}

  {tocItems.length > 0 && (
    <Fragment slot="right-sidebar">
      <aside class="sidebar right-sidebar sticky update-detail-sidebar">
        <section class="widget widget--toc update-detail-sidebar__toc">
          <h2 class="widget-title">{text.toc}</h2>
          <nav class="toc-nav">
            {tocItems.map((item) => (
              <a href={`#${item.id}`} style={`--toc-indent:${Math.max(0, item.depth - 2) * 12}px`}>{item.text}</a>
            ))}
          </nav>
        </section>
      </aside>
    </Fragment>
  )}
</BaseLayout>

<style>
  .update-detail {
    overflow: hidden;
    border-radius: var(--leftjun-radius-lg);
    background: var(--leftjun-reading-surface);
    box-shadow: var(--leftjun-surface-shadow);
  }

  .update-detail-hero {
    background: var(--leftjun-reading-surface);
  }

  .update-detail-hero__media {
    overflow: hidden;
    border-bottom: 1px solid var(--card-separator-color);
    background: var(--leftjun-surface-muted);
  }

  .update-detail-hero__media :global(picture),
  .update-detail-hero__media :global(img),
  .update-detail-hero__media :global(video) {
    display: block;
    width: 100%;
  }

  .update-detail-hero__media :global(img),
  .update-detail-hero__media :global(video) {
    height: auto;
    max-height: none;
    object-fit: contain;
    background: var(--leftjun-surface-muted);
  }

  .update-detail-hero__body {
    padding: 28px var(--card-padding) 30px;
  }

  .update-detail-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 8px;
    margin-bottom: 14px;
  }

  .update-detail-meta > span,
  .update-detail-meta time,
  .update-detail-language {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    min-height: 30px;
    padding: 6px 10px;
    border: 1px solid var(--card-separator-color);
    border-radius: var(--leftjun-radius-sm);
    font-size: 13px;
    font-weight: 850;
    line-height: 1;
  }

  .update-detail-meta time {
    border-color: transparent;
    color: var(--card-text-color-tertiary);
  }

  .update-detail-meta time :global(.inline-icon),
  .update-detail-language :global(.inline-icon) {
    width: 14px;
    height: 14px;
  }

  .update-detail-kind {
    background: var(--leftjun-primary-soft);
    color: var(--leftjun-primary-deep);
  }

  .update-detail-kind--event,
  .update-detail-kind--award {
    border-color: color-mix(in srgb, #c58a12 28%, var(--card-separator-color)) !important;
    background: color-mix(in srgb, #d9a11d 12%, var(--leftjun-surface-strong)) !important;
    color: color-mix(in srgb, #9a6500 82%, var(--card-text-color-main)) !important;
  }

  .update-detail-kind--training,
  .update-detail-kind--research {
    border-color: color-mix(in srgb, #0f8f88 28%, var(--card-separator-color)) !important;
    background: color-mix(in srgb, #0f8f88 11%, var(--leftjun-surface-strong)) !important;
    color: color-mix(in srgb, #0f766e 86%, var(--card-text-color-main)) !important;
  }

  .update-detail-kind--release,
  .update-detail-kind--article {
    border-color: color-mix(in srgb, #dc6b55 26%, var(--card-separator-color)) !important;
    background: color-mix(in srgb, #dc6b55 10%, var(--leftjun-surface-strong)) !important;
    color: color-mix(in srgb, #b54c3a 82%, var(--card-text-color-main)) !important;
  }

  .update-detail-status {
    background: color-mix(in srgb, var(--leftjun-surface-muted) 88%, transparent);
    color: var(--card-text-color-secondary);
  }

  .update-detail h1 {
    max-width: 52rem;
    margin: 0;
    color: var(--card-text-color-main);
    font-size: 42px;
    font-weight: 900;
    line-height: 1.1;
    text-wrap: balance;
  }

  .update-detail-lead {
    max-width: 50rem;
    margin: 12px 0 0;
    color: var(--card-text-color-secondary);
    font-size: 17px;
    line-height: 1.65;
  }

  .update-detail-language {
    width: max-content;
    margin-top: 14px;
    background: color-mix(in srgb, var(--leftjun-primary) 7%, var(--leftjun-surface-strong));
    color: var(--leftjun-primary);
    transition: transform var(--leftjun-hover-duration) ease, border-color var(--leftjun-hover-duration) ease, box-shadow var(--leftjun-hover-duration) ease;
  }

  .update-detail-language:hover,
  .update-detail-language:focus-visible {
    transform: translateY(var(--leftjun-hover-lift));
    border-color: var(--leftjun-hover-border);
    box-shadow: var(--leftjun-hover-shadow);
  }

  .update-detail-summary {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    margin: 0 var(--card-padding);
    border-top: 1px solid var(--card-separator-color);
    border-bottom: 1px solid var(--card-separator-color);
  }

  .update-detail-summary--1 {
    grid-template-columns: 1fr;
  }

  .update-detail-summary--2 {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .update-detail-summary__item {
    min-width: 0;
    padding: 20px;
  }

  .update-detail-summary__item + .update-detail-summary__item {
    border-left: 1px solid var(--card-separator-color);
  }

  .update-detail-summary h2,
  .update-detail-summary p {
    margin: 0;
  }

  .update-detail-summary h2 {
    color: var(--leftjun-primary);
    font-size: 12.5px;
    font-weight: 900;
    line-height: 1.4;
  }

  .update-detail-summary p {
    margin-top: 8px;
    color: var(--card-text-color-main);
    font-size: 15.5px;
    line-height: 1.6;
  }

  .update-detail-evidence {
    display: grid;
    grid-template-columns: minmax(0, 0.7fr) minmax(0, 1.3fr);
    gap: 20px;
    margin: 0 var(--card-padding);
    padding: 20px 0;
    border-bottom: 1px solid var(--card-separator-color);
  }

  .update-detail-section-heading p,
  .update-detail-section-heading h2 {
    margin: 0;
  }

  .update-detail-section-heading p {
    color: var(--leftjun-primary);
    font-size: 12.5px;
    font-weight: 900;
    line-height: 1.4;
  }

  .update-detail-section-heading h2 {
    margin-top: 6px;
    color: var(--card-text-color-main);
    font-size: 20px;
    line-height: 1.3;
  }

  .update-detail-evidence__links {
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-end;
    gap: 10px;
  }

  .update-detail-evidence__links a {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    min-height: 44px;
    padding: 10px 12px;
    border: 1px solid color-mix(in srgb, var(--leftjun-primary) 24%, var(--card-separator-color));
    border-radius: var(--leftjun-radius-sm);
    background: color-mix(in srgb, var(--leftjun-primary) 8%, var(--leftjun-surface-strong));
    color: var(--leftjun-primary-deep);
    font-size: 14px;
    font-weight: 850;
    line-height: 1.3;
    transition: transform var(--leftjun-hover-duration) ease, border-color var(--leftjun-hover-duration) ease, box-shadow var(--leftjun-hover-duration) ease;
  }

  .update-detail-evidence__links a:hover,
  .update-detail-evidence__links a:focus-visible {
    transform: translateY(var(--leftjun-hover-lift));
    border-color: var(--leftjun-hover-border);
    box-shadow: var(--leftjun-hover-shadow);
  }

  .update-detail-evidence__links :global(.inline-icon) {
    width: 16px;
    height: 16px;
  }

  .update-detail-evidence__links :global(.inline-icon:last-child) {
    color: var(--card-text-color-tertiary);
  }

  .update-detail-content {
    padding-top: 24px;
  }

  .update-detail-content :global(video) {
    height: auto;
  }

  .update-detail-footer {
    margin: 0 var(--card-padding) var(--card-padding);
    padding-top: 8px;
  }

  .update-detail-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .update-detail-tags a {
    display: inline-flex;
    align-items: center;
    min-height: 30px;
    padding: 6px 10px;
    border: 1px solid var(--card-separator-color);
    border-radius: var(--leftjun-radius-sm);
    background: var(--leftjun-surface-muted);
    color: var(--card-text-color-secondary);
    font-size: 12.5px;
    font-weight: 800;
    line-height: 1.3;
  }

  .update-detail-related {
    max-width: 100%;
  }

  .update-detail-sidebar {
    overflow: visible;
  }

  .update-detail-sidebar__toc {
    display: flex;
    max-height: calc(100vh - var(--right-sidebar-sticky-top) - 24px);
    flex-direction: column;
    overflow: hidden;
  }

  .update-detail-sidebar__toc .widget-title {
    flex: 0 0 auto;
  }

  .update-detail-sidebar__toc .toc-nav {
    min-height: 0;
    overflow-y: auto;
    overscroll-behavior: contain;
    scrollbar-width: thin;
  }

  @media (max-width: 1000px) {
    .update-detail-hero__body {
      padding: 24px var(--card-padding) 26px;
    }

    .update-detail h1 {
      font-size: 34px;
    }

    .update-detail-summary,
    .update-detail-summary--2,
    .update-detail-summary--3 {
      grid-template-columns: 1fr;
    }

    .update-detail-summary__item {
      padding: 18px;
    }

    .update-detail-summary__item + .update-detail-summary__item {
      border-top: 1px solid var(--card-separator-color);
      border-left: 0;
    }

    .update-detail-evidence {
      grid-template-columns: 1fr;
      gap: 16px;
    }

    .update-detail-evidence__links {
      justify-content: flex-start;
    }

    .update-detail-content {
      padding-top: 20px;
    }
  }

  @media (max-width: 767px) {
    .update-detail {
      border-radius: var(--leftjun-radius-lg);
    }

    .update-detail-hero__body {
      padding: 18px 16px 20px;
    }

    .update-detail h1 {
      font-size: 28px;
    }

    .update-detail-lead {
      font-size: 16px;
      line-height: 1.65;
    }

    .update-detail-summary,
    .update-detail-summary--2,
    .update-detail-summary--3 {
      grid-template-columns: 1fr;
      margin-inline: 16px;
    }

    .update-detail-summary__item {
      padding: 16px 0;
    }

    .update-detail-summary__item + .update-detail-summary__item {
      border-top: 1px solid var(--card-separator-color);
      border-left: 0;
    }

    .update-detail-evidence {
      grid-template-columns: 1fr;
      gap: 12px;
      margin-inline: 16px;
      padding: 18px 0;
    }

    .update-detail-evidence__links {
      justify-content: flex-start;
    }

    .update-detail-evidence__links a {
      width: 100%;
      justify-content: flex-start;
    }

    .update-detail-evidence__links a :global(.inline-icon:last-child) {
      margin-left: auto;
    }

    .update-detail-content {
      padding: 18px 16px 16px;
    }

    .update-detail-footer {
      margin: 0 16px 16px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .update-detail-language,
    .update-detail-evidence__links a {
      transition: none;
    }
  }
</style>
