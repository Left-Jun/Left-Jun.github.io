---
const { entry, compact = true } = Astro.props;
const terms: string[] = [...(entry.data.categories || []), ...(entry.data.tags || [])];
const image = entry.data.image;
const imagePosition = entry.data.imagePosition || "center";
---
<article class:list={["post-card", compact && "post-card--compact", image && "has-image"]}>
  <a href={entry.url}>
    <div class="article-details">
      <div class="compact-title-row">
        <h2 class="article-title">{entry.data.title}</h2>
        {terms.length > 0 && (
          <div class="compact-pill-list">
            {terms.slice(0, 3).map((term) => <span class="compact-pill">{term}</span>)}
          </div>
        )}
      </div>
      {entry.data.description && <p class="compact-subtitle">{entry.data.description}</p>}
      {entry.formattedDate && <time class="article-time" datetime={entry.data.date?.toISOString?.()}>{entry.formattedDate}</time>}
    </div>
    {image && (
      <div class="article-image">
        <img src={entry.asset(image)} alt={entry.data.title} loading="lazy" style={`object-position: ${imagePosition};`} />
      </div>
    )}
  </a>
</article>
