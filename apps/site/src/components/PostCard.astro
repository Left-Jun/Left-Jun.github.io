---
import ResponsiveImage from "./ResponsiveImage.astro";
import { taxonomySlug } from "../lib/content.js";

const { entry, compact = true, columnBadges = [] } = Astro.props;
const terms: string[] = [...(entry.data.categories || []), ...(entry.data.tags || [])];
const categorySlugs = (entry.data.categories || []).map((term: string) => taxonomySlug(term)).filter(Boolean);
const tagSlugs = (entry.data.tags || []).map((term: string) => taxonomySlug(term)).filter(Boolean);
const image = entry.data.image;
const imageUrl = image ? entry.asset(image) : "";
const imagePosition = entry.data.imagePosition || "center";
const visibleColumnBadges = Array.isArray(columnBadges) ? columnBadges.filter(Boolean) : [];
---
<article
  class:list={["post-card", compact && "post-card--compact", image && "has-image"]}
  data-entry-categories={categorySlugs.join(" ")}
  data-entry-tags={tagSlugs.join(" ")}
  data-entry-section={entry.section}
  style={`--leftjun-language-transition-name: lj-entry-${entry.section}-${entry.slug};`}
>
  <a href={entry.url}>
    <div class="article-details">
      {visibleColumnBadges.length > 0 && (
        <div class="post-card-column-badges" aria-label="column">
          {visibleColumnBadges.map((badge: string) => <span class="post-card-column-badge">{badge}</span>)}
        </div>
      )}
      <div class="compact-title-row">
        <h2 class="article-title">{entry.data.title}</h2>
        {terms.length > 0 && (
          <div class="compact-pill-list">
            {terms.slice(0, 3).map((term) => <span class="compact-pill">{term}</span>)}
          </div>
        )}
      </div>
      {entry.data.description && <p class="compact-subtitle">{entry.data.description}</p>}
      {entry.formattedDate && <time class="article-time" datetime={entry.data.date?.toISOString?.()}>{entry.formattedDate}</time>}
    </div>
    {image && (
      <div class="article-image">
        <ResponsiveImage
          src={imageUrl}
          alt={entry.data.title}
          sizes="(max-width: 767px) 92vw, 280px"
          loading="lazy"
          style={`object-position: ${imagePosition};`}
        />
      </div>
    )}
  </a>
</article>
