---
import Icon from "./Icon.astro";
import { siteText, taxonomySlug, taxonomyTermUrl } from "../lib/content.js";

type SidebarEntry = {
  slug: string;
  data: {
    title: string;
    categories?: string[];
    tags?: string[];
    portfolioType?: string;
  };
};

type SidebarProps = {
  type?: "terms" | "projects" | "records";
  lang?: "zh-cn" | "en";
  entries?: SidebarEntry[];
  categoryEntries?: SidebarEntry[];
  activeKind?: "categories" | "tags";
  activeSlug?: string;
  resetUrl?: string;
  localFilters?: boolean;
  sectionPage?: {
    data?: Record<string, string>;
  } | null;
};

const {
  type = "terms",
  lang = "zh-cn",
  entries = [],
  categoryEntries = undefined,
  activeKind = undefined,
  activeSlug = "",
  resetUrl = "",
  localFilters = type !== "projects",
  sectionPage = null
} = Astro.props as SidebarProps;

const text = siteText(lang);
const data = sectionPage?.data || {};
const isEn = text.isEn;
const normalizedActiveSlug = activeSlug ? taxonomySlug(activeSlug) : "";

function collectTerms(items: SidebarEntry[], field: "categories" | "tags", limit = 10) {
  const terms = new Map<string, { slug: string; name: string; count: number }>();
  for (const entry of items) {
    for (const term of entry.data?.[field] || []) {
      const name = String(term || "").trim();
      if (!name) continue;
      const slug = taxonomySlug(name);
      const record = terms.get(slug);
      if (record) {
        record.count += 1;
      } else {
        terms.set(slug, { slug, name, count: 1 });
      }
    }
  }
  const sorted = [...terms.values()].sort((a, b) => {
    const aActive = activeKind === field && a.slug === normalizedActiveSlug;
    const bActive = activeKind === field && b.slug === normalizedActiveSlug;
    if (aActive !== bActive) return aActive ? -1 : 1;
    return b.count - a.count || a.name.localeCompare(b.name, lang);
  });
  const visible = sorted.slice(0, limit);
  const activeTerm = activeKind === field ? sorted.find((term) => term.slug === normalizedActiveSlug) : undefined;
  if (activeTerm && !visible.some((term) => term.slug === activeTerm.slug)) {
    if (visible.length >= limit) {
      visible[visible.length - 1] = activeTerm;
    } else {
      visible.push(activeTerm);
    }
  }
  return visible.map((term) => ({
    ...term,
    active: activeKind === field && normalizedActiveSlug === term.slug,
    url: activeKind === field && normalizedActiveSlug === term.slug && resetUrl
      ? resetUrl
      : taxonomyTermUrl(field, term.name, lang),
    title: activeKind === field && normalizedActiveSlug === term.slug && resetUrl
      ? (isEn ? `Clear ${term.name}` : `清除 ${term.name}`)
      : `${term.name} (${term.count})`
  }));
}

const categories = collectTerms(categoryEntries ?? entries, "categories", 5);
const tags = collectTerms(entries, "tags", 8);
const recordsFilterTitle = isEn ? "Categories" : "分类";
const retrospectiveLabel = isEn ? "Retrospectives" : "项目复盘";
const planLabel = isEn ? "Development Plans" : "开发计划";
const projectTypes = [...new Set(entries.map((entry) => entry.data.portfolioType || "other"))];
const projectTypeLabels: Record<string, string> = {
  game: data.gameFilterLabel || (isEn ? "Game Development" : "游戏开发"),
  embedded: data.embeddedFilterLabel || (isEn ? "Embedded Development" : "嵌入式开发"),
  web: data.webFilterLabel || (isEn ? "Web Development" : "Web 开发"),
  other: isEn ? "Other Projects" : "其他项目"
};
const projectTypeLabel = (projectType: string) => projectTypeLabels[projectType] || projectType.replace(/[-_]+/g, " ");
const typeTitle = data.typeTitle || (isEn ? "Project Types" : "项目类型");
const indexTitle = data.indexTitle || (isEn ? "Project Index" : "项目索引");
const categoryTitle = localFilters ? (isEn ? "Categories" : "分类") : (isEn ? "Related Categories" : "相关分类");
const tagTitle = localFilters ? (isEn ? "Topics" : "主题筛选") : (isEn ? "Related Topics" : "相关主题");
---

<aside class:list={["sidebar right-sidebar sticky", type === "projects" && "project-index-sidebar", type === "records" && "records-filter-sidebar"]}>
  {type === "projects" ? (
    <>
      <section class="widget project-type-widget">
        <div class="widget-icon" aria-hidden="true">
          <Icon name="categories" />
        </div>
        <h2 class="widget-title section-title">{typeTitle}</h2>
        <div class="project-index-type-list" role="group" aria-label={data.filterAriaLabel || (isEn ? "Filter project categories" : "筛选项目分类")}>
          {projectTypes.map((projectType) => (
            <button class="project-index-type-button" type="button" data-filter-target={projectType}>{projectTypeLabel(projectType)}</button>
          ))}
        </div>
      </section>

      <section class="widget project-index-widget">
        <div class="widget-icon" aria-hidden="true">
          <Icon name="link" />
        </div>
        <h2 class="widget-title section-title">{indexTitle}</h2>
        <ol class="project-index-list">
          {entries.map((entry) => (
            <li data-project-type={entry.data.portfolioType || "other"}>
              <a href={`#project-${entry.slug}`}>{entry.data.title}</a>
            </li>
          ))}
        </ol>
      </section>
    </>
  ) : type === "records" ? (
    <>
      <section class="widget project-type-widget records-filter-widget">
        <div class="widget-icon" aria-hidden="true">
          <Icon name="categories" />
        </div>
        <h2 class="widget-title section-title">{recordsFilterTitle}</h2>
        <div class="project-index-type-list records-filter-list" role="group" aria-label={isEn ? "Filter records" : "筛选项目记录"}>
          <button class="project-index-type-button records-filter-button" type="button" data-record-filter="retrospectives">{retrospectiveLabel}</button>
          <button class="project-index-type-button records-filter-button" type="button" data-record-filter="plans">{planLabel}</button>
        </div>
      </section>

      {tags.length > 0 && (
        <section class="widget tagCloud local-filter-widget">
          <div class="widget-icon" aria-hidden="true">
            <Icon name="tag" />
          </div>
          <h2 class="widget-title section-title">{tagTitle}</h2>
          <div class="tagCloud-tags local-filter-tags" role="group" aria-label={isEn ? "Filter by topic" : "按主题筛选"}>
            {tags.map((term) => (
              <button
                class:list={[term.active && "is-active"]}
                type="button"
                data-local-filter={term.slug}
                data-local-filter-kind="tags"
                aria-pressed="false"
                title={`${term.name} (${term.count})`}
              >
                {term.name}
              </button>
            ))}
          </div>
        </section>
      )}
    </>
  ) : (
    <>
      {categories.length > 0 && (
        <section class="widget tagCloud local-filter-widget">
          <div class="widget-icon" aria-hidden="true">
            <Icon name="categories" />
          </div>
          <h2 class="widget-title section-title">{categoryTitle}</h2>
          <div class="tagCloud-tags local-filter-tags" role={localFilters ? "group" : undefined} aria-label={localFilters ? (isEn ? "Filter by category" : "按分类筛选") : undefined}>
            {categories.map((term) => (
              localFilters ? (
                <button
                  class:list={[term.active && "is-active"]}
                  type="button"
                  data-local-filter={term.slug}
                  data-local-filter-kind="categories"
                  aria-pressed="false"
                  title={`${term.name} (${term.count})`}
                >
                  {term.name}
                </button>
              ) : (
                <a class:list={[term.active && "is-active"]} href={term.url} aria-current={term.active ? "page" : undefined} title={term.title}>
                  {term.name}
                </a>
              )
            ))}
          </div>
        </section>
      )}
      {tags.length > 0 && (
        <section class="widget tagCloud local-filter-widget">
          <div class="widget-icon" aria-hidden="true">
            <Icon name="tag" />
          </div>
          <h2 class="widget-title section-title">{tagTitle}</h2>
          <div class="tagCloud-tags local-filter-tags" role={localFilters ? "group" : undefined} aria-label={localFilters ? (isEn ? "Filter by topic" : "按主题筛选") : undefined}>
            {tags.map((term) => (
              localFilters ? (
                <button
                  class:list={[term.active && "is-active"]}
                  type="button"
                  data-local-filter={term.slug}
                  data-local-filter-kind="tags"
                  aria-pressed="false"
                  title={`${term.name} (${term.count})`}
                >
                  {term.name}
                </button>
              ) : (
                <a class:list={[term.active && "is-active"]} href={term.url} aria-current={term.active ? "page" : undefined} title={term.title}>
                  {term.name}
                </a>
              )
            ))}
          </div>
        </section>
      )}
    </>
  )}
</aside>
